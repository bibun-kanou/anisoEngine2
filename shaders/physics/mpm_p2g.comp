mat2 vec4_to_mat2(vec4 v) { return mat2(v.x, v.y, v.z, v.w); }
vec4 mat2_to_vec4(mat2 m) { return vec4(m[0].x, m[0].y, m[1].x, m[1].y); }
// Integer hash — no sin() bias on any GPU
float hash1(vec2 p) {
    uvec2 q = uvec2(floatBitsToUint(p.x), floatBitsToUint(p.y));
    uint h = q.x * 0x45d9f3bu ^ q.y * 0x1e35a7bdu;
    h = (h ^ (h >> 16u)) * 0x45d9f3bu;
    h = h ^ (h >> 16u);
    return float(h & 0xFFFFu) / 65535.0;
}

mat2 outer2(vec2 a, vec2 b) {
    return mat2(a.x * b.x, a.x * b.y,
                a.y * b.x, a.y * b.y);
}

mat2 oriented_growth_target(vec2 dir, float along, float across) {
    vec2 axis = (length(dir) > 1e-6) ? normalize(dir) : vec2(1.0, 0.0);
    vec2 perp = vec2(-axis.y, axis.x);
    return mat2(1.0) + along * outer2(axis, axis) + across * outer2(perp, perp);
}

float magnetic_falloff(vec2 pos, out vec2 dir, out vec2 tangent) {
    vec2 to_magnet = u_magnet_pos - pos;
    float dist = length(to_magnet);
    float inner_radius = max(u_magnet_radius, 1e-4);
    float outer_radius = max(u_magnet_falloff_radius, inner_radius);
    if (abs(u_magnet_force) <= 1e-4 || dist <= 1e-5) {
        dir = vec2(0.0, 1.0);
        tangent = vec2(1.0, 0.0);
        return 0.0;
    }
    vec2 shaped = vec2(to_magnet.x * 0.28,
                       sign(to_magnet.y) * max(abs(to_magnet.y), inner_radius * 0.22));
    dir = normalize(shaped);
    tangent = vec2(-dir.y, dir.x);
    float axial = dot(to_magnet, dir);
    float lateral = abs(dot(to_magnet, tangent));
    float brush_band = 0.0;
    if (dist < outer_radius) {
        if (dist <= inner_radius || outer_radius <= inner_radius + 1e-4) {
            brush_band = 1.0;
        } else {
            float t = clamp((dist - inner_radius) / (outer_radius - inner_radius), 0.0, 1.0);
            brush_band = 1.0 - t * t * (3.0 - 2.0 * t);
        }
    }
    float axial_band = clamp((axial + inner_radius * 0.18) / (outer_radius + inner_radius * 0.18), 0.0, 1.0);
    float lateral_band = clamp(1.0 - lateral / (outer_radius * 0.92 + 1e-4), 0.0, 1.0);
    return brush_band * axial_band * lateral_band * lateral_band;
}

vec4 sample_magnetic_drive_field(vec2 pos) {
    vec2 uv = (pos - u_magnetic_world_min) / (u_magnetic_world_max - u_magnetic_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return vec4(0.0);
    return texture(u_magnetic_drive_tex, uv);
}

vec4 sample_magnetic_drive_field_smooth(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_drive_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    vec4 c = sample_magnetic_drive_field(pos) * 0.34;
    vec4 ax = (sample_magnetic_drive_field(pos + vec2(cell.x, 0.0)) +
               sample_magnetic_drive_field(pos - vec2(cell.x, 0.0)) +
               sample_magnetic_drive_field(pos + vec2(0.0, cell.y)) +
               sample_magnetic_drive_field(pos - vec2(0.0, cell.y))) * 0.12;
    vec4 dg = (sample_magnetic_drive_field(pos + cell) +
               sample_magnetic_drive_field(pos + vec2(cell.x, -cell.y)) +
               sample_magnetic_drive_field(pos + vec2(-cell.x, cell.y)) +
               sample_magnetic_drive_field(pos - cell)) * 0.045;
    return c + ax + dg;
}

vec4 sample_magnetic_drive_field_bulk(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_drive_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    vec4 sum = sample_magnetic_drive_field(pos) * 0.14;
    sum += (sample_magnetic_drive_field(pos + vec2(cell.x, 0.0)) +
            sample_magnetic_drive_field(pos - vec2(cell.x, 0.0)) +
            sample_magnetic_drive_field(pos + vec2(0.0, cell.y)) +
            sample_magnetic_drive_field(pos - vec2(0.0, cell.y))) * 0.09;
    sum += (sample_magnetic_drive_field(pos + cell) +
            sample_magnetic_drive_field(pos + vec2(cell.x, -cell.y)) +
            sample_magnetic_drive_field(pos + vec2(-cell.x, cell.y)) +
            sample_magnetic_drive_field(pos - cell)) * 0.07;
    sum += (sample_magnetic_drive_field(pos + vec2(2.0 * cell.x, 0.0)) +
            sample_magnetic_drive_field(pos - vec2(2.0 * cell.x, 0.0)) +
            sample_magnetic_drive_field(pos + vec2(0.0, 2.0 * cell.y)) +
            sample_magnetic_drive_field(pos - vec2(0.0, 2.0 * cell.y))) * 0.05;
    sum += (sample_magnetic_drive_field(pos + vec2(2.0 * cell.x,  cell.y)) +
            sample_magnetic_drive_field(pos + vec2(2.0 * cell.x, -cell.y)) +
            sample_magnetic_drive_field(pos + vec2(-2.0 * cell.x,  cell.y)) +
            sample_magnetic_drive_field(pos + vec2(-2.0 * cell.x, -cell.y)) +
            sample_magnetic_drive_field(pos + vec2( cell.x, 2.0 * cell.y)) +
            sample_magnetic_drive_field(pos + vec2(-cell.x, 2.0 * cell.y)) +
            sample_magnetic_drive_field(pos + vec2( cell.x,-2.0 * cell.y)) +
            sample_magnetic_drive_field(pos + vec2(-cell.x,-2.0 * cell.y))) * 0.025;
    return sum;
}

vec4 sample_magnetic_total_field(vec2 pos) {
    vec2 uv = (pos - u_magnetic_world_min) / (u_magnetic_world_max - u_magnetic_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return vec4(0.0);
    return texture(u_magnetic_total_tex, uv);
}

vec4 sample_magnetic_total_field_smooth(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_total_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    vec4 c = sample_magnetic_total_field(pos) * 0.34;
    vec4 ax = (sample_magnetic_total_field(pos + vec2(cell.x, 0.0)) +
               sample_magnetic_total_field(pos - vec2(cell.x, 0.0)) +
               sample_magnetic_total_field(pos + vec2(0.0, cell.y)) +
               sample_magnetic_total_field(pos - vec2(0.0, cell.y))) * 0.12;
    vec4 dg = (sample_magnetic_total_field(pos + cell) +
               sample_magnetic_total_field(pos + vec2(cell.x, -cell.y)) +
               sample_magnetic_total_field(pos + vec2(-cell.x, cell.y)) +
               sample_magnetic_total_field(pos - cell)) * 0.045;
    return c + ax + dg;
}

float sample_magnetic_occupancy(vec2 pos) {
    vec2 uv = (pos - u_magnetic_world_min) / (u_magnetic_world_max - u_magnetic_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_magnetic_material_tex, uv).z;
}

float sample_magnetic_occupancy_smooth(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_material_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float c = sample_magnetic_occupancy(pos) * 0.50;
    float ax = (sample_magnetic_occupancy(pos + vec2(cell.x, 0.0)) +
                sample_magnetic_occupancy(pos - vec2(cell.x, 0.0)) +
                sample_magnetic_occupancy(pos + vec2(0.0, cell.y)) +
                sample_magnetic_occupancy(pos - vec2(0.0, cell.y))) * 0.10;
    float dg = (sample_magnetic_occupancy(pos + cell) +
                sample_magnetic_occupancy(pos + vec2(cell.x, -cell.y)) +
                sample_magnetic_occupancy(pos + vec2(-cell.x, cell.y)) +
                sample_magnetic_occupancy(pos - cell)) * 0.025;
    return c + ax + dg;
}

vec2 magnetic_grad_h2(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_drive_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float h2_l = sample_magnetic_drive_field_smooth(pos - vec2(cell.x, 0.0)).w;
    float h2_r = sample_magnetic_drive_field_smooth(pos + vec2(cell.x, 0.0)).w;
    float h2_b = sample_magnetic_drive_field_smooth(pos - vec2(0.0, cell.y)).w;
    float h2_t = sample_magnetic_drive_field_smooth(pos + vec2(0.0, cell.y)).w;
    return vec2((h2_r - h2_l) / max(2.0 * cell.x, 1e-5),
                (h2_t - h2_b) / max(2.0 * cell.y, 1e-5));
}

float magnetic_drive_response_gate(vec2 pos, out vec4 bulk_field, out vec2 grad_h2, out float grad_mag) {
    ivec2 res = textureSize(u_magnetic_drive_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float h2_l = sample_magnetic_drive_field_bulk(pos - vec2(cell.x, 0.0)).w;
    float h2_r = sample_magnetic_drive_field_bulk(pos + vec2(cell.x, 0.0)).w;
    float h2_b = sample_magnetic_drive_field_bulk(pos - vec2(0.0, cell.y)).w;
    float h2_t = sample_magnetic_drive_field_bulk(pos + vec2(0.0, cell.y)).w;
    grad_h2 = vec2((h2_r - h2_l) / max(2.0 * cell.x, 1e-5),
                   (h2_t - h2_b) / max(2.0 * cell.y, 1e-5));
    grad_mag = length(grad_h2);
    bulk_field = sample_magnetic_drive_field_bulk(pos);
    float bulk_h2 = bulk_field.w;
    float local_h2 = sample_magnetic_drive_field_smooth(pos).w;
    float sharpness = max(local_h2 - bulk_h2, 0.0) / max(bulk_h2, 1e-4);
    float grad_ratio = grad_mag / max(local_h2, 1e-4);
    float bulk_ratio = clamp(bulk_h2 / max(local_h2, 1e-4), 0.0, 1.0);
    float gate = bulk_ratio / (1.0 + 1.8 * sharpness + 0.08 * grad_ratio);
    return clamp(gate, 0.06, 1.0);
}

vec2 magnetic_occ_grad(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_material_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float occ_l = sample_magnetic_occupancy(pos - vec2(cell.x, 0.0));
    float occ_r = sample_magnetic_occupancy(pos + vec2(cell.x, 0.0));
    float occ_b = sample_magnetic_occupancy(pos - vec2(0.0, cell.y));
    float occ_t = sample_magnetic_occupancy(pos + vec2(0.0, cell.y));
    return vec2((occ_r - occ_l) / max(2.0 * cell.x, 1e-5),
                (occ_t - occ_b) / max(2.0 * cell.y, 1e-5));
}

float sample_sdf_distance(vec2 pos) {
    if (u_use_sdf == 0) return 1e6;
    vec2 uv = (pos - u_sdf_world_min) / (u_sdf_world_max - u_sdf_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 1e6;
    return texture(u_sdf_tex, uv).r;
}

float magnetic_wall_gate(vec2 pos, float min_keep) {
    float d = sample_sdf_distance(pos);
    float near = smoothstep(u_dx * 2.0, u_dx * 7.0, max(d, 0.0));
    return mix(min_keep, 1.0, near);
}

