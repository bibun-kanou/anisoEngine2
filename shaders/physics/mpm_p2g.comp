void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= u_count) return;

    uint p = u_offset + idx;
    vec2 pos  = positions[p];
    vec2 vel  = velocities[p];
    float mass = masses[p];
    uint mat_type = material_ids[p];
    float temp = temperatures[p];

    // Hard velocity clamp — 3 cells/step max (very conservative)
    float spd = length(vel);
    float max_v = u_dx * 3.0 / u_dt;
    if (spd > max_v || spd != spd) {
        vel = (spd != spd) ? vec2(0.0) : vel * (max_v / spd);
    }

    float inv_dx = 1.0 / u_dx;

    vec2 cell_pos = (pos - u_grid_origin) * inv_dx;
    ivec2 base = ivec2(floor(cell_pos - 0.5));
    vec2 fx = cell_pos - vec2(base);
    vec3 wx = bspline_weights(fx.x);
    vec3 wy = bspline_weights(fx.y);

    // --- Update deformation gradient ---
    mat2 F = vec4_to_mat2(deform_grads[idx]);
    mat2 C = vec4_to_mat2(affine_moms[idx]);
    F = (mat2(1.0) + u_dt * C) * F;

    SVD2 svd = svd2x2(F);
    // Tighter clamp for solid materials (prevent excessive compression)
    bool is_solid_mat = (mat_type == MAT_ELASTIC || mat_type == MAT_ANISO ||
                         mat_type == MAT_FRACTURE || mat_type == MAT_HARDEN ||
                         mat_type == MAT_CERAMIC || mat_type == MAT_COMPOSITE ||
                         mat_type == MAT_BRITTLE || mat_type == MAT_TOUGH ||
                         mat_type == MAT_GLASS || mat_type == MAT_BLOOM ||
                         mat_type == MAT_FOAM || mat_type == MAT_SPLINTER ||
                         mat_type == MAT_BREAD || mat_type == MAT_PUFF_CLAY ||
                         mat_type == MAT_FIRECRACKER || mat_type == MAT_GLAZE_CLAY ||
                         mat_type == MAT_CRUST_DOUGH || mat_type == MAT_THERMO_METAL ||
                         mat_type == MAT_REACTIVE_BURN || mat_type == MAT_GLAZE_DRIP ||
                         mat_type == MAT_STEAM_BUN || mat_type == MAT_FILAMENT_GLASS ||
                         mat_type == MAT_CHEESE_PULL || mat_type == MAT_MEMORY_WAX ||
                         mat_type == MAT_MAILLARD || mat_type == MAT_MUSHROOM ||
                         mat_type == MAT_CRUMB_LOAF || mat_type == MAT_BISQUE ||
                         mat_type == MAT_TEAR_SKIN || mat_type == MAT_LAMINATED_PASTRY ||
                         mat_type == MAT_STONEWARE || mat_type == MAT_ORTHO_BEND ||
                         mat_type == MAT_ORTHO_TEAR || mat_type == MAT_VENT_CRUMB ||
                         mat_type == MAT_VITREOUS_CLAY || mat_type == MAT_BLISTER_GLAZE ||
                         mat_type == MAT_OPEN_CRUMB || mat_type == MAT_SINTER_LOCK ||
                         mat_type == MAT_BINDER_CRUMB || mat_type == MAT_CHANNEL_CRUMB ||
                         mat_type == MAT_BURNOUT_CLAY || mat_type == MAT_VENTED_SKIN ||
                         mat_type == MAT_TOPO_GOO || mat_type == MAT_OOBLECK ||
                         mat_type == MAT_IMPACT_GEL || mat_type == MAT_SEALED_CHARGE ||
                         mat_type == MAT_MORPH_TISSUE || mat_type == MAT_ROOT_WEAVE ||
                         mat_type == MAT_CELL_SHEET || mat_type == MAT_ASH_REGROWTH ||
                         mat_type == MAT_SUPERCONDUCTOR || mat_type == MAT_CURIE_FERRO ||
                         mat_type == MAT_EDDY_COPPER);
    float sig_min = is_solid_mat ? 0.5 : 0.1;  // Solids: max 50% compression
    float sig_max = is_solid_mat ? 3.0 : 8.0;
    svd.sigma = clamp(svd.sigma, vec2(sig_min), vec2(sig_max));
    F = svd.U * mat2(svd.sigma.x, 0, 0, svd.sigma.y) * transpose(svd.V);
    float J = svd.sigma.x * svd.sigma.y;

    // --- Material parameters ---
    vec4 base_params = mat_params0[idx];
    float E = (base_params.x > 0.0) ? base_params.x : u_E;
    float nu = (base_params.x > 0.0) ? base_params.y : u_nu;
    float fiber_strength = (base_params.x > 0.0) ? base_params.z : u_fiber_strength;
    float shell_seed = clamp(base_params.w, 0.0, 1.0);
    float core_seed = 1.0 - shell_seed;
    float pseudo_depth = (u_enable_pseudo_25d != 0) ? clamp(u_pseudo_25d_depth, 0.0, 2.0) : 0.0;
    float pseudo_shell = (u_enable_pseudo_25d != 0) ? clamp(u_pseudo_25d_shell_support, 0.0, 2.0) : 0.0;
    float pseudo_enclosure = (u_enable_pseudo_25d != 0) ? clamp(u_pseudo_25d_enclosure, 0.0, 2.0) : 0.0;
    float pseudo_cohesion = (u_enable_pseudo_25d != 0) ? clamp(u_pseudo_25d_cohesion, 0.0, 2.0) : 0.0;
    float pseudo_shell_boost = 1.0 + pseudo_shell * (0.18 + 0.82 * shell_seed);
    float pseudo_volume_hold = 1.0 + pseudo_depth * (0.16 + 0.84 * core_seed);
    float pseudo_enclosure_hold = 1.0 + pseudo_enclosure * (0.14 + 0.86 * core_seed);
    float pseudo_split_hold = 1.0 + pseudo_cohesion * (0.16 + 0.84 * core_seed);
    float fracture_threshold = u_fracture_threshold;
    float fracture_rate = u_fracture_rate;
    vec4 thermal_params = thermal_coupling_defaults(mat_type);

    // Temperature softening for thermal/phase materials
    if (mat_type == MAT_THERMAL) {
        E *= clamp(1.0 - (temp - 300.0) / 200.0, 0.05, 1.0);
    }

    float mu     = E / (2.0 * (1.0 + nu));
    float lambda = E * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

    // --- Constitutive model ---
    mat2 stress;
    mat2 R = svd.U * transpose(svd.V);

    if (mat_type == MAT_FLUID) {
        F = mat2(sqrt(max(J, 0.01)));
        J = max(J, 0.01);
        stress = mat2(lambda * J * (J - 1.0));
    }
    else if (mat_type == MAT_FLAMMABLE_FLUID) {
        float burn = damage[idx];
        float batch_heat = max(thermal_params.y, 0.1);
        float batch_cooling = max(thermal_params.z, 0.02);
        if (temp > 338.0 && burn < 1.0) {
            float fuel_hold = mix(0.60, 0.96, clamp(batch_cooling, 0.0, 1.2));
            float ignition = clamp((temp - 330.0) / 210.0, 0.0, 1.0);
            float burn_drag = mix(1.0, 0.62, smoothstep(0.18, 0.80, burn));
            burn += 0.82 * fuel_hold * burn_drag * ignition * u_dt;
        }
        if (burn > 0.02 && burn < 0.98) {
            float flame = clamp(burn * (1.0 - burn) * 4.0, 0.0, 1.0);
            temp += (620.0 + 170.0 * batch_heat) * flame * u_dt;
            temp = max(temp, 465.0 + 65.0 * min(batch_heat, 1.5) + 30.0 * flame);
        }
        if (burn > 0.92) {
            temp += (345.0 - temp) * mix(0.036, 0.012, clamp(batch_cooling, 0.0, 1.0)) * u_dt;
        }
        burn = clamp(burn, 0.0, 1.0);
        damage[idx] = burn;
        temperatures[p] = clamp(temp, 0.0, 1400.0);

        float vapor = smoothstep(0.72, 0.99, burn);
        float bulk = max(E * mix(0.28, 0.10, vapor), 450.0);
        float J_rest = 1.0 + vapor * 0.08 + burn * 0.018;
        F = mat2(sqrt(max(J, 0.01)));
        J = max(J, 0.01);
        stress = mat2(bulk * J * (J - J_rest));
        C *= (1.0 - vapor * 0.16);
    }
    else if (mat_type == MAT_FERRO_FLUID || mat_type == MAT_HEAVY_FERRO_FLUID ||
             mat_type == MAT_DIAMAGNETIC_FLUID || mat_type == MAT_PARA_MIST ||
             mat_type == MAT_STICKY_FERRO) {
        // Heavy variant reuses the Tait EOS + spike dynamics — it's the same
        // fluid, just with much stronger magnetic response (tuned in the
        // magnetic force block in mpm_g2p and Langevin saturation in
        // magnetic_particles). That way all the surface-tension / spike code
        // still applies and spikes can form.
        // ── Weakly compressible Tait EOS ──────────────────────────────
        // p = B * ((rho/rho0)^gamma - 1),  B = rho0 * c0^2 / gamma
        //
        // CFL BUDGET (dx ≈ 0.033, sub_dt ≈ 1.67e-3, 5 substeps at 1/120):
        //   Tait:     c0 <= 0.4 * dx / sub_dt ≈ 8.0 m/s
        //   Viscous:  mu <= 0.5 * dx² * rho / sub_dt ≈ 440 Pa·s
        //
        // These limits are hard: exceed them and the integrator
        // oscillates, overshoots, and the fluid explodes.

        // Thermal softening: placeholder for future Curie-law chi
        // modulation. For now only softens bulk and viscosity a little.
        float hot = smoothstep(360.0, 700.0, temp);

        // EOS constants. c0 set conservatively (~75% of CFL limit)
        // because real-world deformation rates can locally amplify the
        // effective wave speed when combined with affine momentum.
        const float c0_cold   = 6.0;
        const float c0_warm   = 4.5;
        const float gamma_eos = 7.0;

        // Follow the actually spawned particle mass instead of assuming
        // one hard-coded fluid density. Several magnetic benches use a
        // lighter density_scale, and treating them as rho0=1350 made the
        // puddle behave like a hidden "ferro pebble" material.
        float rho0 = clamp(mass / max(u_p_vol, 1e-6), 120.0, 1800.0);
        float density_ratio = clamp(rho0 / 1000.0, 0.12, 1.8);

        float c0    = mix(c0_cold, c0_warm, hot);
        float B_mod = rho0 * c0 * c0 / gamma_eos;  // ~6943 Pa cold

        // J safety clamp: lower bound prevents Tait runaway under
        // compression (pressure ~ (1/J)^7 goes vertical near J=0).
        // Upper bound is just a numerical safety net — Tait tension
        // naturally plateaus at -B_mod as J → ∞, so there's no
        // runaway on that side.
        float J_safe  = clamp(J, 0.7, 4.0);
        float rho_rel = 1.0 / J_safe;

        // Full Tait: positive pressure (compression) pushes outward,
        // NEGATIVE pressure (rarefaction) pulls inward. The tensile
        // branch is the restoring force that keeps the fluid cohesive
        // at rest density. Previous versions clamped this to max(p, 0),
        // which removed the only mechanism that could bring expanded
        // particles back together — without tension the fluid puffed
        // up indefinitely because nothing resisted rarefaction.
        //
        // Tait tension saturates at ~-B_mod ≈ -7kPa, well inside the
        // fluid stress clamp (E*40 ≈ 168kPa), and the cold c0=6 keeps
        // the wave speed inside CFL — so explicit-integrator blow-up
        // from tension is not a concern at these parameters.
        float p       = B_mod * (pow(rho_rel, gamma_eos) - 1.0);

        // Fluid: no shear memory. Reset F to isotropic scaling of J.
        F = mat2(sqrt(J_safe));
        J = J_safe;

        // Viscous damping stress from APIC C. 120 Pa·s cold is ~1.3
        // orders of magnitude more viscous than water — appropriate
        // for ferrofluid, and well inside the 440 Pa·s CFL limit.
        float mu_visc = mix(120.0, 50.0, hot) *
                        mix(0.55, 1.0, smoothstep(0.18, 1.0, density_ratio));

        // Hydrostatic pressure + viscous deviator.
        stress = mat2(-p) + mu_visc * (C + transpose(C));

        if (u_use_real_magnetics != 0) {
            vec4 drive_local = sample_magnetic_drive_field_smooth(pos);
            vec4 total_local = sample_magnetic_total_field_smooth(pos);
            vec4 drive_bulk = vec4(0.0);
            vec2 grad_h2 = vec2(0.0);
            float grad_mag = 0.0;
            float rigid_gate = magnetic_drive_response_gate(pos, drive_bulk, grad_h2, grad_mag);
            float wall_gate = magnetic_wall_gate(pos, 0.16);
            vec2 drive_vec = mix(drive_local.xy, drive_bulk.xy, 0.68);
            float induced_gain = clamp((total_local.z - drive_local.z) / max(drive_local.z, 1e-4), 0.0, 1.0);
            vec2 align_vec = mix(drive_vec, total_local.xy, 0.16 * induced_gain);
            float hmag = mix(drive_local.z, drive_bulk.z, 0.72);
            if (hmag > 1e-4) {
                vec2 field_dir = normalize(align_vec + vec2(1e-6, 0.0));
                vec2 field_tangent = vec2(-field_dir.y, field_dir.x);

                // A first real ferro term: add anisotropic magnetic stress
                // rather than relying on Kelvin attraction alone. This is a
                // coarse 2D Maxwell-stress approximation that creates
                // field-aligned chain tension and lateral squeeze so puddles
                // can neck into combs/spikes instead of translating as a blob.
                float sat = 1.0 - exp(-hmag * 0.42);
                float grad_term = grad_mag / (hmag * hmag + 1e-4);
                float mag_gate = rigid_gate * wall_gate;
                float occ_support = sample_magnetic_occupancy_smooth(pos);
                float pack_gate = smoothstep(0.16, 0.50, occ_support);
                float chain = clamp(0.11 * u_magnet_chain_rate * sat * mag_gate, 0.0, 2.2);
                float spike = clamp(0.13 * u_magnet_spike_strength *
                                    (0.35 * sat + 0.65 * clamp(grad_term, 0.0, 2.5)),
                                    0.0, 2.6) * mag_gate * mag_gate;
                chain *= mix(0.45, 1.0, pack_gate);
                spike *= pack_gate;

                float magnetic_scale = B_mod * (0.09 * chain + 0.18 * spike);
                mat2 maxwell = -magnetic_scale *
                    (outer2(field_dir, field_dir) - 0.50 * mat2(1.0));
                stress += maxwell;

                // Field-aligned extensional viscosity: once columns start
                // forming, this helps them stay coherent instead of turning
                // into free-flying dust under the bulk magnetic pull.
                mat2 D = 0.5 * (C + transpose(C));
                float along_rate = dot(field_dir, D * field_dir);
                float across_rate = dot(field_tangent, D * field_tangent);
                float chain_visc = mu_visc * (0.45 * chain + 0.85 * spike);
                stress += chain_visc *
                    (along_rate * outer2(field_dir, field_dir) +
                     0.22 * across_rate * outer2(field_tangent, field_tangent));

                // Surface-aware Rosensweig surrogate: use a lightweight
                // occupancy texture of the ferro phase so the magnetic
                // term acts mostly at the liquid interface instead of
                // squeezing the whole puddle uniformly.
                float occ = sample_magnetic_occupancy(pos);
                vec2 occ_grad = magnetic_occ_grad(pos);
                float occ_grad_mag = length(occ_grad);
                float interface_band = smoothstep(0.06, 0.28, occ_grad_mag) *
                                       smoothstep(0.05, 0.22, occ) *
                                       pack_gate;
                if (interface_band > 1e-4) {
                    vec2 n_in = occ_grad / max(occ_grad_mag, 1e-5);
                    vec2 n_out = -n_in;
                    vec2 t_int = vec2(-n_out.y, n_out.x);
                    float normal_align = abs(dot(field_dir, n_out));
                    float tangent_align = abs(dot(field_dir, t_int));
                    float surface_push = B_mod * interface_band *
                                         (0.08 * chain + 0.21 * spike) *
                                         (0.25 + 0.75 * sat) *
                                         normal_align * normal_align *
                                         mag_gate * mag_gate;
                    float rim_hold = B_mod * interface_band *
                                     (0.04 + 0.09 * chain) *
                                     (0.30 + 0.70 * tangent_align * tangent_align) *
                                     mag_gate * mag_gate;
                    stress -= surface_push *
                              (outer2(n_out, n_out) - 0.30 * outer2(t_int, t_int));
                    stress -= rim_hold * outer2(field_dir, field_dir);

                    float normal_rate = dot(n_out, D * n_out);
                    float tangent_rate = dot(t_int, D * t_int);
                    float interface_visc = mu_visc * interface_band *
                                           (0.16 + 0.38 * spike) *
                                           mix(0.55, 1.0, mag_gate);
                    stress += interface_visc *
                              (normal_rate * outer2(n_out, n_out) +
                               0.30 * tangent_rate * outer2(t_int, t_int));
                }
            }
        }

        // (Stateless per-particle: the fluid's only state is F, J, pos.)
    }
    else if (mat_type == MAT_MAG_SOFT_IRON || mat_type == MAT_MAGNETIC_RUBBER ||
             mat_type == MAT_SUPERCONDUCTOR || mat_type == MAT_CURIE_FERRO ||
             mat_type == MAT_EDDY_COPPER) {
        bool soft_rubber = (mat_type == MAT_MAGNETIC_RUBBER);
        // Superconductor + Curie ferro behave like stiff iron solids; eddy
        // copper is slightly softer (real copper has lower Young's modulus
        // than iron but not by much).
        float stiff_mul = soft_rubber ? 0.65
                        : (mat_type == MAT_EDDY_COPPER ? 3.20
                        : (mat_type == MAT_SUPERCONDUCTOR ? 5.80
                        : 4.80));
        float E_mag = E * stiff_mul;
        float nu_mag = soft_rubber ? 0.36 : 0.34;
        float mu_mag = E_mag / (2.0 * (1.0 + nu_mag));
        float lam_mag = E_mag * nu_mag / ((1.0 + nu_mag) * (1.0 - 2.0 * nu_mag));
        stress = 2.0 * mu_mag * (F - R) * transpose(F)
               + lam_mag * (J - 1.0) * J * mat2(1.0);

        if (u_use_real_magnetics != 0) {
            vec4 drive_local = sample_magnetic_drive_field_smooth(pos);
            vec4 total_local = sample_magnetic_total_field_smooth(pos);
            vec4 drive_bulk = vec4(0.0);
            vec2 grad_h2 = vec2(0.0);
            float grad_mag = 0.0;
            float rigid_gate = magnetic_drive_response_gate(pos, drive_bulk, grad_h2, grad_mag);
            float wall_gate = magnetic_wall_gate(pos, 0.22);
            vec2 drive_vec = mix(drive_local.xy, drive_bulk.xy, 0.70);
            float total_align = clamp(total_local.z / max(drive_local.z, 1e-4), 0.0, 1.0);
            vec2 align_vec = mix(drive_vec, total_local.xy, 0.76 * total_align);
            float hmag = mix(drive_local.z, drive_bulk.z, 0.76);
            if (hmag > 1e-4) {
                vec2 field_dir = normalize(align_vec + vec2(1e-6, 0.0));
                vec2 field_tangent = vec2(-field_dir.y, field_dir.x);
                float sat = 1.0 - exp(-hmag * (soft_rubber ? 0.16 : 0.26));
                float align = clamp(sat * rigid_gate * wall_gate, 0.0, soft_rubber ? 0.42 : 0.72);
                float compression = max(1.0 - J, 0.0);
                float grad_term = clamp(grad_mag / (hmag * hmag + 1e-4), 0.0, 2.8);
                if (soft_rubber) {
                    float eps_parallel = 0.032 * align;
                    float eps_perp = -eps_parallel * 0.52;
                    mat2 F_target = mat2(1.0)
                                  + eps_parallel * outer2(field_dir, field_dir)
                                  + eps_perp * outer2(field_tangent, field_tangent);
                    float mag_shape = max(E_mag * 0.16, 150.0) * (0.35 + 0.65 * align);
                    stress += mag_shape * (F_target - F) * transpose(F);

                    float pole_lock = max(E_mag * 0.08, 70.0)
                                    * (0.14 + 0.56 * grad_term * align);
                    float anti_collapse = max(E_mag * 0.18, 180.0)
                                        * (0.30 + compression * (1.5 + align));
                    float bend_hold = max(E_mag * 0.10, 90.0) * (0.20 + 0.80 * align);
                    mat2 D = 0.5 * (C + transpose(C));
                    float along_rate = dot(field_dir, D * field_dir);
                    float across_rate = dot(field_tangent, D * field_tangent);
                    stress += pole_lock * outer2(field_dir, field_dir);
                    stress += (pole_lock * 0.28) * outer2(field_tangent, field_tangent);
                    stress -= mat2(anti_collapse * max(1.0 - J, 0.0));
                    stress += bend_hold *
                              (along_rate * outer2(field_dir, field_dir) +
                               0.55 * across_rate * outer2(field_tangent, field_tangent));
                } else {
                    // Soft iron should behave like a stiff coherent body whose
                    // bulk motion comes from the external Kelvin pull, not like
                    // a contracting magnetic actuator. Keep only stiffening and
                    // anti-collapse support here.
                    float field_stiffen = 1.0 + 1.2 * align;
                    stress *= field_stiffen;
                    float anti_collapse = max(E_mag * 0.46, 2200.0)
                                        * (0.35 + compression * (2.4 + 0.6 * align));
                    float shape_hold = max(E_mag * 0.22, 900.0) * (0.30 + 0.70 * align);
                    mat2 D = 0.5 * (C + transpose(C));
                    float along_rate = dot(field_dir, D * field_dir);
                    float across_rate = dot(field_tangent, D * field_tangent);
                    stress -= mat2(anti_collapse * max(1.0 - J, 0.0));
                    stress += shape_hold * (mat2(1.0) - F) * transpose(F);
                    stress += max(E_mag * 0.14, 700.0) *
                              (along_rate * outer2(field_dir, field_dir) +
                               0.42 * across_rate * outer2(field_tangent, field_tangent));
                }
            }
        }
    }
    else if (mat_type == MAT_SNOW) {
        float theta_c = 2.5e-2, theta_s = 4.5e-3;
        vec2 new_sig = clamp(svd.sigma, vec2(1.0 - theta_c), vec2(1.0 + theta_s));
        float Jp = Jp_data[idx];
        Jp *= (svd.sigma.x * svd.sigma.y) / (new_sig.x * new_sig.y);
        Jp_data[idx] = clamp(Jp, 0.6, 20.0);
        svd.sigma = new_sig;
        F = svd.U * mat2(svd.sigma.x, 0, 0, svd.sigma.y) * transpose(svd.V);
        J = new_sig.x * new_sig.y;
        float h = clamp(exp(10.0 * (1.0 - Jp)), 0.1, 5.0);
        R = svd.U * transpose(svd.V);
        stress = 2.0 * mu * h * (F - R) * transpose(F)
               + lambda * h * (J - 1.0) * J * mat2(1.0);
    }
    else if (mat_type == MAT_BRITTLE || mat_type == MAT_TOUGH) {
        bool is_tough = (mat_type == MAT_TOUGH);
        float thermal = clamp((temp - 380.0) / 320.0, 0.0, 1.0);
        float E_eff = E * (is_tough ? 1.15 : 0.95) * (1.0 - thermal * (is_tough ? 0.18 : 0.08));
        float nu_eff = clamp(nu * (is_tough ? 1.0 : 0.85), 0.08, 0.34);
        float mu_s = E_eff / (2.0 * (1.0 + nu_eff));
        float lam_s = E_eff * nu_eff / ((1.0 + nu_eff) * (1.0 - 2.0 * nu_eff));

        stress = 2.0 * mu_s * (F - R) * transpose(F)
               + lam_s * (J - 1.0) * J * mat2(1.0);

        vec2 fiber = fiber_dirs[idx];
        float along_strain = 0.0;
        float cross_strain = 0.0;
        if (length(fiber) > 0.3 && fiber_strength > 0.1) {
            vec2 df = F * fiber;
            float fs = length(df);
            if (fs > 1e-6) {
                vec2 fh = df / fs;
                float fi = clamp(fs - 1.0, -0.35, 0.35);
                stress += fiber_strength * mu_s * fi * mat2(
                    fh.x*fh.x, fh.x*fh.y, fh.y*fh.x, fh.y*fh.y);
                along_strain = abs(fs - 1.0);
                vec2 perp = vec2(-fiber.y, fiber.x);
                cross_strain = abs(length(F * perp) - 1.0);
            }
        }

        float d = damage[idx];
        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = is_tough ? 0.13 : 0.055;
        crack_thresh *= (1.0 - thermal * (is_tough ? 0.25 : 0.45));
        float crack_rate = is_tough ? 1.8 : 4.8;
        crack_rate *= 1.0 + thermal * (is_tough ? 0.7 : 1.6);
        float directional = max(cross_strain - along_strain * 0.35, 0.0);
        float crack_drive = max(
            tensile * (is_tough ? 0.8 : 1.2) +
            shear * (is_tough ? 0.55 : 0.85) +
            directional * 0.6 - crack_thresh, 0.0);
        d += crack_drive * crack_rate * u_dt;
        d = clamp(d, 0.0, 1.0);
        damage[idx] = d;

        float matrix_loss = max(1.0 - d * (is_tough ? 0.35 : 0.55), is_tough ? 0.65 : 0.42);
        stress *= matrix_loss;
        if (d > 0.72) {
            float bond_loss = smoothstep(0.72, 1.0, d);
            stress *= mix(1.0, is_tough ? 0.55 : 0.30, bond_loss);
        }
    }
    else if (mat_type == MAT_GLASS) {
        float soft = phase_data[idx];
        float crack = damage[idx];
        float glass_hold = clamp(0.50 * pseudo_depth + 0.60 * pseudo_shell + 0.50 * pseudo_cohesion, 0.0, 2.0);

        float target_soft = smoothstep(720.0, 980.0, temp);
        soft += clamp(target_soft - soft, -1.6 * u_dt, 1.8 * u_dt);
        soft = clamp(soft, 0.0, 1.0);
        phase_data[idx] = soft;

        float hot_floor = mix(0.55, 0.78, clamp(glass_hold * 0.45, 0.0, 1.0));
        float E_g = mix(E * (3.4 + 0.20 * glass_hold), E * hot_floor, soft)
                  * mix(1.0, pseudo_shell_boost, 0.12 + 0.34 * (1.0 - soft));
        float nu_g = mix(0.17, mix(0.31, 0.28, clamp(glass_hold * 0.40, 0.0, 1.0)), soft);
        float mu_g = E_g / (2.0 * (1.0 + nu_g));
        float lam_g = E_g * nu_g / ((1.0 + nu_g) * (1.0 - 2.0 * nu_g));

        mat2 elastic_stress = 2.0 * mu_g * (F - R) * transpose(F)
                            + lam_g * (J - 1.0) * J * mat2(1.0);
        float J_rest = 1.0 + soft * max(temp - 760.0, 0.0) * 0.00006;
        mat2 liquid_stress = mat2(lam_g * J * (J - J_rest));
        float blend = smoothstep(0.86 + 0.08 * clamp(glass_hold * 0.45, 0.0, 1.0), 1.0, soft);
        stress = elastic_stress * (1.0 - blend) + liquid_stress * blend;

        if (soft > 0.35 && soft < 0.98) {
            float viscosity = max(E * 0.24 * (1.0 - abs(soft - 0.78) * 1.1) * (1.0 + 0.35 * pseudo_depth), 0.0);
            stress += viscosity * (C + transpose(C));
        }
        if (soft > 0.92) {
            float relax = smoothstep(0.92, 1.0, soft) * 0.015 * mix(1.0, 0.55, clamp(pseudo_cohesion * 0.65, 0.0, 1.0));
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            F = F * (1.0 - relax) + F_iso * relax;
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = mix(0.028, 0.11, soft) * pseudo_split_hold
                           + 0.012 * clamp(pseudo_shell * 0.60, 0.0, 1.0) * (1.0 - soft);
        float crack_rate = mix(9.0, 1.2, soft) * mix(1.0, 0.72, clamp(pseudo_cohesion * 0.70, 0.0, 1.0));
        crack += max(tensile * 1.6 + shear * 1.2 - crack_thresh, 0.0) * crack_rate * u_dt;
        crack = clamp(crack, 0.0, 1.0);
        damage[idx] = crack;

        float integrity_floor = 0.18 + soft * 0.2 + clamp(glass_hold * 0.08, 0.0, 0.16) * (1.0 - soft * 0.5);
        float integrity = max(1.0 - crack * mix(0.82, 0.62, clamp(pseudo_cohesion * 0.80, 0.0, 1.0)), integrity_floor);
        stress *= integrity;
        if (crack > 0.70) {
            float shatter = smoothstep(0.70, 1.0, crack);
            stress *= mix(1.0, mix(0.18, 0.30, clamp(pseudo_cohesion * 0.80, 0.0, 1.0)), shatter);
        }
    }
    else if (mat_type == MAT_ANISO || mat_type == MAT_FRACTURE) {
        // Only apply heat effects if material HAS fibers (fiber_strength > 0)
        // Glass/non-fiber fracture materials are NOT affected by temperature
        bool has_fibers = (length(fiber_dirs[idx]) > 0.3 && fiber_strength > 0.1);
        float heat_effect = 0.0;
        float char_level = 0.0;

        if (has_fibers && temp > 350.0) {
            heat_effect = clamp((temp - 350.0) / 400.0, 0.0, 1.0);
            char_level = clamp((temp - 500.0) / 300.0, 0.0, 1.0);
        }

        // Heat strongly weakens the matrix so ropes/woods visibly lose structure.
        float E_eff = E * mix(1.0, 0.28, heat_effect);
        float mu_s = E_eff / (2.0 * (1.0 + nu));
        float lam_s = E_eff * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

        stress = 2.0 * mu_s * (F - R) * transpose(F)
               + lam_s * (J - 1.0) * J * mat2(1.0);

        // Fiber reinforcement (weakens with heat)
        vec2 fiber = fiber_dirs[idx];
        vec2 df = F * fiber;
        float fs = length(df);
        if (fs > 1e-6 && fiber_strength > 0.1) {
            float fiber_eff = fiber_strength * (1.0 - char_level * 0.8);
            vec2 fh = df / fs;
            float fi = clamp(fs - 1.0, -0.5, 0.5);
            stress += fiber_eff * mu_s * fi * mat2(
                fh.x*fh.x, fh.x*fh.y, fh.y*fh.x, fh.y*fh.y);
        }

        // ANISO: store charring for visual
        if (mat_type == MAT_ANISO && has_fibers) {
            float charred = max(damage[idx], char_level);
            damage[idx] = charred;
            float base_rigid = smoothstep(9000.0, 18000.0, E);
            float char_soft = mix(0.28, 0.58, base_rigid);
            float char_brittle = mix(0.0, 0.35, base_rigid) * smoothstep(0.35, 0.95, charred);
            stress *= max(1.0 - charred * char_soft - char_brittle, 0.12);
            if (charred > 0.55) {
                float relax = smoothstep(0.55, 0.95, charred) * mix(0.10, 0.03, base_rigid);
                F = F * (1.0 - relax) + R * relax;
            }
        }

        // FRACTURE: damage from strain (heat only affects fibered materials)
        if (mat_type == MAT_FRACTURE) {
            float d = damage[idx];
            float strain_mag = length(svd.sigma - vec2(1.0));
            float thresh = fracture_threshold;
            float rate = fracture_rate;
            if (has_fibers) {
                thresh *= (1.0 - heat_effect * 0.5);
                rate *= (1.0 + heat_effect * 2.0);
                d = max(d, char_level * 0.5);
            } else if (temp > 350.0) {
                float heat_brittleness = clamp((temp - 350.0) / 350.0, 0.0, 1.0);
                thresh *= (1.0 - heat_brittleness * 0.6);
                rate *= (1.0 + heat_brittleness * 1.8);
            }
            d += max(strain_mag - thresh, 0.0) * rate * u_dt;
            d = clamp(d, 0.0, 1.0);
            damage[idx] = d;
            float coupling = max(1.0 - d * 0.82, 0.18);
            stress *= coupling;
            if (d > 0.75) {
                float relax = smoothstep(0.75, 1.0, d) * 0.2;
                mat2 F_chunk = mat2(sqrt(max(J, 0.01)));
                F = F * (1.0 - relax) + F_chunk * relax;
                C *= (1.0 - relax * 0.5);
            }
        }
    }
    else if (mat_type == MAT_ORTHO_BEND || mat_type == MAT_ORTHO_TEAR) {
        vec2 fiber = normalize(fiber_dirs[idx] + vec2(1e-6, 0.0));
        vec2 perp = vec2(-fiber.y, fiber.x);
        vec2 df = F * fiber;
        vec2 dp = F * perp;
        float fs = max(length(df), 1e-6);
        float ps = max(length(dp), 1e-6);
        vec2 fh = df / fs;
        vec2 ph = dp / ps;
        float along = fs - 1.0;
        float across = ps - 1.0;
        float shear = dot(df, dp);

        float cure = 0.0;
        float crack = 0.0;
        float heat = 0.0;
        float ortho_hold = 0.0;
        if (mat_type == MAT_ORTHO_TEAR) {
            cure = damage[idx];
            crack = Jp_data[idx];
            heat = smoothstep(360.0, 680.0, temp);
            ortho_hold = clamp(0.45 * pseudo_depth + 0.35 * pseudo_shell + 0.45 * pseudo_cohesion, 0.0, 2.0);
            if (temp > 360.0) {
                cure += mix(0.08, 0.38, shell_seed) * heat * u_dt * (1.0 - cure);
            }
            cure = clamp(cure, 0.0, 1.0);
        }

        float matrix_scale = (mat_type == MAT_ORTHO_BEND) ? 0.08 : mix(0.12, 0.20, cure);
        float along_scale = (mat_type == MAT_ORTHO_BEND) ? (1.2 + fiber_strength * 2.6)
                                                         : (1.3 + fiber_strength * (2.0 + cure * 0.8));
        float cross_scale = (mat_type == MAT_ORTHO_BEND) ? 0.05
                                                         : mix(0.10, 0.04, cure);
        float shear_scale = (mat_type == MAT_ORTHO_BEND) ? 0.06
                                                         : mix(0.10, 0.05, cure);
        if (mat_type == MAT_ORTHO_TEAR) {
            matrix_scale *= 1.0 + 0.55 * ortho_hold;
            along_scale *= 1.0 + 0.18 * ortho_hold;
            cross_scale *= 1.0 + 0.90 * ortho_hold;
            shear_scale *= 1.0 + 0.75 * ortho_hold;
        }

        float E_iso = E * matrix_scale;
        float mu_iso = E_iso / (2.0 * (1.0 + nu));
        float lam_iso = E_iso * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));
        float E_along = E * along_scale;
        float E_cross = E * cross_scale;
        float E_shear = E * shear_scale;
        float J_rest = 1.0;
        if (mat_type == MAT_ORTHO_TEAR) {
            J_rest += cure * 0.012 - heat * 0.018 / max(1.0, pseudo_enclosure_hold);
        }

        mat2 iso_stress = 2.0 * mu_iso * (F - R) * transpose(F)
                        + lam_iso * (J - J_rest) * J * mat2(1.0);
        mat2 along_stress = E_along * along * mat2(
            fh.x*fh.x, fh.x*fh.y,
            fh.y*fh.x, fh.y*fh.y);
        mat2 cross_stress = E_cross * across * mat2(
            ph.x*ph.x, ph.x*ph.y,
            ph.y*ph.x, ph.y*ph.y);
        mat2 shear_stress = E_shear * shear * mat2(
            fh.x*ph.x + ph.x*fh.x, fh.x*ph.y + ph.x*fh.y,
            fh.y*ph.x + ph.y*fh.x, fh.y*ph.y + ph.y*fh.y);
        stress = iso_stress + along_stress + cross_stress + shear_stress;

        if (mat_type == MAT_ORTHO_BEND) {
            damage[idx] = clamp(abs(across) * 0.35 + abs(shear) * 0.20, 0.0, 1.0);
        } else {
            float cross_mag = abs(across);
            float along_mag = abs(along);
            float shear_mag = abs(shear);
            float crack_thresh = mix(0.10, 0.05, heat) * mix(1.0, 0.75, cure) * pseudo_split_hold
                               + pseudo_shell * 0.04;
            float crack_drive = max(cross_mag * 3.2 + shear_mag * 1.8 + heat * 0.10 - along_mag * 0.80 - crack_thresh, 0.0);
            crack += crack_drive * (0.35 + cure * 1.25 + heat * 1.35) * (1.0 / max(1.0, pseudo_split_hold)) * u_dt;
            crack = clamp(crack, 0.0, 1.0);

            damage[idx] = cure;
            phase_data[idx] = cross_mag;
            Jp_data[idx] = crack;

            if (crack > 0.22) {
                float split = smoothstep(0.22, 1.0, crack);
                float residual = clamp(pseudo_cohesion * 0.80, 0.0, 1.0);
                iso_stress *= mix(1.0, mix(0.28, 0.46, residual), split);
                cross_stress *= mix(1.0, mix(0.04, 0.16, residual), split);
                shear_stress *= mix(1.0, mix(0.10, 0.24, residual), split);
                along_stress *= mix(1.0, mix(0.58, 0.72, residual), split);
                stress = iso_stress + along_stress + cross_stress + shear_stress;
            }
        }
    }
    else if (mat_type == MAT_PHASE) {
        // Phase-field: interpolate solid↔liquid based on temperature
        float phi = phase_data[idx];
        float T_s = u_melt_temp - u_melt_range * 0.5;
        float T_l = u_melt_temp + u_melt_range * 0.5;
        float target = clamp((temp - T_s) / (T_l - T_s), 0.0, 1.0);
        float dphi = clamp(target - phi, -2.0 * u_dt, 2.0 * u_dt);
        phi = clamp(phi + dphi, 0.0, 1.0);
        phase_data[idx] = phi;

        // Latent heat
        temperatures[p] = clamp(temp - dphi * u_latent_heat, 0.0, 1500.0);

        // Thermal expansion: liquid wants to occupy more volume
        float expansion = 1.0 + phi * max(temp - u_melt_temp, 0.0) * 0.001;
        float J_rest = expansion; // Rest-state volume ratio

        // Interpolate stiffness (keep minimum lambda for liquid body)
        float sf = (1.0 - phi);
        float E_eff = max(E * sf * sf * sf, E * 0.02); // 2% floor so liquid isn't infinitely soft
        float mu_p = E_eff / (2.0 * (1.0 + nu));
        float lam_p = E_eff * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

        // Glass transition: smooth interpolation between solid and liquid
        // phi=0: full elastic solid
        // phi=0.3-0.7: "glass transition zone" - viscous, deformable, partially elastic
        // phi=1: fully liquid
        mat2 elastic_stress = 2.0 * mu_p * (F - R) * transpose(F)
                            + lam_p * (J - 1.0) * J * mat2(1.0);

        // In the transition zone, partially reset F toward isotropic
        // This models the loss of elastic memory (glass → liquid)
        float reset_fraction = smoothstep(0.3, 0.9, phi);
        mat2 F_isotropic = mat2(sqrt(max(J, 0.01)));
        float rf = reset_fraction * 0.3;
        F = F * (1.0 - rf) + F_isotropic * rf;

        // Liquid stress (volumetric only)
        float J_iso = max(determinant(F), 0.01);
        mat2 liquid_stress = mat2(lam_p * J_iso * (J_iso - J_rest));

        // Smoothly blend: elastic → viscous → liquid
        float blend = smoothstep(0.2, 0.95, phi);
        stress = elastic_stress * (1.0 - blend) + liquid_stress * blend;

        // Add viscous damping in the transition zone (glass-like)
        // Uses the velocity gradient (C matrix) as a proxy for strain rate
        if (phi > 0.1 && phi < 0.95) {
            float viscosity = mu_p * 0.5 * (1.0 - abs(phi - 0.5) * 2.0);
            stress += viscosity * (C + transpose(C)); // Viscous stress from strain rate
        }

        mu = mu_p; lambda = lam_p;
    }
    else if (mat_type == MAT_MEMORY_WAX) {
        float soft = phase_data[idx];
        float recover = damage[idx];

        float target_soft = smoothstep(320.0, 470.0, temp);
        soft += clamp(target_soft - soft, -2.2 * u_dt, 2.6 * u_dt);
        soft = clamp(soft, 0.0, 1.0);
        phase_data[idx] = soft;

        float cool_recover = 1.0 - smoothstep(0.04, 0.42, soft);
        recover += (cool_recover - recover) * 1.6 * u_dt;
        recover = clamp(recover, 0.0, 1.0);
        damage[idx] = recover;
        Jp_data[idx] *= max(1.0 - 0.9 * u_dt, 0.0);

        float E_mw = mix(E * 1.30, E * 0.10, soft);
        float nu_mw = clamp(mix(0.24, 0.39, soft), 0.16, 0.42);
        float mu_mw = E_mw / (2.0 * (1.0 + nu_mw));
        float lam_mw = E_mw * nu_mw / ((1.0 + nu_mw) * (1.0 - 2.0 * nu_mw));
        float J_rest = 1.0 + soft * 0.035;

        mat2 elastic_stress = 2.0 * mu_mw * (F - R) * transpose(F)
                            + lam_mw * (J - 1.0) * J * mat2(1.0);
        mat2 liquid_stress = mat2(lam_mw * J * (J - J_rest));
        float blend = smoothstep(0.72, 0.98, soft);
        stress = elastic_stress * (1.0 - blend) + liquid_stress * blend;

        if (soft > 0.45) {
            stress += mu_mw * mix(0.08, 0.38, soft) * (C + transpose(C));
        }
        if (recover > 0.05) {
            float restore = mix(0.010, 0.11, recover) * (1.0 - soft);
            mat2 F_rest = mat2(1.0);
            F = F * (1.0 - restore) + F_rest * restore;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
            stress += E * recover * 0.06 * (mat2(1.0) - F);
        }
    }
    else if (mat_type == MAT_BURNING) {
        // Combustion: solid → burning → hot gas → ash
        float burn = damage[idx];
        float batch_heat = max(thermal_params.y, 0.1);
        float batch_cooling = max(thermal_params.z, 0.02);
        float batch_loft = max(thermal_params.w, 0.0);

        // Ignition
        if (temp > 370.0 && burn < 1.0) {
            float fuel_hold = mix(0.54, 0.96, clamp(batch_cooling, 0.0, 1.2));
            float ignition = clamp((temp - 360.0) / 250.0, 0.0, 1.0);
            float burn_drag = mix(1.0, 0.58, smoothstep(0.16, 0.84, burn));
            burn += 0.42 * fuel_hold * burn_drag * ignition * u_dt;
        }

        // Exothermic: strong enough to sustain against grid cooling
        if (burn > 0.01 && burn < 0.985) {
            float flame = clamp(burn * (1.0 - burn) * 4.0, 0.0, 1.0);
            float heat_output = (860.0 + 220.0 * batch_heat) * flame;
            temp += heat_output * u_dt;
            // Burning particles resist grid cooling (they're ON FIRE)
            temp = max(temp, 505.0 + 60.0 * min(batch_heat, 1.5) + 35.0 * flame); // Never drop below ignition while actively burning
        }

        // Ash cools (slowly)
        if (burn > 0.94) {
            temp += (340.0 - temp) * mix(0.040, 0.012, clamp(batch_cooling, 0.0, 1.0)) * u_dt;
        }

        burn = clamp(burn, 0.0, 1.0);
        damage[idx] = burn;
        temperatures[p] = clamp(temp, 0.0, 1200.0);

        // Stiffness drops gradually
        float E_burn = E * max(1.0 - burn * 0.9, 0.05);
        float mu_b = E_burn / (2.0 * (1.0 + nu));
        float lam_b = E_burn * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

        // Anneal F as material burns (release locked deformation)
        if (burn > 0.1) {
            float anneal = burn * 0.3 * u_dt;
            F = F * (1.0 - anneal) + R * anneal;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
        }

        if (burn > 0.92 + 0.04 * clamp(batch_loft, 0.0, 1.0)) {
            // Gas: zero stress, zero affine, damp velocity
            F = mat2(sqrt(max(J, 0.01)));
            J = max(J, 0.01);
            stress = mat2(0.0);
            C = mat2(0.0);
        } else {
            // Solid, weakening
            stress = 2.0 * mu_b * (F - R) * transpose(F)
                   + lam_b * (J - 1.0) * J * mat2(1.0);

            vec2 fiber = fiber_dirs[idx];
            if (length(fiber) > 0.5) {
                vec2 df = F * fiber;
                float fs = length(df);
                if (fs > 1e-6) {
                    vec2 fh = df / fs;
                    float fi = clamp(fs - 1.0, -0.5, 0.5);
                    float fiber_E = fiber_strength * mu_b * (1.0 - burn);
                    stress += fiber_E * fi * mat2(fh.x*fh.x, fh.x*fh.y, fh.y*fh.x, fh.y*fh.y);
                }
            }
        }
    }
    else if (mat_type == MAT_EMBER) {
        // Embers/sparks: like burning but ash stays HOT much longer
        float burn = damage[idx];
        float ignition_temp = 350.0;
        float batch_heat = max(thermal_params.y, 0.1);
        float batch_cooling = max(thermal_params.z, 0.02);

        if (temp > ignition_temp && burn < 1.0) {
            burn += 0.95 * mix(0.55, 1.00, clamp(batch_cooling, 0.0, 1.0))
                 * u_dt * clamp((temp - ignition_temp) / 220.0, 0.0, 1.0);
        }
        // Exothermic (strong — embers are hot!)
        if (burn > 0.01 && burn < 0.985) {
            temp += (820.0 + 180.0 * batch_heat) * clamp(burn * (1.0 - burn) * 4.0, 0.0, 1.0) * u_dt;
            temp = max(temp, 540.0 + 55.0 * min(batch_heat, 1.5)); // Embers stay HOT
        }
        // Very slow cooling (embers glow for a long time)
        if (burn > 0.90) {
            temp += (360.0 - temp) * mix(0.010, 0.0035, clamp(batch_cooling, 0.0, 1.0)) * u_dt;
            temp = max(temp, 410.0); // Ash stays warm
        }
        burn = clamp(burn, 0.0, 1.0);
        damage[idx] = burn;
        temperatures[p] = clamp(temp, 0.0, 1200.0);

        float E_e = E * max(1.0 - burn * 0.95, 0.03);
        float mu_e = E_e / (2.0 * (1.0 + nu));
        float lam_e = E_e * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

        // Anneal during burning
        if (burn > 0.1) {
            float anneal = burn * 0.3 * u_dt;
            F = F * (1.0 - anneal) + R * anneal;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
        }

        if (burn > 0.6) {
            F = mat2(sqrt(max(J, 0.01)));
            stress = mat2(0.0);
            C = mat2(0.0);
            vel *= 0.95;
        } else {
            stress = 2.0 * mu_e * (F - R) * transpose(F)
                   + lam_e * (J - 1.0) * J * mat2(1.0);
        }
    }
    else if (mat_type == MAT_HARDEN) {
        // Heat-curing material: soft → hard when heated
        float cured = damage[idx];

        // Cure when hot
        if (temp > 400.0) {
            float prev = cured;
            cured += 1.0 * u_dt * clamp((temp - 400.0) / 200.0, 0.0, 1.0);
            cured = clamp(cured, 0.0, 1.0);
            // Anneal ONLY during active curing (not constantly!)
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * 0.3;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }
        damage[idx] = cured;

        // E increases dramatically with curing
        float E_h = E * (1.0 + cured * 4.0);
        float mu_h = E_h / (2.0 * (1.0 + nu));
        float lam_h = E_h * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

        stress = 2.0 * mu_h * (F - R) * transpose(F)
               + lam_h * (J - 1.0) * J * mat2(1.0);
    }
    else if (mat_type == MAT_CERAMIC) {
        // Ceramic: hardens when heated, then fractures into clean chunks
        // damage = cure fraction, Jp = crack damage
        float cured = damage[idx];
        float crack = Jp_data[idx];

        // Cure when hot
        if (temp > 400.0) {
            float prev = cured;
            cured += 0.8 * u_dt * clamp((temp - 400.0) / 200.0, 0.0, 1.0);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * 0.2;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }
        damage[idx] = cured;

        float E_c = E * (1.0 + cured * 4.0);
        float thermal_brittleness = clamp((temp - 450.0) / 350.0, 0.0, 1.0);
        float strain_mag = length(svd.sigma - vec2(1.0));
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = fracture_threshold * mix(1.25, 0.45, max(cured, thermal_brittleness));
        float crack_rate = fracture_rate * mix(0.8, 3.0, max(cured, thermal_brittleness));
        float crack_drive = max(strain_mag + shear * 0.9 - crack_thresh, 0.0);
        if (cured > 0.55 && crack_drive > 0.0) {
            crack += crack_drive * crack_rate * u_dt;
        }
        crack = clamp(crack, 0.0, 1.0);
        Jp_data[idx] = crack;

        // KEY: cracked particles stay STIFF but reduce coupling
        // This makes fragments, not dust. Cracked material doesn't
        // go to zero E — it keeps 40% stiffness as rigid chunks.
        float integrity = max(1.0 - crack * 0.75, 0.25);
        float mu_c = (E_c * integrity) / (2.0 * (1.0 + nu));
        float lam_c = (E_c * integrity) * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));

        stress = 2.0 * mu_c * (F - R) * transpose(F)
               + lam_c * (J - 1.0) * J * mat2(1.0);

        // Reduce stress exchange more aggressively than stiffness so hot ceramics
        // separate into chunks instead of collapsing into a soft ribbon.
        if (crack > 0.35) {
            float bond_loss = smoothstep(0.35, 1.0, crack);
            stress *= mix(1.0, 0.18, bond_loss);
        }
    }
    else if (mat_type == MAT_BLOOM) {
        float cured = damage[idx];
        float crack = Jp_data[idx];
        float bloom = phase_data[idx];

        if (temp > 420.0) {
            float prev = cured;
            cured += 0.7 * u_dt * clamp((temp - 420.0) / 220.0, 0.0, 1.0);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * 0.18;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }
        damage[idx] = cured;

        float target_bloom = clamp((temp - 560.0) / 220.0, 0.0, 1.0) * clamp(cured * 1.3 - 0.2, 0.0, 1.0);
        bloom += clamp(target_bloom - bloom, -0.6 * u_dt, 1.8 * u_dt);
        bloom = clamp(bloom, 0.0, 1.0);
        phase_data[idx] = bloom;

        float E_b = E * (1.2 + cured * 4.2);
        float integrity = max(1.0 - crack * 0.7, 0.30);
        float mu_b = (E_b * integrity) / (2.0 * (1.0 + nu));
        float lam_b = (E_b * integrity) * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));
        float J_rest = 1.0 + bloom * cured * 0.22;
        stress = 2.0 * mu_b * (F - R) * transpose(F)
               + lam_b * (J - J_rest) * J * mat2(1.0);

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = mix(0.11, 0.03, cured) * (1.0 - bloom * 0.4);
        float crack_rate = mix(0.6, 5.0, cured) * (1.0 + bloom * 2.5);
        float crack_drive = max(tensile * 1.2 + shear * 1.4 + bloom * 0.18 - crack_thresh, 0.0);
        crack += crack_drive * crack_rate * u_dt;
        crack = clamp(crack, 0.0, 1.0);
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.5, 0.35);
        if (crack > 0.35) {
            float petal = smoothstep(0.35, 1.0, crack);
            stress *= mix(1.0, 0.16, petal);
        }
    }
    else if (mat_type == MAT_SPLINTER) {
        float cured = damage[idx];
        float crack = Jp_data[idx];
        float bloom = phase_data[idx];

        if (temp > 430.0) {
            float prev = cured;
            cured += 1.1 * u_dt * clamp((temp - 430.0) / 170.0, 0.0, 1.0);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * 0.12;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }
        damage[idx] = cured;

        float thermal_drive = clamp((temp - 540.0) / 170.0, 0.0, 1.0);
        bloom += clamp(thermal_drive - bloom, -0.5 * u_dt, 2.8 * u_dt);
        bloom = clamp(bloom, 0.0, 1.0);
        phase_data[idx] = bloom;

        vec2 fiber = normalize(fiber_dirs[idx] + vec2(1e-6, 0.0));
        vec2 df = F * fiber;
        float fs = length(df);
        vec2 perp = vec2(-fiber.y, fiber.x);
        float perp_strain = abs(length(F * perp) - 1.0);
        float along_strain = abs(fs - 1.0);

        float E_s = E * (1.1 + cured * 5.6);
        float mu_s = E_s / (2.0 * (1.0 + nu));
        float lam_s = E_s * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));
        float J_rest = 1.0 + cured * 0.015 - bloom * 0.05;

        stress = 2.0 * mu_s * (F - R) * transpose(F)
               + lam_s * (J - J_rest) * J * mat2(1.0);

        if (fs > 1e-6) {
            vec2 fh = df / fs;
            float fi = clamp(fs - 1.0, -0.25, 0.35);
            stress += fiber_strength * mu_s * (1.0 + cured * 0.8) * fi * mat2(
                fh.x*fh.x, fh.x*fh.y, fh.y*fh.x, fh.y*fh.y);
        }

        float self_split = max(bloom * cured - 0.28, 0.0);
        float crack_drive = max(perp_strain * 1.8 + self_split * 0.55 - along_strain * 0.2 - 0.04, 0.0);
        crack += crack_drive * (3.8 + bloom * 5.0) * u_dt;
        crack = clamp(crack, 0.0, 1.0);
        Jp_data[idx] = crack;

        float matrix_keep = max(1.0 - crack * 0.82, 0.16);
        stress *= matrix_keep;
        if (crack > 0.28) {
            float split = smoothstep(0.28, 1.0, crack);
            stress *= mix(1.0, 0.08, split);
        }
    }
    else if (mat_type == MAT_BREAD) {
        float baked = damage[idx];
        float gas = phase_data[idx];
        float tear = Jp_data[idx];

        if (temp > 340.0) {
            gas += 2.2 * u_dt * clamp((temp - 340.0) / 180.0, 0.0, 1.0) * (1.0 - gas) * mix(1.0, 0.75, baked);
        } else {
            gas += (0.0 - gas) * 0.16 * u_dt;
        }
        gas = clamp(gas, 0.0, 1.0);

        if (temp > 385.0) {
            float prev = baked;
            baked += 0.55 * u_dt * clamp((temp - 385.0) / 220.0, 0.0, 1.0) * (1.0 - baked);
            baked = clamp(baked, 0.0, 1.0);
            float dbake = baked - prev;
            if (dbake > 0.0) {
                float anneal = dbake * 0.10;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float warm_soft = smoothstep(340.0, 560.0, temp);
        float crumb_set = smoothstep(0.16, 0.70, gas) * smoothstep(0.10, 0.85, baked);
        float E_d = E * mix(1.20, 2.25, baked) * mix(1.0, 0.90, warm_soft) * (1.0 + crumb_set * 2.1);
        float nu_d = clamp(mix(0.33, 0.27, baked), 0.16, 0.38);
        float mu_d = E_d / (2.0 * (1.0 + nu_d));
        float lam_d = E_d * nu_d / ((1.0 + nu_d) * (1.0 - 2.0 * nu_d));
        // Match crust_dough / steam_bun: gas-inflated J_rest benefits from 2.5D depth so
        // plain bread doesn't starve for the pseudo-thickness reinforcement the other
        // baking materials already get.
        float J_rest = 1.0 + gas * mix(0.24, 0.36, baked) * (1.0 + 0.22 * pseudo_depth)
                           - baked * 0.02 - crumb_set * 0.015;

        stress = 2.0 * mu_d * (F - R) * transpose(F)
               + lam_d * (J - J_rest) * J * mat2(1.0);
        stress += gas * mu_d * mix(0.10, 0.04, crumb_set) * (C + transpose(C));

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float tear_thresh = (mix(0.36, 0.20, baked) + crumb_set * 0.08) * pseudo_enclosure_hold;
        float tear_rate = mix(0.18, 1.55, baked) * (1.0 + gas * 0.9) / pseudo_split_hold;
        float tear_drive = max(tensile * 1.00 + shear * 0.78 + gas * (0.18 + baked * 0.14) - tear_thresh, 0.0);
        tear += tear_drive * tear_rate * u_dt;
        tear = clamp(tear, 0.0, 1.0);
        if (tear > 0.62) gas *= max(1.0 - 1.1 * u_dt, 0.0);

        damage[idx] = baked;
        phase_data[idx] = gas;
        Jp_data[idx] = tear;

        stress *= max(1.0 - tear * 0.60, 0.34);
        if (tear > 0.42) {
            float vent = smoothstep(0.42, 1.0, tear);
            stress *= mix(1.0, 0.32, vent);
        }
    }
    else if (mat_type == MAT_PUFF_CLAY) {
        float cured = damage[idx];
        float gas = phase_data[idx];
        float crack = Jp_data[idx];

        if (temp > 425.0) {
            float prev = cured;
            cured += 0.75 * u_dt * clamp((temp - 425.0) / 190.0, 0.0, 1.0);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * 0.14;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float target_gas = clamp((temp - 535.0) / 180.0, 0.0, 1.0) * clamp(cured * 1.25 - 0.12, 0.0, 1.0);
        gas += clamp(target_gas - gas, -0.25 * u_dt, 2.2 * u_dt);
        gas = clamp(gas, 0.0, 1.0);

        float E_pc = E * (1.0 + cured * 4.8) * mix(1.0, 0.72, gas);
        float nu_pc = clamp(mix(nu, 0.31, gas), 0.14, 0.35);
        float mu_pc = E_pc / (2.0 * (1.0 + nu_pc));
        float lam_pc = E_pc * nu_pc / ((1.0 + nu_pc) * (1.0 - 2.0 * nu_pc));
        float J_rest = 1.0 + gas * (0.14 + 0.10 * cured);

        stress = 2.0 * mu_pc * (F - R) * transpose(F)
               + lam_pc * (J - J_rest) * J * mat2(1.0);

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = mix(0.16, 0.05, cured) * (1.0 - gas * 0.28);
        float crack_rate = mix(0.8, 5.6, cured) * (1.0 + gas * 2.2);
        float crack_drive = max(tensile * 1.25 + shear * 1.65 + gas * (0.28 + cured * 0.40) - crack_thresh, 0.0);
        crack += crack_drive * crack_rate * u_dt;
        crack = clamp(crack, 0.0, 1.0);
        if (crack > 0.35) gas *= max(1.0 - 1.2 * u_dt, 0.0);

        damage[idx] = cured;
        phase_data[idx] = gas;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.60, 0.20);
        if (crack > 0.32) {
            float crumble = smoothstep(0.32, 1.0, crack);
            stress *= mix(1.0, 0.10, crumble);
        }
    }
    else if (mat_type == MAT_FIRECRACKER) {
        float fuse = damage[idx];
        float gas = phase_data[idx];
        float crack = Jp_data[idx];
        float batch_heat = max(thermal_params.y, 0.1);
        float batch_cooling = max(thermal_params.z, 0.02);
        float batch_loft = max(thermal_params.w, 0.0);

        if (temp > 340.0 && fuse < 1.0) {
            float ignite_rate = mix(2.35, 1.05, shell_seed) * mix(0.82, 1.22, clamp(batch_cooling, 0.0, 1.2));
            fuse += ignite_rate * u_dt * clamp((temp - 340.0) / 170.0, 0.0, 1.0);
        }
        if (fuse > 0.03 && fuse < 0.985) {
            temp += (1480.0 + 260.0 * batch_heat) * clamp(fuse * (1.0 - fuse) * 4.0, 0.0, 1.0) * u_dt;
        }
        fuse = clamp(fuse, 0.0, 1.0);
        temperatures[p] = clamp(temp, 0.0, 1400.0);

        float target_gas = clamp((fuse - mix(0.10, 0.22, shell_seed)) / mix(0.18, 0.44, shell_seed), 0.0, 1.0)
                         * mix(1.18, 0.56, shell_seed);
        gas += clamp(target_gas - gas, -0.18 * u_dt, 14.0 * u_dt);
        gas = clamp(gas, 0.0, 1.0);

        float sealed = 1.0 - smoothstep(mix(0.18, 0.32, shell_seed), mix(0.62, 0.78, shell_seed), crack);
        float pressure = gas * sealed * mix(1.45, 0.78, shell_seed);
        float E_fc = E * mix(1.10, 0.78, fuse) * mix(1.0, 1.45, shell_seed * (1.0 - crack));
        float mu_fc = E_fc / (2.0 * (1.0 + nu));
        float lam_fc = E_fc * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));
        float J_rest = 1.0 + pressure * (0.62 + 0.10 * core_seed) + gas * 0.08 - shell_seed * fuse * 0.04;

        stress = 2.0 * mu_fc * (F - R) * transpose(F)
               + lam_fc * (J - J_rest) * J * mat2(1.0);
        if (pressure > 0.02) {
            stress += mat2(pressure * mu_fc * (0.22 + 0.20 * core_seed));
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_drive = max(tensile * 1.10 + shear * 1.45 + pressure * (2.30 + fuse * 4.8) - mix(0.09, 0.04, core_seed), 0.0);
        if (fuse > mix(0.22, 0.14, core_seed)) {
            crack += crack_drive * (1.4 + pressure * 42.0) * u_dt;
        }
        crack = clamp(crack, 0.0, 1.0);

        float vent = smoothstep(0.56, 0.96, crack) * smoothstep(0.36, 0.96, pressure);
        if (vent > 0.001) {
            float h0 = hash1(vec2(float(p) * 0.6180339 + fuse * 31.7,
                                  float(idx) * 1.173 + gas * 17.3));
            // Use angle-based random direction (guaranteed uniform on circle)
            float angle = h0 * 6.28318;
            vec2 burst_dir = vec2(cos(angle), sin(angle));
            float burst_speed = vent * mix(14.0, 46.0, pressure) * mix(1.0, 0.58, shell_seed);
            vel += burst_dir * burst_speed;
            gas *= max(1.0 - vent * 0.94, 0.0);
            C *= max(1.0 - vent * 0.82, 0.04);
            temp = max(temp, 680.0 + 220.0 * pressure + 120.0 * batch_loft);
        }

        damage[idx] = fuse;
        phase_data[idx] = gas;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.96, 0.02);
        if (crack > 0.30) {
            float burst = smoothstep(0.30, 1.0, crack);
            stress *= mix(1.0, 0.02, burst);
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            F = F * (1.0 - burst * 0.22) + F_iso * (burst * 0.22);
        }
    }
    else if (mat_type == MAT_GLAZE_CLAY) {
        float cured = damage[idx];
        float glaze = phase_data[idx];
        float crack = Jp_data[idx];

        if (temp > 380.0) {
            float prev = cured;
            float cure_rate = mix(0.28, 1.20, shell_seed) * clamp((temp - 380.0) / 230.0, 0.0, 1.0);
            cured += cure_rate * u_dt * (1.0 - cured);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * mix(0.06, 0.18, shell_seed);
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float target_glaze = shell_seed * clamp((temp - 610.0) / 190.0, 0.0, 1.0) * smoothstep(0.35, 0.85, cured);
        glaze += clamp(target_glaze - glaze, -0.24 * u_dt, 1.35 * u_dt);
        glaze = clamp(glaze, 0.0, 1.0);

        float shell_shrink = shell_seed * cured * 0.055 + shell_seed * clamp((temp - 430.0) / 260.0, 0.0, 1.0) * 0.015;
        float core_swelling = core_seed * clamp((temp - 460.0) / 220.0, 0.0, 1.0) * (1.0 - cured) * 0.045;
        float glaze_flow = glaze * shell_seed * clamp((temp - 700.0) / 220.0, 0.0, 1.0) * 0.02;

        float E_gc = E * mix(0.85, 4.8, cured) * mix(1.0, 0.72, glaze * shell_seed);
        float nu_gc = clamp(mix(nu, 0.32, glaze * shell_seed), 0.12, 0.36);
        float mu_gc = E_gc / (2.0 * (1.0 + nu_gc));
        float lam_gc = E_gc * nu_gc / ((1.0 + nu_gc) * (1.0 - 2.0 * nu_gc));
        float J_rest = 1.0 - shell_shrink + core_swelling + glaze_flow;

        stress = 2.0 * mu_gc * (F - R) * transpose(F)
               + lam_gc * (J - J_rest) * J * mat2(1.0);
        if (glaze > 0.04) {
            stress += shell_seed * glaze * mu_gc * 0.18 * (C + transpose(C));
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float mismatch = abs(shell_shrink - core_swelling) + glaze * shell_seed * 0.08;
        float crack_thresh = mix(0.18, 0.07, cured) * mix(1.0, 0.82, shell_seed);
        float crack_rate = mix(0.35, 3.4, cured) * (1.0 + shell_seed * 1.5 + glaze);
        float crack_drive = max(tensile * 1.15 + shear * 1.25 + mismatch - crack_thresh, 0.0);
        crack += crack_drive * crack_rate * u_dt;
        crack = clamp(crack, 0.0, 1.0);

        damage[idx] = cured;
        phase_data[idx] = glaze;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.58, 0.24);
        if (crack > 0.38) {
            float shard = smoothstep(0.38, 1.0, crack);
            stress *= mix(1.0, 0.18, shard);
        }
    }
    else if (mat_type == MAT_GLAZE_DRIP) {
        float cured = damage[idx];
        float glaze = phase_data[idx];
        float crack = Jp_data[idx];

        if (temp > 360.0) {
            float prev = cured;
            float cure_rate = mix(0.22, 0.95, shell_seed) * clamp((temp - 360.0) / 240.0, 0.0, 1.0);
            cured += cure_rate * u_dt * (1.0 - cured);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * mix(0.05, 0.14, shell_seed);
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float target_glaze = shell_seed * clamp((temp - 560.0) / 150.0, 0.0, 1.0) * smoothstep(0.20, 0.70, cured);
        glaze += clamp(target_glaze - glaze, -0.18 * u_dt, 1.90 * u_dt);
        glaze = clamp(glaze, 0.0, 1.0);

        float shell_shrink = shell_seed * cured * 0.035;
        float core_swelling = core_seed * clamp((temp - 470.0) / 220.0, 0.0, 1.0) * (1.0 - cured) * 0.03;
        float E_gd = E * mix(0.80, 3.20, cured) * mix(1.0, 0.24, glaze * shell_seed);
        float nu_gd = clamp(mix(nu, 0.34, glaze * shell_seed), 0.16, 0.39);
        float mu_gd = E_gd / (2.0 * (1.0 + nu_gd));
        float lam_gd = E_gd * nu_gd / ((1.0 + nu_gd) * (1.0 - 2.0 * nu_gd));
        float J_rest = 1.0 - shell_shrink + core_swelling + glaze * shell_seed * 0.045;

        stress = 2.0 * mu_gd * (F - R) * transpose(F)
               + lam_gd * (J - J_rest) * J * mat2(1.0);
        if (glaze > 0.04) {
            stress += shell_seed * glaze * mu_gd * 0.36 * (C + transpose(C));
        }
        if (glaze > 0.30) {
            float relax = shell_seed * smoothstep(0.30, 1.0, glaze) * 0.022;
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            F = F * (1.0 - relax) + F_iso * relax;
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float mismatch = abs(shell_shrink - core_swelling) * 0.8 + glaze * shell_seed * 0.04;
        float crack_thresh = mix(0.22, 0.10, cured) * (1.0 + glaze * 0.25);
        float crack_rate = mix(0.18, 1.80, cured) * (1.0 + shell_seed * 0.8);
        float crack_drive = max(tensile * 1.00 + shear * 0.90 + mismatch - crack_thresh, 0.0);
        crack += crack_drive * crack_rate * u_dt;
        crack = clamp(crack, 0.0, 1.0);

        damage[idx] = cured;
        phase_data[idx] = glaze;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.50, 0.22);
        if (crack > 0.55) {
            float shard = smoothstep(0.55, 1.0, crack);
            stress *= mix(1.0, 0.24, shard);
        }
    }
    else if (mat_type == MAT_CRUST_DOUGH) {
        float crust = damage[idx];
        float gas = phase_data[idx];
        float tear = Jp_data[idx];

        float gas_source = clamp((temp - 345.0) / 165.0, 0.0, 1.0) * mix(1.8, 0.12, shell_seed) * (1.0 - crust * 0.25);
        gas += gas_source * 2.2 * u_dt * (1.0 - gas);
        if (temp < 335.0) {
            gas += (0.0 - gas) * 0.10 * u_dt / pseudo_enclosure_hold;
        }
        gas = clamp(gas, 0.0, 1.0);

        if (temp > 370.0) {
            float prev = crust;
            float crust_rate = mix(0.18, 1.40, shell_seed) * clamp((temp - 370.0) / 220.0, 0.0, 1.0);
            crust += crust_rate * u_dt * (1.0 - crust);
            crust = clamp(crust, 0.0, 1.0);
            float dcrust = crust - prev;
            if (dcrust > 0.0) {
                float anneal = dcrust * mix(0.04, 0.10, shell_seed);
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float warm_soft = smoothstep(340.0, 560.0, temp);
        float crumb_set = smoothstep(0.14, 0.72, gas) * smoothstep(0.12, 0.90, crust);
        float shell_stiff = mix(1.20, 6.80, crust * shell_seed) * mix(1.0, pseudo_shell_boost, 0.24 + crust * 0.48);
        float core_soft = mix(1.0, 0.90, warm_soft * core_seed);
        float crumb_scaffold = (1.0 + crumb_set * mix(0.85, 0.30, shell_seed))
                             * (1.0 + pseudo_depth * (0.08 + crumb_set * 0.34));
        float E_cd = E * shell_stiff * core_soft * crumb_scaffold * mix(0.96, 1.10, shell_seed);
        float nu_cd = clamp(mix(0.32, 0.22, crust * shell_seed), 0.16, 0.38);
        float mu_cd = E_cd / (2.0 * (1.0 + nu_cd));
        float lam_cd = E_cd * nu_cd / ((1.0 + nu_cd) * (1.0 - 2.0 * nu_cd));
        float J_rest = 1.0 + gas * (0.30 + 0.18 * core_seed) * (1.0 + 0.30 * pseudo_depth * core_seed)
