            binder = clamp(binder, 0.0, 1.0);
            float dbind = binder - prev;
            if (dbind > 0.0) {
                float anneal = dbind * mix(0.02, 0.08, shell_seed);
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float evap = heat * moisture * mix(0.16, 0.96, core_seed) * mix(0.90, 1.12, micro) / pseudo_enclosure_hold;
        moisture += -evap * u_dt;
        moisture = clamp(moisture, 0.0, 1.0);

        vec2 grain = normalize(fiber_dirs[idx] + vec2(1e-6, 0.0));
        vec2 cross_dir = vec2(-grain.y, grain.x);
        vec2 dg = F * grain;
        vec2 dc = F * cross_dir;
        float gs = max(length(dg), 1e-6);
        float cs = max(length(dc), 1e-6);
        vec2 gh = dg / gs;
        float along = abs(gs - 1.0);
        float across = abs(cs - 1.0);

        float gas = heat * moisture * (0.26 + 0.54 * core_seed) * (0.42 + 0.58 * (1.0 - binder));
        float channel_drive = max(gas * (0.14 + 0.30 * core_seed) * pseudo_volume_hold
                                + across * 0.08 + along * 0.04 - channel * (0.04 + 0.04 * shell_seed), 0.0);
        channel += channel_drive * u_dt;
        channel = clamp(channel, 0.0, 1.0);

        float scaffold = smoothstep(0.12, 0.84, binder);
        float E_cc = E * mix(0.94, 2.20, binder) * (1.0 + scaffold * 1.00 + channel * (0.30 + 0.36 * core_seed))
                       * mix(1.0, pseudo_shell_boost, 0.12 + 0.28 * binder)
                       * (1.0 + pseudo_depth * (0.10 + 0.22 * channel))
                       * mix(1.0, 0.82, gas * 0.36);
        float nu_cc = clamp(mix(0.31, 0.22, binder), 0.16, 0.40);
        float mu_cc = E_cc / (2.0 * (1.0 + nu_cc));
        float lam_cc = E_cc * nu_cc / ((1.0 + nu_cc) * (1.0 - 2.0 * nu_cc));
        float J_rest = 1.0 + gas * (0.22 + 0.18 * core_seed) * (1.0 + 0.34 * pseudo_depth * core_seed)
                            + channel * 0.05 * pseudo_volume_hold - shell_seed * binder * 0.024;

        stress = 2.0 * mu_cc * (F - R) * transpose(F)
               + lam_cc * (J - J_rest) * J * mat2(1.0);
        stress += fiber_strength * mu_cc * (0.10 + 0.30 * scaffold) * (gs - 1.0) * mat2(
            gh.x*gh.x, gh.x*gh.y,
            gh.y*gh.x, gh.y*gh.y);

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float vent_thresh = (0.50 + scaffold * 0.12) * pseudo_enclosure_hold + pseudo_shell * 0.03;
        float vent_drive = max(tensile * 0.36 + shear * 0.24 + across * 0.28 + gas * 0.34 - vent_thresh, 0.0);
        channel += vent_drive * (0.10 + gas * 0.85 + binder * 0.24) * u_dt;
        channel = clamp(channel, 0.0, 1.0);
        if (channel > 0.54) {
            moisture *= max(1.0 - (0.24 + 0.28 * core_seed) * u_dt / pseudo_enclosure_hold, 0.0);
        }

        damage[idx] = binder;
        phase_data[idx] = moisture;
        Jp_data[idx] = channel;

        stress *= max(1.0 - channel * mix(0.30, 0.18, clamp(pseudo_cohesion * 0.70, 0.0, 1.0)), 0.44);
    }
    else if (mat_type == MAT_BURNOUT_CLAY) {
        float fired = damage[idx];
        float moisture = phase_data[idx];
        float pore = Jp_data[idx];
        float micro = hash1(vec2(float(p) * 0.187 + 4.8, float(idx) * 0.093 + 7.1));

        float heat = smoothstep(360.0, 1180.0, temp);
        float dry_heat = smoothstep(340.0, 680.0, temp);
        float evap = dry_heat * moisture * mix(0.12, 0.78, core_seed) * mix(0.92, 1.10, micro) / pseudo_enclosure_hold;
        moisture += -evap * u_dt;
        moisture = clamp(moisture, 0.0, 1.0);

        if (temp > 430.0) {
            float prev = fired;
            float fire_rate = mix(0.06, 0.92, shell_seed) * clamp((temp - 430.0) / 440.0, 0.0, 1.0);
            fired += fire_rate * u_dt * (1.0 - fired);
            fired = clamp(fired, 0.0, 1.0);
            float dfire = fired - prev;
            if (dfire > 0.0) {
                float anneal = dfire * mix(0.02, 0.10, shell_seed);
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float burnout = smoothstep(430.0, 920.0, temp) * (0.24 + 0.76 * fired) * mix(0.32, 1.00, core_seed);
        pore += max(burnout * (0.12 + 0.16 * micro) - pore * (0.04 + 0.03 * shell_seed), 0.0) * u_dt;
        pore = clamp(pore, 0.0, 1.0);

        float shrink = fired * (0.08 + 0.12 * shell_seed);
        float E_bo = E * mix(0.92, 2.80, fired) * (1.0 - pore * 0.18)
                       * mix(1.0, pseudo_shell_boost, 0.16 + 0.40 * fired)
                       * (1.0 + pseudo_depth * 0.18);
        float nu_bo = clamp(mix(0.24, 0.17, fired), 0.12, 0.32);
        float mu_bo = E_bo / (2.0 * (1.0 + nu_bo));
        float lam_bo = E_bo * nu_bo / ((1.0 + nu_bo) * (1.0 - 2.0 * nu_bo));
        float J_rest = 1.0 - shrink + pore * 0.026 * pseudo_volume_hold + moisture * 0.02 * core_seed;

        stress = 2.0 * mu_bo * (F - R) * transpose(F)
               + lam_bo * (J - J_rest) * J * mat2(1.0);

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float check = max(tensile * 0.18 + shear * 0.14 + pore * 0.06 - (0.46 + fired * 0.08) * pseudo_split_hold, 0.0);
        pore += check * 0.18 * u_dt;
        pore = clamp(pore, 0.0, 1.0);

        damage[idx] = fired;
        phase_data[idx] = moisture;
        Jp_data[idx] = pore;

        stress *= max(1.0 - pore * mix(0.24, 0.14, clamp(pseudo_cohesion * 0.70, 0.0, 1.0)), 0.46);
    }
    else if (mat_type == MAT_VENTED_SKIN) {
        float dry = damage[idx];
        float moisture = phase_data[idx];
        float vent = Jp_data[idx];
        float micro = hash1(vec2(float(p) * 0.223 + 0.7, float(idx) * 0.063 + 6.8));

        if (temp > 342.0) {
            float prev = dry;
            float dry_rate = mix(0.14, 1.10, shell_seed) * clamp((temp - 342.0) / 225.0, 0.0, 1.0);
            dry += dry_rate * u_dt * (1.0 - dry);
            dry = clamp(dry, 0.0, 1.0);
            float ddry = dry - prev;
            if (ddry > 0.0) {
                float anneal = ddry * mix(0.02, 0.07, shell_seed);
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }

        float heat = smoothstep(350.0, 560.0, temp);
        float evap = heat * moisture * mix(0.10, 0.72, core_seed) * mix(0.92, 1.08, micro) / pseudo_enclosure_hold;
        moisture += -evap * u_dt;
        moisture = clamp(moisture, 0.0, 1.0);

        vec2 fiber = normalize(fiber_dirs[idx] + vec2(1e-6, 0.0));
        vec2 df = F * fiber;
        float fs = max(length(df), 1e-6);
        vec2 fh = df / fs;
        vec2 perp = vec2(-fiber.y, fiber.x);
        float across = abs(length(F * perp) - 1.0);
        float along = abs(fs - 1.0);

        float gas = heat * moisture * (0.18 + 0.40 * core_seed) * (0.50 + 0.50 * (1.0 - dry));
        float E_vs = E * mix(0.98, 2.30, dry) * mix(1.0, pseudo_shell_boost, 0.16 + 0.34 * dry)
                       * (1.0 + pseudo_depth * 0.10) * mix(1.0, 0.82, gas * 0.26);
        float nu_vs = clamp(mix(0.34, 0.22, dry), 0.14, 0.40);
        float mu_vs = E_vs / (2.0 * (1.0 + nu_vs));
        float lam_vs = E_vs * nu_vs / ((1.0 + nu_vs) * (1.0 - 2.0 * nu_vs));
        float J_rest = 1.0 + gas * 0.04 - dry * (0.024 + 0.008 * shell_seed);

        stress = 2.0 * mu_vs * (F - R) * transpose(F)
               + lam_vs * (J - J_rest) * J * mat2(1.0);
        stress += fiber_strength * mu_vs * (0.38 + dry * 0.44) * clamp(fs - 1.0, -0.16, 0.24) * mat2(
            fh.x*fh.x, fh.x*fh.y, fh.y*fh.x, fh.y*fh.y);

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float vent_thresh = (0.50 + dry * 0.12) * pseudo_enclosure_hold + pseudo_shell * 0.04;
        float vent_drive = max(tensile * 0.40 + shear * 0.22 + across * 0.28 + along * 0.12 + gas * 0.30 - vent_thresh, 0.0);
        vent += vent_drive * (0.10 + gas * 1.05 + dry * 0.18) * u_dt;
        vent = clamp(vent, 0.0, 1.0);
        if (vent > 0.48) {
            moisture *= max(1.0 - (0.30 + 0.22 * core_seed) * u_dt / pseudo_enclosure_hold, 0.0);
        }

        damage[idx] = dry;
        phase_data[idx] = moisture;
        Jp_data[idx] = vent;

        stress *= max(1.0 - vent * mix(0.22, 0.12, clamp(pseudo_cohesion * 0.70, 0.0, 1.0)), 0.54);
        if (vent > 0.72) {
            float open = smoothstep(0.72, 1.0, vent);
            stress *= mix(1.0, mix(0.76, 0.86, clamp(pseudo_cohesion * 0.70, 0.0, 1.0)), open);
        }
    }
    else if (mat_type == MAT_MAILLARD) {
        float brown = damage[idx];
        float dry = phase_data[idx];
        float blister = Jp_data[idx];

        float cook = smoothstep(360.0, 540.0, temp);
        if (temp > 350.0) {
            dry += mix(0.10, 0.85, shell_seed) * cook * u_dt * (1.0 - dry);
        }
        dry = clamp(dry, 0.0, 1.0);

        float brown_drive = smoothstep(390.0, 580.0, temp) * mix(0.25, 1.25, shell_seed);
        brown += brown_drive * (0.25 + dry * 0.75) * u_dt * (1.0 - brown);
        brown = clamp(brown, 0.0, 1.0);

        float steam_drive = smoothstep(380.0, 520.0, temp) * (1.0 - dry) * core_seed;
        blister += max(steam_drive * 0.34 - 0.04, 0.0) * u_dt;
        blister = clamp(blister, 0.0, 1.0);

        float E_ml = E * mix(0.92, 1.45, brown * shell_seed + dry * 0.35)
                       * mix(1.0, 0.86, cook * core_seed * 0.4);
        float nu_ml = clamp(mix(0.30, 0.24, dry), 0.16, 0.39);
        float mu_ml = E_ml / (2.0 * (1.0 + nu_ml));
        float lam_ml = E_ml * nu_ml / ((1.0 + nu_ml) * (1.0 - 2.0 * nu_ml));
        float J_rest = 1.0 + core_seed * (1.0 - dry) * 0.040 + blister * 0.020 - shell_seed * brown * 0.030;

        stress = 2.0 * mu_ml * (F - R) * transpose(F)
               + lam_ml * (J - J_rest) * J * mat2(1.0);
        if (dry < 0.65) {
            stress += mu_ml * (0.05 + core_seed * 0.08) * (1.0 - dry) * (C + transpose(C));
        }

        if (blister > 0.70) {
            float vent = smoothstep(0.70, 1.0, blister);
            stress *= mix(1.0, 0.64, vent);
        }

        damage[idx] = brown;
        phase_data[idx] = dry;
        Jp_data[idx] = blister;
    }
    else if (mat_type == MAT_FILAMENT_GLASS || mat_type == MAT_CHEESE_PULL) {
        bool is_cheese = (mat_type == MAT_CHEESE_PULL);
        float soft = phase_data[idx];
        float stringy = damage[idx];
        float tear = Jp_data[idx];

        float target_soft = smoothstep(is_cheese ? 315.0 : 690.0, is_cheese ? 500.0 : 1020.0, temp);
        soft += clamp(target_soft - soft, -2.0 * u_dt, 2.4 * u_dt);
        soft = clamp(soft, 0.0, 1.0);

        vec2 major_axis = (svd.sigma.x >= svd.sigma.y)
            ? normalize(svd.U[0] + vec2(1e-6, 0.0))
            : normalize(svd.U[1] + vec2(1e-6, 0.0));
        vec2 fiber = fiber_dirs[idx];
        if (length(fiber) < 0.15) fiber = major_axis;
        float align = mix(0.06, is_cheese ? 0.34 : 0.24, soft);
        fiber = normalize(mix(fiber, major_axis, align) + vec2(1e-6, 0.0));
        fiber_dirs[idx] = fiber;
        vec2 perp = vec2(-fiber.y, fiber.x);

        float axial = length(F * fiber);
        float radial = length(F * perp);
        float ext = max(axial - 1.0, 0.0);
        float neck = clamp(1.0 - radial, 0.0, 1.0);
        float aspect = axial / max(radial, 0.35);

        float thread_target = smoothstep(0.22, 0.86, soft) *
                              smoothstep(is_cheese ? 1.05 : 1.12, is_cheese ? 2.2 : 2.9, aspect);
        stringy += clamp(thread_target - stringy, -1.4 * u_dt, 2.0 * u_dt);
        stringy = clamp(stringy, 0.0, 1.0);

        float E_fg = E * mix(is_cheese ? 1.25 : 1.95, is_cheese ? 0.18 : 0.14, soft)
                       * mix(1.0, is_cheese ? 1.22 : 1.45, stringy);
        float nu_fg = clamp(mix(is_cheese ? 0.34 : 0.22, is_cheese ? 0.42 : 0.33, soft), 0.16, 0.43);
        float mu_fg = E_fg / (2.0 * (1.0 + nu_fg));
        float lam_fg = E_fg * nu_fg / ((1.0 + nu_fg) * (1.0 - 2.0 * nu_fg));
        float J_rest = 1.0 + soft * (is_cheese ? 0.055 : 0.030) - stringy * neck * (is_cheese ? 0.030 : 0.015);

        stress = 2.0 * mu_fg * (F - R) * transpose(F)
               + lam_fg * (J - J_rest) * J * mat2(1.0);

        float axial_visc = mu_fg * mix(0.08, is_cheese ? 0.55 : 0.42, clamp(soft + stringy * 0.4, 0.0, 1.0));
        stress += axial_visc * (C + transpose(C));

        float axial_drive = max(ext + neck * (is_cheese ? 0.45 : 0.35), 0.0);
        mat2 fiber_outer = mat2(fiber.x * fiber.x, fiber.x * fiber.y,
                                fiber.y * fiber.x, fiber.y * fiber.y);
        stress += E * (is_cheese ? 0.65 : 1.05) * mix(0.10, 0.42, soft) * max(stringy, 0.18)
                * axial_drive * fiber_outer;

        float tear_thresh = is_cheese
            ? (0.85 + soft * 0.35 + stringy * 0.18)
            : (mix(0.82, 0.30, soft) + stringy * 0.10);
        float tear_rate = is_cheese
            ? mix(0.05, 0.40, soft) * (1.0 + aspect * 0.10)
            : mix(0.15, 1.40, soft) * (1.0 + aspect * 0.18);
        float tear_drive = max(ext * (is_cheese ? 0.60 : 0.95)
                             + neck * (is_cheese ? 0.35 : 0.72)
                             + abs(J - J_rest) * 0.50 - tear_thresh, 0.0);
        tear += tear_drive * tear_rate * u_dt;
        if (!is_cheese && soft < 0.25 && stringy > 0.45) {
            tear += stringy * 0.45 * u_dt;
        }
        tear = clamp(tear, 0.0, 1.0);

        if (soft > 0.72) {
            float relax = (is_cheese ? 0.010 : 0.007) * soft * (1.0 - stringy * 0.35);
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            F = F * (1.0 - relax) + F_iso * relax;
        }

        damage[idx] = stringy;
        phase_data[idx] = soft;
        Jp_data[idx] = tear;

        stress *= max(1.0 - tear * (is_cheese ? 0.34 : 0.56), is_cheese ? 0.42 : 0.18);
        if (tear > (is_cheese ? 0.72 : 0.48)) {
            float fail = smoothstep(is_cheese ? 0.72 : 0.48, 1.0, tear);
            stress *= mix(1.0, is_cheese ? 0.46 : 0.16, fail);
        }
    }
    else if (mat_type == MAT_THERMO_METAL) {
        float harden = damage[idx];
        float hot_memory = phase_data[idx];
        float crack = Jp_data[idx];

        float hot = smoothstep(520.0, 920.0, temp);
        if (temp > 620.0) {
            hot_memory += 0.90 * u_dt * clamp((temp - 620.0) / 220.0, 0.0, 1.0) * (1.0 - hot_memory);
            float anneal = smoothstep(660.0, 980.0, temp) * 0.10 * u_dt;
            F = F * (1.0 - anneal) + R * anneal;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
        } else {
            hot_memory += (0.0 - hot_memory) * 0.04 * u_dt;
        }
        hot_memory = clamp(hot_memory, 0.0, 1.0);

        if (temp < 520.0 && hot_memory > harden) {
            float quench = clamp((520.0 - temp) / 220.0, 0.0, 1.0);
            harden += (hot_memory - harden) * mix(0.35, 1.6, quench) * u_dt;
        }
        harden = clamp(harden, 0.0, 1.0);

        float E_tm = E * mix(1.0, 1.65, harden) * mix(1.0, 0.46, hot);
        float nu_tm = clamp(mix(nu, 0.26, harden), 0.14, 0.34);
        float mu_tm = E_tm / (2.0 * (1.0 + nu_tm));
        float lam_tm = E_tm * nu_tm / ((1.0 + nu_tm) * (1.0 - 2.0 * nu_tm));
        float thermal_rest = 1.0 + 0.00008 * (temp - 300.0) * (1.0 - harden * 0.12);

        stress = 2.0 * mu_tm * (F - R) * transpose(F)
               + lam_tm * (J - thermal_rest) * J * mat2(1.0);
        if (hot > 0.12) {
            stress += mu_tm * hot * 0.04 * (C + transpose(C));
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float thermal_strain = abs(thermal_rest - 1.0);
        float crack_thresh = mix(0.18, 0.09, harden) * mix(1.0, 0.82, hot);
        float crack_rate = mix(0.25, 2.8, harden) * (1.0 + thermal_strain * 12.0);
        float crack_drive = max(tensile * 1.35 + shear * 0.9 + thermal_strain * (0.40 + harden * 0.35) - crack_thresh, 0.0);
        crack += crack_drive * crack_rate * u_dt;
        crack = clamp(crack, 0.0, 1.0);

        damage[idx] = harden;
        phase_data[idx] = hot_memory;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.46, 0.36);
        if (crack > 0.50) {
            float fail = smoothstep(0.50, 1.0, crack);
            stress *= mix(1.0, 0.22, fail);
        }
    }
    else if (mat_type == MAT_REACTIVE_BURN) {
        float charred = damage[idx];
        float gas = phase_data[idx];
        float crack = Jp_data[idx];
        float batch_heat = max(thermal_params.y, 0.1);
        float batch_cooling = max(thermal_params.z, 0.02);
        float batch_loft = max(thermal_params.w, 0.0);

        float ignition = clamp((temp - 360.0) / 200.0, 0.0, 1.0);
        if (temp > 350.0) {
            charred += mix(0.36, 1.35, shell_seed) * ignition * mix(0.82, 1.18, clamp(batch_cooling, 0.0, 1.2)) * u_dt * (1.0 - charred);
        }
        charred = clamp(charred, 0.0, 1.0);

        float pyro_drive = clamp((temp - 405.0) / 170.0, 0.0, 1.0) * mix(1.55, 0.24, shell_seed);
        gas += pyro_drive * 2.6 * u_dt * (1.0 - gas);
        gas = clamp(gas, 0.0, 1.0);

        if (charred > 0.08 && gas > 0.02) {
            float flare = clamp(gas * (0.45 + charred), 0.0, 1.0);
            temp += (720.0 + 110.0 * batch_heat) * flare * u_dt;
        }
        if (charred > 0.92) {
            temp += (350.0 - temp) * mix(0.14, 0.08, clamp(batch_cooling, 0.0, 1.0)) * u_dt;
        }
        temperatures[p] = clamp(temp, 0.0, 1450.0);

        float sealed = 1.0 - smoothstep(mix(0.24, 0.36, shell_seed), mix(0.68, 0.82, shell_seed), crack);
        float pressure = gas * sealed * mix(1.10, 0.72, charred);
        float E_rb = E * mix(1.08, 0.34, charred) * mix(1.0, 1.55, shell_seed * (1.0 - crack));
        float nu_rb = clamp(mix(nu, 0.34, gas * core_seed), 0.14, 0.40);
        float mu_rb = E_rb / (2.0 * (1.0 + nu_rb));
        float lam_rb = E_rb * nu_rb / ((1.0 + nu_rb) * (1.0 - 2.0 * nu_rb));
        float J_rest = 1.0 + pressure * (0.30 * core_seed + 0.14) + gas * 0.05 - shell_seed * charred * 0.05;

        stress = 2.0 * mu_rb * (F - R) * transpose(F)
               + lam_rb * (J - J_rest) * J * mat2(1.0);
        if (pressure > 0.02) {
            stress += mat2(pressure * mu_rb * (0.10 + 0.18 * core_seed));
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = mix(0.24, 0.05, charred) * mix(1.15, 0.84, shell_seed);
        float crack_drive = max(tensile * 1.12 + shear * 1.30 + pressure * (0.80 + shell_seed * 0.55 + charred * 1.20) - crack_thresh, 0.0);
        if (charred > 0.15) {
            crack += crack_drive * (1.0 + pressure * 20.0) * u_dt;
        }
        crack = clamp(crack, 0.0, 1.0);

        float vent = smoothstep(0.42, 0.96, crack) * smoothstep(0.22, 0.90, pressure);
        if (vent > 0.001) {
            float h0 = hash1(vec2(float(p) * 0.75487766 + charred * 41.3,
                                  float(p) * 1.32471795 + gas * 33.9));
            float angle = h0 * 6.28318;
            vec2 burst_dir = vec2(cos(angle), sin(angle));
            float burst_speed = vent * mix(6.0, 26.0, pressure) * mix(1.0, 0.62, shell_seed);
            vel += burst_dir * burst_speed;
            gas *= max(1.0 - vent * 0.88, 0.0);
            C *= max(1.0 - vent * 0.55, 0.08);
            temp = max(temp, 520.0 + 180.0 * pressure + 100.0 * batch_loft);
        }

        damage[idx] = charred;
        phase_data[idx] = gas;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.88, 0.05);
        if (crack > 0.28) {
            float burst = smoothstep(0.28, 1.0, crack);
            stress *= mix(1.0, 0.05, burst);
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            F = F * (1.0 - burst * 0.14) + F_iso * (burst * 0.14);
        }
    }
    else if (mat_type == MAT_SEALED_CHARGE) {
        float cooked = damage[idx];
        float gas = phase_data[idx];
        float crack = Jp_data[idx];
        float batch_outgas = max(thermal_params.x, 0.02);
        float batch_heat = max(thermal_params.y, 0.1);
        float batch_cooling = max(thermal_params.z, 0.02);
        float batch_loft = max(thermal_params.w, 0.0);

        float ignite_temp = mix(320.0, 368.0, shell_seed);
        float ignite_span = mix(110.0, 185.0, shell_seed);
        float ignite = clamp((temp - ignite_temp) / ignite_span, 0.0, 1.0);
        if (temp > ignite_temp - 10.0) {
            float cook_rate = mix(3.80, 0.48, shell_seed) * mix(0.92, 1.08, clamp(batch_cooling, 0.0, 1.2));
            cooked += cook_rate * ignite * u_dt * (1.0 - cooked);
        }
        cooked = clamp(cooked, 0.0, 1.0);

        if (cooked > 0.02) {
            float flare = clamp((0.32 + gas * 0.92) * cooked, 0.0, 1.0);
            temp += (760.0 + 260.0 * batch_heat) * flare * u_dt;
            float sustain_floor = mix(660.0, 420.0, shell_seed) + 45.0 * min(batch_heat, 1.8) * (0.35 + 0.65 * core_seed);
            temp = max(temp, mix(temp, sustain_floor, flare));
        }
        temperatures[p] = clamp(temp, 0.0, 1500.0);

        float target_gas = clamp((cooked - mix(0.05, 0.42, shell_seed)) / mix(0.12, 0.42, shell_seed), 0.0, 1.0)
                         * mix(2.35, 0.022, shell_seed) * batch_outgas;
        float leak_gate = smoothstep(mix(0.72, 0.84, shell_seed), mix(0.96, 0.995, shell_seed), crack);
        gas += clamp(target_gas - gas, -0.03 * u_dt, (4.0 + 2.0 * core_seed) * u_dt);
        gas *= max(1.0 - leak_gate * mix(0.22, 0.04, shell_seed) * u_dt * (1.0 + batch_loft), 0.0);
        gas = clamp(gas, 0.0, 1.0);

        float sealed = 1.0 - smoothstep(mix(0.50, 0.62, shell_seed), mix(0.92, 0.988, shell_seed), crack);
        float cavity_hold = (1.46 + 1.00 * pseudo_enclosure_hold) * mix(2.30, 0.88, shell_seed);
        float pressure = gas * sealed * cavity_hold;
        float cooked_soften = mix(0.52, 0.96, shell_seed);
        float E_sc = E * mix(1.16, cooked_soften, cooked) * mix(1.0, 3.10, shell_seed * (1.0 - crack));
        float nu_sc = clamp(mix(nu, 0.31, gas * 0.40 * core_seed), 0.12, 0.34);
        float mu_sc = E_sc / (2.0 * (1.0 + nu_sc));
        float lam_sc = E_sc * nu_sc / ((1.0 + nu_sc) * (1.0 - 2.0 * nu_sc));
        float J_rest = 1.0 + pressure * (0.05 + 0.05 * core_seed) + gas * 0.008 - shell_seed * cooked * 0.03;

        stress = 2.0 * mu_sc * (F - R) * transpose(F)
               + lam_sc * (J - J_rest) * J * mat2(1.0);
        if (pressure > 0.01) {
            stress += mat2(pressure * mu_sc * mix(0.12, 0.38, core_seed));
        }

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_thresh = mix(0.04, 0.34, shell_seed) * mix(0.98, 1.20, 1.0 - cooked * 0.28);
        float crack_drive = max(tensile * 1.16 + shear * 1.42 + pressure * (1.62 + 0.82 * core_seed + cooked * 2.30) - crack_thresh, 0.0);
        if (cooked > 0.08) {
            crack += crack_drive * (0.98 + pressure * 30.0) * u_dt;
        }
        if (leak_gate > 0.0) {
            crack += leak_gate * (0.10 + pressure * 0.24) * u_dt;
        }
        crack = clamp(crack, 0.0, 1.0);

        float vent = smoothstep(0.58, 0.90, crack) * smoothstep(0.18, 0.78, pressure);
        if (vent > 0.001) {
            float h0 = hash1(vec2(float(p) * 0.931f + cooked * 37.0,
                                  float(idx) * 1.618f + gas * 29.0));
            float angle = h0 * 6.28318;
            vec2 burst_dir = vec2(cos(angle), sin(angle));
            float shell_frag = smoothstep(0.52, 1.0, shell_seed);
            float burst_speed = vent * mix(28.0, 84.0, clamp(pressure * 0.60, 0.0, 1.0)) * mix(1.24, 0.66, shell_frag);
            vel += burst_dir * burst_speed;
            gas *= max(1.0 - vent * mix(1.05, 0.72, shell_frag), 0.0);
            C *= max(1.0 - vent * 0.88, 0.02);
            temp = max(temp, 760.0 + 260.0 * pressure + 120.0 * batch_loft);
            crack = clamp(crack + vent * (0.10 + 0.42 * shell_frag + pressure * 0.28), 0.0, 1.0);
        }

        damage[idx] = cooked;
        phase_data[idx] = gas;
        Jp_data[idx] = crack;
        temperatures[p] = clamp(temp, 0.0, 1500.0);

        stress *= max(1.0 - crack * mix(0.98, 0.90, shell_seed), 0.02);
        if (crack > 0.34) {
            float burst = smoothstep(0.34, 1.0, crack);
            stress *= mix(1.0, mix(0.04, 0.10, shell_seed), burst);
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            float relax = mix(0.18, 0.08, shell_seed);
            F = F * (1.0 - burst * relax) + F_iso * (burst * relax);
        }
    }
    else if (mat_type == MAT_COMPOSITE) {
        // Composite: aniso fibers + hardening + directional fracture
        // Breaks along grain into petal/splinter shapes
        float cured = damage[idx];
        float crack = Jp_data[idx];

        // Cure when hot
        if (temp > 400.0) {
            float prev = cured;
            cured += 0.6 * u_dt * clamp((temp - 400.0) / 200.0, 0.0, 1.0);
            cured = clamp(cured, 0.0, 1.0);
            float dcure = cured - prev;
            if (dcure > 0.0) {
                float anneal = dcure * 0.15;
                F = F * (1.0 - anneal) + R * anneal;
                svd = svd2x2(F);
                R = svd.U * transpose(svd.V);
                J = svd.sigma.x * svd.sigma.y;
            }
        }
        damage[idx] = cured;

        float fire_brittle = clamp((temp - 470.0) / 240.0, 0.0, 1.0);
        float E_comp = E * (1.0 + cured * 4.0) * mix(1.0, 1.18, fire_brittle);
        float mu_comp = E_comp / (2.0 * (1.0 + nu));
        float lam_comp = E_comp * nu / ((1.0 + nu) * (1.0 - 2.0 * nu));
        float J_rest = 1.0 + cured * 0.02 - fire_brittle * 0.03;

        // Base elastic stress
        stress = 2.0 * mu_comp * (F - R) * transpose(F)
               + lam_comp * (J - J_rest) * J * mat2(1.0);

        // Fiber reinforcement
        vec2 fiber = fiber_dirs[idx];
        vec2 df = F * fiber;
        float fs = length(df);
        if (fs > 1e-6) {
            vec2 fh = df / fs;
            float fi = clamp(fs - 1.0, -0.5, 0.5);
            stress += fiber_strength * mu_comp * fi * mat2(
                fh.x*fh.x, fh.x*fh.y, fh.y*fh.x, fh.y*fh.y);
        }

        // DIRECTIONAL fracture: strain perpendicular to fiber causes cracks
        // but strain along fiber doesn't (fiber holds it together)
        vec2 perp = vec2(-fiber.y, fiber.x);
        vec2 F_perp = F * perp;
        float perp_strain = abs(length(F_perp) - 1.0);
        float along_strain = abs(fs - 1.0);
        // Cracks form perpendicular to fiber (along grain)
        float directional_strain = max(perp_strain - along_strain * 0.3, 0.0);

        float spontaneous_drive = max(fire_brittle * cured - 0.42, 0.0) * (0.10 + fiber_strength * 0.02);
        if (cured > 0.45 && directional_strain + spontaneous_drive > 0.12) {
            crack += max(directional_strain + spontaneous_drive - 0.12, 0.0) * (1.8 + fire_brittle * 2.0) * max(cured, 0.35) * u_dt;
        }
        crack = clamp(crack, 0.0, 1.0);
        Jp_data[idx] = crack;

        // Cracked: weaken cross-grain bonds but keep along-grain strength
        if (crack > 0.3) {
            float weak = (crack - 0.3) / 0.7; // 0→1 over crack 0.3→1.0
            // Reduce isotropic stress but keep fiber stress
            float iso_factor = max(1.0 - weak * 0.7, 0.3);
            // Recompute: keep fiber contribution at full, weaken matrix
            mat2 iso_stress = 2.0 * mu_comp * iso_factor * (F - R) * transpose(F)
                            + lam_comp * iso_factor * (J - 1.0) * J * mat2(1.0);
            // Fiber still holds at reduced strength
            mat2 fiber_stress = mat2(0.0);
            if (fs > 1e-6) {
                vec2 fh2 = df / fs;
                float fi2 = clamp(fs - 1.0, -0.3, 0.3);
                fiber_stress = fiber_strength * mu_comp * (1.0 - weak * 0.3) * fi2 * mat2(
                    fh2.x*fh2.x, fh2.x*fh2.y, fh2.y*fh2.x, fh2.y*fh2.y);
            }
            stress = iso_stress + fiber_stress;
        }
    }
    else if (mat_type == MAT_MUSHROOM) {
        float wilt = damage[idx];
        float spores = phase_data[idx];
        float crack = Jp_data[idx];

        float heat = smoothstep(330.0, 560.0, temp);
        if (temp > 330.0) {
            wilt += mix(0.08, 0.42, shell_seed) * heat * u_dt * (1.0 - wilt);
        }
        wilt = clamp(wilt, 0.0, 1.0);

        float spore_drive = smoothstep(360.0, 520.0, temp) * mix(0.22, 0.95, core_seed) * (1.0 - wilt * 0.35);
        spores += spore_drive * u_dt * (1.0 - spores);
        spores = clamp(spores, 0.0, 1.0);

        float E_mu = E * mix(1.0, 0.38, heat) * mix(1.0, 0.76, wilt) * mix(1.0, 0.58, spores);
        float nu_mu = clamp(mix(0.24, 0.36, heat), 0.16, 0.42);
        float mu_mu = E_mu / (2.0 * (1.0 + nu_mu));
        float lam_mu = E_mu * nu_mu / ((1.0 + nu_mu) * (1.0 - 2.0 * nu_mu));
        float J_rest = 1.0 + spores * (0.10 * core_seed + 0.03) - wilt * (0.05 * shell_seed + 0.02);

        stress = 2.0 * mu_mu * (F - R) * transpose(F)
               + lam_mu * (J - J_rest) * J * mat2(1.0);
        stress += mu_mu * spores * 0.10 * (C + transpose(C));

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_drive = max(spores * 0.32 + tensile * 0.55 + shear * 0.42 - (0.45 - wilt * 0.14), 0.0);
        crack += crack_drive * mix(0.18, 1.05, wilt) * u_dt;
        crack = clamp(crack, 0.0, 1.0);
        if (crack > 0.72) {
            spores *= max(1.0 - 1.2 * u_dt, 0.0);
        }

        damage[idx] = wilt;
        phase_data[idx] = spores;
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.42, 0.30);
    }
    else if (mat_type == MAT_FOAM) {
        float pore = damage[idx];
        float soft = phase_data[idx];
        float crack = Jp_data[idx];

        float target_soft = smoothstep(430.0, 620.0, temp);
        soft += clamp(target_soft - soft, -2.5 * u_dt, 2.5 * u_dt);
        soft = clamp(soft, 0.0, 1.0);
        phase_data[idx] = soft;

        if (temp > 520.0) {
            pore += 0.8 * u_dt * clamp((temp - 520.0) / 260.0, 0.0, 1.0) * (1.0 - pore);
        }
        pore = clamp(pore, 0.0, 1.0);
        damage[idx] = pore;

        float E_f = E * 2.4 * mix(1.0, 0.18, soft) * mix(1.0, 0.35, pore);
        float nu_f = mix(0.22, 0.38, soft);
        float mu_f = E_f / (2.0 * (1.0 + nu_f));
        float lam_f = E_f * nu_f / ((1.0 + nu_f) * (1.0 - 2.0 * nu_f));
        float J_rest = 1.0 + pore * 0.24;

        stress = 2.0 * mu_f * (F - R) * transpose(F)
               + lam_f * (J - J_rest) * J * mat2(1.0);

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float crack_drive = max(tensile + shear * 0.8 + pore * 0.2 - 0.11, 0.0);
        if (pore > 0.25) {
            crack += crack_drive * 2.0 * u_dt;
        }
        crack = clamp(crack, 0.0, 1.0);
        Jp_data[idx] = crack;

        stress *= max(1.0 - crack * 0.55, 0.25);
        if (soft > 0.5) {
            float relax = smoothstep(0.5, 1.0, soft) * 0.06;
            F = F * (1.0 - relax) + R * relax;
        }
    }
    else if (mat_type == MAT_TOPO_GOO) {
        float split = damage[idx];
        float heal = phase_data[idx];
        float pore = Jp_data[idx];

        float strain_mag = length(svd.sigma - vec2(1.0));
        float shear_rate = length(vec4(C[0], C[1]));
        float stress_drive = clamp(shear_rate * 0.34 + strain_mag * 5.2 + length(vel) * 0.10, 0.0, 4.0);
        float calm = 1.0 - smoothstep(0.50, 1.80, stress_drive);

        heal += calm * 1.05 * u_dt * (1.0 - heal);
        split += max(stress_drive - mix(0.58, 1.05, heal), 0.0) * mix(0.16, 0.54, 1.0 - heal) * u_dt;
        split -= calm * heal * 0.60 * u_dt;
        split = clamp(split, 0.0, 1.0);

        pore += max(split - 0.48, 0.0) * mix(0.08, 0.28, clamp(stress_drive * 0.35, 0.0, 1.0)) * u_dt;
        pore -= calm * heal * 0.42 * u_dt;
        pore = clamp(pore, 0.0, 1.0);
        heal = clamp(heal - pore * 0.08 * u_dt, 0.0, 1.0);

        float merge = clamp(heal * (1.0 - split * 0.55), 0.0, 1.0);
        float pseudo_hold = 1.0 + 0.34 * pseudo_depth + 0.24 * pseudo_enclosure;
        float bulk = max(E * mix(0.42, 0.18, split), 780.0) * mix(1.00, 2.10, merge) * pseudo_hold;
        float mu_visc = mix(140.0, 44.0, split) * mix(1.24, 0.92, calm);
        float mu_gel = max(E * mix(0.16, 0.24, merge) * mix(1.0, 0.60, split) * (0.94 + 0.42 * pseudo_depth), 420.0);
        float J_rest = 1.0 + 0.02 * pseudo_depth + 0.02 * pseudo_enclosure + pore * 0.06 - merge * 0.05 - split * 0.02;

        mat2 F_iso = mat2(sqrt(max(J, 0.01)));
        float fluid_relax = clamp(0.028 + 0.040 * (1.0 - calm) + 0.035 * split - 0.020 * merge, 0.01, 0.09);
        F = F * (1.0 - fluid_relax) + F_iso * fluid_relax;
        J = determinant(F);

        stress = mat2(bulk * J * (J - J_rest))
               + mu_visc * (C + transpose(C))
               + 2.0 * mu_gel * (F - R) * transpose(F);

        float cohesion = mix(1.0, 0.36, split) * mix(0.90, 1.18, merge);
        stress *= max(cohesion, 0.22);
        if (split > 0.54) {
            float relax = smoothstep(0.54, 1.0, split) * 0.05;
            F = F * (1.0 - relax) + F_iso * relax;
            C *= (1.0 - relax * 0.30);
        }

        damage[idx] = split;
        phase_data[idx] = heal;
        Jp_data[idx] = pore;
    }
    else if (mat_type == MAT_OOBLECK) {
        float jam = damage[idx];
        float yielded = phase_data[idx];
        float compaction = Jp_data[idx];

        float strain_mag = length(svd.sigma - vec2(1.0));
        float shear_rate = length(vec4(C[0], C[1]));
        float impact = shear_rate * 0.48 + strain_mag * 7.6 + length(vel) * 0.22;
        float jam_target = smoothstep(0.18, 0.95, impact);
        jam += clamp(jam_target - jam, -0.10 * u_dt, 10.0 * u_dt);
        jam = clamp(jam, 0.0, 1.0);

        float calm = 1.0 - smoothstep(0.28, 1.20, impact);
        yielded += max(strain_mag * 1.5 - 0.06, 0.0) * 1.2 * u_dt * (1.0 - jam * 0.55);
        yielded -= calm * 0.20 * u_dt;
        yielded = clamp(yielded, 0.0, 1.0);

        compaction += max(1.0 - J, 0.0) * (0.9 + 1.4 * jam) * u_dt;
        compaction -= calm * 0.14 * u_dt;
        compaction = clamp(compaction, 0.0, 1.0);

        float E_o = E * mix(0.08, 28.0, jam) * mix(1.0, 0.60, yielded);
        float nu_o = mix(0.43, 0.20, jam);
        float mu_o = E_o / (2.0 * (1.0 + nu_o));
        float lam_o = E_o * nu_o / ((1.0 + nu_o) * (1.0 - 2.0 * nu_o));
        float J_rest = 1.0 - yielded * 0.02 + compaction * 0.06;
        float mu_visc = mix(10.0, 520.0, jam);

        stress = 2.0 * mu_o * (F - R) * transpose(F)
               + lam_o * (J - J_rest) * J * mat2(1.0)
               + mu_visc * (C + transpose(C));
        stress *= max(1.0 - yielded * 0.20, 0.58);

        if (jam < 0.20) {
            float relax = (0.03 + yielded * 0.01) * u_dt;
            mat2 F_iso = mat2(sqrt(max(J, 0.01)));
            F = F * (1.0 - relax) + F_iso * relax;
        }

        damage[idx] = jam;
        phase_data[idx] = yielded;
        Jp_data[idx] = compaction;
    }
    else if (mat_type == MAT_IMPACT_GEL) {
        float hard = damage[idx];
        float memory = phase_data[idx];
        float bruise = Jp_data[idx];

        float strain_mag = length(svd.sigma - vec2(1.0));
        float shear_rate = length(vec4(C[0], C[1]));
        float impact = clamp(shear_rate * 0.34 + strain_mag * 6.4 + length(vel) * 0.22, 0.0, 5.0);
        float hit = smoothstep(0.55, 1.80, impact);

        hard += hit * 3.40 * u_dt * (1.0 - hard);
        hard -= (1.0 - hit) * 0.04 * u_dt;
        hard = clamp(hard, 0.0, 1.0);

        memory += hit * 1.85 * u_dt * (1.0 - memory);
        memory -= 0.015 * u_dt * (1.0 - hit);
        memory = clamp(memory, 0.0, 1.0);

        bruise += max(strain_mag * 1.8 + hit * 0.60 - 0.20, 0.0) * 0.70 * u_dt;
        bruise -= 0.06 * u_dt;
        bruise = clamp(bruise, 0.0, 1.0);

        float E_i = E * mix(0.85, 14.0, hard) * mix(1.0, 1.70, memory);
        float nu_i = mix(0.38, 0.23, hard);
        float mu_i = E_i / (2.0 * (1.0 + nu_i));
        float lam_i = E_i * nu_i / ((1.0 + nu_i) * (1.0 - 2.0 * nu_i));

        stress = 2.0 * mu_i * (F - R) * transpose(F)
               + lam_i * (J - 1.0) * J * mat2(1.0)
               + (28.0 + 40.0 * hard + 18.0 * memory) * (C + transpose(C));
        stress *= max(1.0 - bruise * 0.18, 0.68);

        float relax = mix(0.05, 0.004, memory) * (1.0 - hard * 0.45) * u_dt;
        F = F * (1.0 - relax) + R * relax;

        damage[idx] = hard;
        phase_data[idx] = memory;
        Jp_data[idx] = bruise;
    }
    else if (mat_type == MAT_MORPH_TISSUE) {
        float growth = damage[idx];
        float fold = phase_data[idx];
        float scar = Jp_data[idx];

        float heat = smoothstep(318.0, 520.0, temp);
        float active_growth = clamp(growth * (0.55 + 0.45 * heat), 0.0, 1.0);
        float shell_mismatch = shell_seed * fold * (0.06 + 0.04 * heat);
        float core_swelling = core_seed * active_growth * (0.10 + 0.06 * pseudo_depth);
        float soft_scaffold = 1.0 + 0.18 * pseudo_depth + 0.14 * pseudo_shell + 0.10 * pseudo_enclosure;

        float E_mt = E * mix(0.82, 1.90, fold) * mix(1.0, 0.88, active_growth * 0.35) * soft_scaffold;
        float nu_mt = clamp(mix(0.39, 0.27, fold), 0.18, 0.44);
        float mu_mt = E_mt / (2.0 * (1.0 + nu_mt));
        float lam_mt = E_mt * nu_mt / ((1.0 + nu_mt) * (1.0 - 2.0 * nu_mt));

        vec2 fiber = fiber_dirs[idx];
        if (length(fiber) < 0.12) fiber = vec2(1.0, 0.0);
        fiber = normalize(fiber);
        vec2 flow_dir = (length(vel) > 0.04) ? normalize(vel) : fiber;
        fiber = normalize(mix(fiber, flow_dir, clamp(active_growth * 0.12 + fold * 0.04, 0.0, 0.28)));
        fiber_dirs[idx] = fiber;
        float frontier_lift = active_growth * (0.14 + 0.18 * core_seed) + fold * (0.05 + 0.03 * shell_seed);
        float frontier_spread = active_growth * (0.03 + 0.05 * core_seed) - shell_mismatch * 0.55;
        mat2 growth_target = oriented_growth_target(fiber, frontier_lift, frontier_spread);
        float growth_relax = clamp((0.16 * active_growth + 0.08 * fold) * u_dt, 0.0, 0.12);
        F = F * (1.0 - growth_relax) + growth_target * growth_relax;
        svd = svd2x2(F);
        R = svd.U * transpose(svd.V);
        J = svd.sigma.x * svd.sigma.y;

        vec2 perp = vec2(-fiber.y, fiber.x);
        vec2 df = F * fiber;
        float fs = max(length(df), 1e-6);
        vec2 fh = df / fs;
        vec2 dp = F * perp;
        float ps = max(length(dp), 1e-6);
        vec2 ph = dp / ps;

        float along_target = 1.0 + active_growth * (0.18 + 0.20 * core_seed) + fold * (0.04 + 0.04 * shell_seed);
        float across_target = 1.0 + active_growth * (0.04 + 0.06 * core_seed) - shell_mismatch * 1.25;
        float J_rest = 1.0 + core_swelling * 1.80 + active_growth * 0.04 - shell_seed * fold * 0.034 - scar * 0.03;

        stress = 2.0 * mu_mt * (F - R) * transpose(F)
               + lam_mt * (J - J_rest) * J * mat2(1.0);
        stress += fiber_strength * mu_mt * clamp(fs - along_target, -0.18, 0.44) * outer2(fh, fh);
        stress += 0.76 * mu_mt * clamp(ps - across_target, -0.28, 0.26) * outer2(ph, ph);
        stress += mu_mt * (0.04 + 0.14 * fold + 0.08 * active_growth) * (C + transpose(C));

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float scar_drive = max(tensile * 0.56 + shear * 0.38 + abs(along_target - across_target) * 0.42
                             - (0.64 - 0.18 * fold), 0.0);
        scar += scar_drive * (0.12 + 0.62 * active_growth) * u_dt;
        scar -= 0.08 * u_dt;
        scar = clamp(scar, 0.0, 1.0);

        if (active_growth > 0.35) {
            float hold = clamp((0.08 * active_growth + 0.05 * fold) * u_dt, 0.0, 0.08);
            F = F * (1.0 - hold) + growth_target * hold;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
        }

        damage[idx] = growth;
        phase_data[idx] = fold;
        Jp_data[idx] = scar;
        stress *= max(1.0 - scar * 0.28, 0.38);
    }
    else if (mat_type == MAT_ROOT_WEAVE) {
        float colonize = damage[idx];
        float lignify = phase_data[idx];
        float branch = Jp_data[idx];

        float heat = smoothstep(308.0, 480.0, temp);
        float scaffold = 1.0 + 0.16 * pseudo_depth + 0.12 * pseudo_shell + 0.10 * pseudo_cohesion;
        vec2 fiber = fiber_dirs[idx];
        if (length(fiber) < 0.12) fiber = vec2(0.0, 1.0);
        fiber = normalize(fiber);
        vec2 flow_dir = (length(vel) > 0.04) ? normalize(vel) : fiber;
        fiber = normalize(mix(fiber, flow_dir, clamp(colonize * 0.10 + heat * 0.04, 0.0, 0.28)));
        fiber_dirs[idx] = fiber;
        float along_growth = colonize * (0.18 + 0.16 * core_seed) * (1.0 - 0.50 * lignify);
        float across_shrink = colonize * (0.06 + 0.08 * shell_seed) * (0.40 + 0.60 * lignify);
        mat2 growth_target = oriented_growth_target(fiber, along_growth, -across_shrink * 0.85);
        float growth_relax = clamp((0.18 * colonize + 0.04 * heat) * u_dt, 0.0, 0.12);
        F = F * (1.0 - growth_relax) + growth_target * growth_relax;
        svd = svd2x2(F);
        R = svd.U * transpose(svd.V);
        J = svd.sigma.x * svd.sigma.y;

        vec2 perp = vec2(-fiber.y, fiber.x);
        vec2 df = F * fiber;
        float fs = max(length(df), 1e-6);
        vec2 fh = df / fs;
        vec2 dp = F * perp;
        float ps = max(length(dp), 1e-6);
        vec2 ph = dp / ps;

        float E_rw = E * mix(0.76, 2.90, lignify) * scaffold;
        float nu_rw = clamp(mix(0.34, 0.22, lignify), 0.14, 0.38);
        float mu_rw = E_rw / (2.0 * (1.0 + nu_rw));
        float lam_rw = E_rw * nu_rw / ((1.0 + nu_rw) * (1.0 - 2.0 * nu_rw));
        float J_rest = 1.0 + along_growth * 0.70 - across_shrink * 0.24 - branch * 0.02 + pseudo_depth * 0.016;

        stress = 2.0 * mu_rw * (F - R) * transpose(F)
               + lam_rw * (J - J_rest) * J * mat2(1.0);
        stress += fiber_strength * mu_rw * clamp(fs - (1.0 + along_growth), -0.16, 0.46) * outer2(fh, fh);
        stress += 0.90 * mu_rw * clamp(ps - (1.0 - across_shrink), -0.32, 0.20) * outer2(ph, ph);
        stress += mu_rw * (0.03 + 0.08 * colonize) * (C + transpose(C));

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float across = max(ps - 1.0, 0.0);
        float branch_drive = max(across * 0.70 + shear * 0.34 + tensile * 0.28 + branch * 0.18
                               - (0.86 + lignify * 0.16), 0.0);
        branch += branch_drive * (0.08 + 0.48 * colonize) * u_dt;
        branch -= 0.03 * u_dt;
        branch = clamp(branch, 0.0, 1.0);

        if (colonize > 0.20) {
            float hold = clamp((0.10 * colonize + 0.04 * lignify) * u_dt, 0.0, 0.09);
            F = F * (1.0 - hold) + growth_target * hold;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
        }

        damage[idx] = colonize;
        phase_data[idx] = lignify;
        Jp_data[idx] = branch;
        stress *= max(1.0 - branch * 0.22, 0.44);
    }
    else if (mat_type == MAT_CELL_SHEET) {
        float bud = damage[idx];
        float seal = phase_data[idx];
        float frill = Jp_data[idx];

        float heat = smoothstep(314.0, 470.0, temp);
        float edge_growth = shell_seed * bud * (0.12 + 0.08 * heat);
        float inner_hold = core_seed * seal * 0.05;
        float membrane = 1.0 + 0.20 * pseudo_shell + 0.10 * pseudo_depth;
        vec2 fiber = fiber_dirs[idx];
        if (length(fiber) < 0.12) fiber = vec2(1.0, 0.0);
        fiber = normalize(fiber);
        vec2 flow_dir = (length(vel) > 0.04) ? normalize(vel) : fiber;
        fiber = normalize(mix(fiber, flow_dir, clamp(bud * 0.10 + frill * 0.06 + shell_seed * 0.04, 0.0, 0.24)));
        fiber_dirs[idx] = fiber;
        float sheet_lobe = bud * (0.10 + 0.14 * shell_seed + 0.05 * heat);
        float sheet_spread = bud * (0.06 + 0.08 * core_seed) - inner_hold * 0.30;
        mat2 growth_target = oriented_growth_target(fiber, sheet_lobe, sheet_spread);
        float growth_relax = clamp((0.14 * bud + 0.06 * shell_seed + 0.03 * frill) * u_dt, 0.0, 0.10);
        F = F * (1.0 - growth_relax) + growth_target * growth_relax;
        svd = svd2x2(F);
        R = svd.U * transpose(svd.V);
        J = svd.sigma.x * svd.sigma.y;

        float E_cs = E * mix(0.84, 1.95, seal) * mix(1.0, 0.78, bud * shell_seed * 0.40) * membrane;
        float nu_cs = clamp(mix(0.42, 0.27, seal), 0.18, 0.46);
        float mu_cs = E_cs / (2.0 * (1.0 + nu_cs));
        float lam_cs = E_cs * nu_cs / ((1.0 + nu_cs) * (1.0 - 2.0 * nu_cs));
        float J_rest = 1.0 + edge_growth * 1.55 + bud * core_seed * 0.04 - inner_hold * 1.25 - frill * 0.03;

        stress = 2.0 * mu_cs * (F - R) * transpose(F)
               + lam_cs * (J - J_rest) * J * mat2(1.0);
        stress += shell_seed * mu_cs * (0.10 + 0.26 * bud + 0.10 * frill) * (C + transpose(C));

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float frill_drive = max(edge_growth * 0.52 + tensile * 0.36 + shear * 0.28 - (0.30 + 0.24 * seal), 0.0);
        frill += frill_drive * (0.16 + 0.44 * bud) * u_dt;
        frill -= 0.04 * u_dt;
        frill = clamp(frill, 0.0, 1.0);

        if (frill > 0.42) {
            float hold = clamp(smoothstep(0.42, 1.0, frill) * shell_seed * 0.040 * u_dt, 0.0, 0.06);
            F = F * (1.0 - hold) + growth_target * hold;
            svd = svd2x2(F);
            R = svd.U * transpose(svd.V);
            J = svd.sigma.x * svd.sigma.y;
        }

        damage[idx] = bud;
        phase_data[idx] = seal;
        Jp_data[idx] = frill;
        stress *= mix(1.0, 0.56, smoothstep(0.45, 1.0, frill) * shell_seed);
    }
    else if (mat_type == MAT_ASH_REGROWTH) {
        float regrow = damage[idx];
        float ash = phase_data[idx];
        float crumble = Jp_data[idx];

        float regrow_rate_raw = clamp(u_bio_regrowth_rate, 0.0, 16.0);
        float regrow_rate = regrow_rate_raw;
        if (regrow_rate_raw > 1.0) {
            float hi = regrow_rate_raw - 1.0;
            regrow_rate = 1.0 + hi * (0.90 + 0.20 * sqrt(hi));
        }
        float ash_soft = smoothstep(0.08, 0.92, ash);
        float live = clamp(regrow * (0.35 + 0.65 * regrow_rate), 0.0, 1.0);
        float rigid_ash = ash_soft * (1.0 - live);
        float recovery = smoothstep(0.28, 0.86, live) * ash_soft;
        float scaffold = 1.0 + 0.22 * pseudo_depth + 0.14 * pseudo_shell + 0.12 * pseudo_cohesion;

        vec2 fiber = fiber_dirs[idx];
        if (length(fiber) < 0.12) fiber = vec2(0.0, 1.0);
        fiber = normalize(fiber);
        vec2 flow_dir = (length(vel) > 0.04) ? normalize(vel) : fiber;
        fiber = normalize(mix(fiber, flow_dir, clamp(live * 0.06 + rigid_ash * 0.02, 0.0, 0.14)));
        fiber_dirs[idx] = fiber;

        float ash_collapse = rigid_ash * (0.02 + 0.04 * shell_seed);
        float overgrow = recovery * (0.08 + 0.24 * shell_seed) * (0.72 + 0.28 * pseudo_shell) *
                         (0.72 + 0.04 * min(regrow_rate, 10.0));
        float regrow_lift = live * ash_soft * (0.10 + 0.16 * core_seed) + overgrow * (0.10 + 0.08 * core_seed);
        float regrow_spread = live * ash_soft * (0.05 + 0.08 * shell_seed) +
                              overgrow * (0.10 + 0.18 * shell_seed) -
                              ash_collapse * 0.16;
        mat2 growth_target = oriented_growth_target(fiber, regrow_lift, regrow_spread);
        float growth_relax = clamp((0.072 * live * ash_soft * regrow_rate +
                                    0.050 * overgrow * regrow_rate +
                                    0.012 * shell_seed) * u_dt, 0.0, 0.14);
        F = F * (1.0 - growth_relax) + growth_target * growth_relax;
        svd = svd2x2(F);
        R = svd.U * transpose(svd.V);
        J = svd.sigma.x * svd.sigma.y;

        // Ash is brittle but still hard — it should hold shape until actually struck.
        // The original 2.85x over-reinforced ash; the 0.35x over-swung and let ash
        // slump under its own weight. 0.85x keeps ash almost as stiff as living
        // tissue so it stays up, while brittleness comes from the fracture-drive
        // coefficients below (they amplify impact stress heavily at full ash).
        float E_ar = E * mix(1.10, 0.85, rigid_ash) * mix(1.0, 1.35, live) * scaffold;
        float nu_ar = clamp(mix(0.12, 0.24, live), 0.06, 0.28);
        float mu_ar = E_ar / (2.0 * (1.0 + nu_ar));
        float lam_ar = E_ar * nu_ar / ((1.0 + nu_ar) * (1.0 - 2.0 * nu_ar));
        float J_rest = 1.0 + regrow_lift * 0.80 + overgrow * 0.26 - ash_collapse * 0.16 - crumble * 0.03;

        stress = 2.0 * mu_ar * (F - R) * transpose(F)
               + lam_ar * (J - J_rest) * J * mat2(1.0);
        stress += mu_ar * (0.03 + 0.04 * live) * (1.0 - 0.25 * rigid_ash) * (C + transpose(C));

        float tensile = max(max(svd.sigma.x, svd.sigma.y) - 1.0, 0.0);
        float shear = abs(svd.sigma.x - svd.sigma.y);
        float impact_drive = clamp(length(vec4(C[0], C[1])) * 0.030, 0.0, 1.6);
        // Brittle-but-hard fracture: impact stress dominates at full ash (×1.40),
        // while quasistatic tensile/shear contributions are modest so ash doesn't
        // self-crumble under its own weight. Threshold stays generous so it takes
        // a real strike to cross into fracture.
        float crumble_drive = max(tensile * (0.20 + 1.00 * rigid_ash) +
                                  shear * (0.16 + 0.80 * rigid_ash) +
                                  impact_drive * (0.12 + 1.40 * rigid_ash) -
                                  (0.86 - 0.38 * rigid_ash + 0.10 * live), 0.0);
        // Accumulation rate tamed so ash doesn't ratchet toward collapse from tiny
        // background stresses. When a real impact hits, crumble_drive spikes and
        // this term still builds crumble fast.
        crumble += crumble_drive * (0.10 + 0.60 * rigid_ash) * u_dt;
        crumble -= live * 0.08 * regrow_rate * u_dt;
        crumble = clamp(crumble, 0.0, 1.0);

        // Advance regrow / ash. Two hard lessons from the previous tuning:
        // 1. The burn threshold was too low (420K), so any heat that diffused to a
        //    neighbor — even after the heat source was off — kept killing live tissue.
        //    Ash propagated outward instead of healing inward. Raise the threshold to
        //    540K and narrow the kill band so only directly-cooked cells turn to ash.
        // 2. Heal was slower than burn, so even in the neutral band healing lost
        //    ground to stale burn. Speed healing up and slow burning down.
        // 3. Give the "neutral" band 360-540K width so diffused residual heat just
        //    sits there without killing or healing — this is crucial for the recovery
        //    phase right after the heat source is released.
        float heal_drive = clamp((360.0 - temp) / 100.0, 0.0, 1.0);
        float burn_drive = clamp((temp - 540.0) / 260.0, 0.0, 1.0);
        regrow += heal_drive * 0.75 * regrow_rate * (1.0 - regrow) * u_dt;
        regrow -= burn_drive * 0.28 * regrow * u_dt;
        // Only real fracture events should knock regrow back, not background sag.
        float fracture_event = smoothstep(0.15, 0.55, crumble_drive);
        regrow -= fracture_event * 0.35 * u_dt;
        regrow = clamp(regrow, 0.0, 1.0);

        ash += burn_drive * 0.42 * (1.0 - ash) * u_dt;
        // Recovery pulls ash back down. Faster than before so the "black spreading"
        // failure mode resolves cleanly once the cells cool back into the heal band.
        ash -= recovery * 0.55 * regrow_rate * ash * u_dt;
        ash = clamp(ash, 0.0, 1.0);

        damage[idx] = regrow;
        phase_data[idx] = ash;
        Jp_data[idx] = crumble;

        stress *= max(1.0 - crumble * 0.82, 0.12);
        if (crumble > 0.22) {
            float dust = smoothstep(0.22, 1.0, crumble);
            stress *= mix(1.0, 0.18, dust);
        }
    }
    else {
        // ELASTIC + THERMAL fallback
        stress = 2.0 * mu * (F - R) * transpose(F)
               + lambda * (J - 1.0) * J * mat2(1.0);
    }

    // Stress clamp — prevents MPM blow-up from constitutive failure modes.
    // Fluid materials with a proper EOS (Tait etc.) can legitimately
    // produce pressures well above their nominal E, so they need a
    // more generous ceiling than solids. The old E*0.8 clamp was
    // nuking all meaningful fluid pressure response.
    float sn = length(vec4(stress[0], stress[1]));
    float ms;
    if (mat_type == MAT_FERRO_FLUID || mat_type == MAT_HEAVY_FERRO_FLUID ||
        mat_type == MAT_DIAMAGNETIC_FLUID || mat_type == MAT_PARA_MIST ||
        mat_type == MAT_STICKY_FERRO ||
        mat_type == MAT_FLUID || mat_type == MAT_FLAMMABLE_FLUID) {
        // Fluid EOS ceiling: 40x E. For ferrofluid E=4200 → 168000 Pa,
        // comfortably above the max Tait pressure at the J_safe floor
        // of 0.7 (which is ~108000 Pa at c0=6). Tighter than the
        // previous E*200, which allowed the integrator to generate
        // pressures that exceeded the CFL-safe propagation speed.
        ms = E * 40.0;
    } else {
        ms = E * 0.8;
    }
    if (sn > ms) stress *= ms / sn;

    deform_grads[idx] = mat2_to_vec4(F);

    mat2 affine = (-u_dt * u_p_vol * 4.0 * inv_dx * inv_dx) * stress + mass * C;

    // --- Scatter to grid ---
    for (int gy = 0; gy < 3; gy++) {
        for (int gx = 0; gx < 3; gx++) {
            ivec2 node = base + ivec2(gx, gy);
            if (node.x < 0 || node.y < 0 || node.x >= u_grid_res.x || node.y >= u_grid_res.y)
                continue;
            float weight = wx[gx] * wy[gy];
            vec2 dpos = (vec2(node) - cell_pos) * u_dx;
            vec2 momentum = weight * (mass * vel + affine * dpos);
            float m = weight * mass;
            uint cell = uint(node.y * u_grid_res.x + node.x);
            atomicAdd(grid_mass[cell], int(m * FIXED_SCALE));
            atomicAdd(grid_mom_x[cell], int(momentum.x * FIXED_SCALE));
            atomicAdd(grid_mom_y[cell], int(momentum.y * FIXED_SCALE));
            atomicAdd(grid_temp_ato[cell], int(m * temp * FIXED_SCALE * 0.001));
        }
    }
}
