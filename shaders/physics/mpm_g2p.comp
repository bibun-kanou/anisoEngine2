        // Velocity
        color = vec4(viridis(speed * 0.3), 1.0);
    } else if (u_vis_mode == 2) {
        // Stress proxy: ||F - R|| via SVD
        color = vec4(viridis(dev_vis * 5.0), 1.0);
    } else if (u_vis_mode == 3) {
        // Deformation norm ||F||
        float fn = length(deform_grads[idx]);
        color = vec4(viridis((fn - 1.41) * 3.0), 1.0);
    } else if (u_vis_mode == 4) {
        // Damage
