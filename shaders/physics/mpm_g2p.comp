#version 450 core

// MLS-MPM G2P: gather velocity, advect, thermal, visualization

layout(local_size_x = 256) in;

layout(std430, binding = 0) buffer PositionBuffer  { vec2  positions[];    };
layout(std430, binding = 1) buffer VelocityBuffer  { vec2  velocities[];   };
layout(std430, binding = 4) readonly buffer DeformGradBuf { vec4 deform_grads[]; };
layout(std430, binding = 5) buffer AffineMomBuffer  { vec4  affine_moms[]; };
layout(std430, binding = 6) buffer TempBuffer       { float temperatures[];};
layout(std430, binding = 7) readonly buffer MatIDBuffer { uint material_ids[];};
layout(std430, binding = 9) buffer ColorBuffer { vec4  colors[];  };

layout(std430, binding = 43) readonly buffer GridVelX  { float grid_vel_x[]; };
layout(std430, binding = 44) readonly buffer GridVelY  { float grid_vel_y[]; };
layout(std430, binding = 45) readonly buffer GridTemp  { float grid_temp[];  };
layout(std430, binding = 56) readonly buffer GridContactTemp { int grid_contact_temp[]; };

layout(std430, binding = 47) buffer JpBuffer    { float Jp_data[];    };
layout(std430, binding = 49) buffer DamageBuf   { float damage[];     };
layout(std430, binding = 50) buffer PhaseBuf    { float phase_data[]; };
layout(std430, binding = 52) readonly buffer SpringAnchorBuf { vec2 spring_anchor[]; };
layout(std430, binding = 53) readonly buffer SpringWeightBuf { float spring_weight[]; };

layout(binding = 0) uniform sampler2D u_sdf_tex;
layout(binding = 1) uniform sampler2D u_magnetic_field_tex;
layout(binding = 2) uniform sampler2D u_magnetic_total_tex;
layout(binding = 3) uniform sampler2D u_magnetic_material_tex;
layout(binding = 4) uniform sampler2D u_air_temp_tex;
layout(binding = 5) uniform sampler2D u_airtight_pressure_tex;
layout(binding = 6) uniform sampler2D u_airtight_outside_tex;
layout(binding = 7) uniform sampler2D u_bio_a_tex;
layout(binding = 8) uniform sampler2D u_bio_b_tex;
layout(binding = 9) uniform sampler2D u_automata_tex;
layout(binding = 10) uniform sampler2D u_bio_support_tex;
layout(binding = 11) uniform sampler2D u_bio_source_tex;

uniform uint  u_offset, u_count;
uniform float u_dx, u_dt;
uniform vec2  u_grid_origin;
uniform ivec2 u_grid_res;
uniform int   u_vis_mode;
uniform vec2  u_sdf_world_min, u_sdf_world_max;
uniform int   u_use_sdf;
uniform vec2  u_heat_pos;
uniform float u_heat_radius, u_heat_power;
// Ambient heat source
uniform vec2  u_heat_src_pos;
uniform float u_heat_src_radius, u_heat_src_temp;
uniform float u_ambient_temp; // From Eulerian air solver
uniform float u_particle_cooling;
uniform int   u_use_air_heat;
uniform vec2  u_air_world_min;
uniform vec2  u_air_world_max;
uniform int   u_use_airtight_pressure;
uniform ivec2 u_cavity_res;
uniform int   u_use_bio_field;
uniform float u_bio_coupling;
uniform float u_bio_regrowth_rate;
uniform int   u_use_automata_field;
uniform float u_automata_coupling;
uniform float u_bio_view_gain;
uniform float u_automata_view_gain;
uniform int   u_enable_pseudo_25d;
uniform float u_pseudo_25d_depth;
uniform vec2  u_mouse_world;
uniform float u_mouse_force;
uniform float u_mouse_damping;
uniform int   u_mouse_mode;
uniform vec2  u_spring_origin;
uniform int   u_kinematic_targets_active;
uniform float u_kinematic_target_force;
uniform float u_kinematic_target_damping;
uniform vec2  u_magnet_pos;
uniform float u_magnet_radius;
uniform float u_magnet_falloff_radius;
uniform float u_magnet_force;
uniform float u_magnet_spike_strength;
uniform float u_magnet_spike_freq;
uniform int   u_use_real_magnetics;
uniform vec2  u_magnetic_world_min;
uniform vec2  u_magnetic_world_max;
uniform float u_magnetic_force_scale;
// External-drive signals used to gate Kelvin body-force. When neither the
// ambient field nor the cursor brush is strong enough to provide a clean
// "external" stimulus, we damp the body-force so particle-to-particle
// dipole-dipole self-feedback can't run away and collapse a puddle under a
// microscopic ambient seed. Both paths are OR'd — if EITHER is strong, force
// passes through.
uniform float u_magnetic_ambient_mag;     // |ambient_H|
uniform float u_magnetic_cursor_strength; // |cursor_strength|
// Set true when Real Magnetics is on — scene SDF magnets + soft iron etc
// contribute to the solved field. Their gradients are inherently non-self,
// so the gate should pass full force through whenever they might exist,
// or ferro next to a scene magnet (without M held) would feel no force.
uniform int   u_magnetic_scene_active;

// Per-particle persistent magnetization (written by magnetic_particles.comp).
// We read it here to compute the ANISOTROPIC dipole-dipole pair force
// F = ∇(M · H) which, unlike the isotropic (χ/2)∇|H|² Kelvin force, gives
// head-to-tail attraction + side-by-side repulsion between two particles
// with aligned M. This is what produces the iconic ferrofluid chain
// patterns (Rosensweig '85 and many SIGGRAPH ferrofluid papers).
layout(std430, binding = 22) readonly buffer ParticleMPrev {
    vec2 particle_m_prev[];
};

// Electrostatic coupling. The E-field texture is written by the
// ElectrostaticField solver (Poisson + grad(-phi)). Per-particle scalar
// charge `q` drives F = qE. The separate gate uniform lets MPM run with
// electrostatics entirely off (0 = skip). Binding 10 picked because
// units 0-9 are already taken by SDF, magnetic, air, airtight pressure,
// bio, and automata samplers — sharing a binding silently breaks the
// shader so MPM particles freeze (the symptom this commit fixes).
layout(binding = 10) uniform sampler2D u_electric_field_tex;
uniform int u_use_electrostatics;
uniform vec2 u_electric_world_min;
uniform vec2 u_electric_world_max;
uniform float u_electric_force_scale;

layout(std430, binding = 24) readonly buffer ParticleCharge {
    float particle_charge[];
};
uniform int   u_keep_colors;
uniform uint  u_highlight_start; // Global index range to highlight
uniform uint  u_highlight_end;
uniform float u_time;
uniform vec2  u_gravity;
uniform int   u_multi_scale; // 0=uniform gravity, 1=per-material scale

#include "common/mpm_utils.glsl"

// --- Colormaps ---
vec3 viridis(float t) {
    t = clamp(t, 0.0, 1.0);
    vec3 a = vec3(0.267,0.004,0.329), b = vec3(0.163,0.471,0.558);
    vec3 c = vec3(0.477,0.821,0.318), d = vec3(0.993,0.906,0.144);
    if (t < 0.33) return mix(a, b, t*3.0);
    if (t < 0.66) return mix(b, c, (t-0.33)*3.0);
    return mix(c, d, (t-0.66)*3.0);
}
vec3 heat_color(float t) {
    t = clamp(t, 0.0, 1.0);
    if (t < 0.33) return mix(vec3(0.1,0.1,0.5), vec3(0.9,0.9,0.1), t*3.0);
    if (t < 0.66) return mix(vec3(0.9,0.9,0.1), vec3(0.9,0.4,0.1), (t-0.33)*3.0);
    return mix(vec3(0.9,0.4,0.1), vec3(1.0,0.1,0.1), (t-0.66)*3.0);
}
vec3 coolwarm(float t) {
    t = clamp(t, 0.0, 1.0);
    if (t < 0.5) return mix(vec3(0.1,0.3,0.8), vec3(0.9), t*2.0);
    return mix(vec3(0.9), vec3(0.8,0.1,0.1), (t-0.5)*2.0);
}

vec3 ash_regrowth_state_color(float regrow, float ash, float crumble, float temp_here) {
    float cool_restore = 1.0 - smoothstep(360.0, 450.0, temp_here);
    float recovery_vis = smoothstep(0.05, 0.42, regrow) * cool_restore * smoothstep(0.12, 0.90, ash);
    float effective_live = clamp(max(regrow, recovery_vis * (0.28 + 0.72 * ash)), 0.0, 1.0);
    float dead = clamp(ash * (1.0 - effective_live * 0.92), 0.0, 1.0);
    float ember = smoothstep(520.0, 920.0, temp_here) * (0.18 + 0.82 * ash) * (1.0 - regrow * 0.35);
    vec3 char_c = mix(vec3(0.58, 0.58, 0.56), vec3(0.04, 0.04, 0.04), smoothstep(0.10, 0.92, dead));
    vec3 live_c = mix(vec3(0.76, 0.78, 0.74), vec3(0.97, 0.98, 0.95), smoothstep(0.08, 0.88, effective_live));
    float revive = smoothstep(0.08, 0.58, effective_live) * mix(0.34, 1.0, cool_restore);
    vec3 c = mix(char_c, live_c, revive);
    c = mix(c, vec3(0.08, 0.07, 0.06), smoothstep(0.10, 0.95, crumble) * 0.45);
    c += vec3(0.26, 0.10, 0.03) * ember;
    return c;
}

vec4 sample_magnetic_field(vec2 pos) {
    vec2 uv = (pos - u_magnetic_world_min) / (u_magnetic_world_max - u_magnetic_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return vec4(0.0);
    return texture(u_magnetic_field_tex, uv);
}

vec4 sample_magnetic_field_smooth(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_field_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    vec4 c = sample_magnetic_field(pos) * 0.34;
    vec4 ax = (sample_magnetic_field(pos + vec2(cell.x, 0.0)) +
               sample_magnetic_field(pos - vec2(cell.x, 0.0)) +
               sample_magnetic_field(pos + vec2(0.0, cell.y)) +
               sample_magnetic_field(pos - vec2(0.0, cell.y))) * 0.12;
    vec4 dg = (sample_magnetic_field(pos + cell) +
               sample_magnetic_field(pos + vec2(cell.x, -cell.y)) +
               sample_magnetic_field(pos + vec2(-cell.x, cell.y)) +
               sample_magnetic_field(pos - cell)) * 0.045;
    return c + ax + dg;
}

vec4 sample_magnetic_total_field(vec2 pos) {
    vec2 uv = (pos - u_magnetic_world_min) / (u_magnetic_world_max - u_magnetic_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return vec4(0.0);
    return texture(u_magnetic_total_tex, uv);
}

vec4 sample_magnetic_total_field_smooth(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_total_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    vec4 c = sample_magnetic_total_field(pos) * 0.34;
    vec4 ax = (sample_magnetic_total_field(pos + vec2(cell.x, 0.0)) +
               sample_magnetic_total_field(pos - vec2(cell.x, 0.0)) +
               sample_magnetic_total_field(pos + vec2(0.0, cell.y)) +
               sample_magnetic_total_field(pos - vec2(0.0, cell.y))) * 0.12;
    vec4 dg = (sample_magnetic_total_field(pos + cell) +
               sample_magnetic_total_field(pos + vec2(cell.x, -cell.y)) +
               sample_magnetic_total_field(pos + vec2(-cell.x, cell.y)) +
               sample_magnetic_total_field(pos - cell)) * 0.045;
    return c + ax + dg;
}

vec4 sample_magnetic_field_bulk(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_field_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    vec4 sum = sample_magnetic_field(pos) * 0.14;
    sum += (sample_magnetic_field(pos + vec2(cell.x, 0.0)) +
            sample_magnetic_field(pos - vec2(cell.x, 0.0)) +
            sample_magnetic_field(pos + vec2(0.0, cell.y)) +
            sample_magnetic_field(pos - vec2(0.0, cell.y))) * 0.09;
    sum += (sample_magnetic_field(pos + cell) +
            sample_magnetic_field(pos + vec2(cell.x, -cell.y)) +
            sample_magnetic_field(pos + vec2(-cell.x, cell.y)) +
            sample_magnetic_field(pos - cell)) * 0.07;
    sum += (sample_magnetic_field(pos + vec2(2.0 * cell.x, 0.0)) +
            sample_magnetic_field(pos - vec2(2.0 * cell.x, 0.0)) +
            sample_magnetic_field(pos + vec2(0.0, 2.0 * cell.y)) +
            sample_magnetic_field(pos - vec2(0.0, 2.0 * cell.y))) * 0.05;
    sum += (sample_magnetic_field(pos + vec2(2.0 * cell.x,  cell.y)) +
            sample_magnetic_field(pos + vec2(2.0 * cell.x, -cell.y)) +
            sample_magnetic_field(pos + vec2(-2.0 * cell.x,  cell.y)) +
            sample_magnetic_field(pos + vec2(-2.0 * cell.x, -cell.y)) +
            sample_magnetic_field(pos + vec2( cell.x, 2.0 * cell.y)) +
            sample_magnetic_field(pos + vec2(-cell.x, 2.0 * cell.y)) +
            sample_magnetic_field(pos + vec2( cell.x,-2.0 * cell.y)) +
            sample_magnetic_field(pos + vec2(-cell.x,-2.0 * cell.y))) * 0.025;
    return sum;
}

float sample_magnetic_occupancy(vec2 pos) {
    vec2 uv = (pos - u_magnetic_world_min) / (u_magnetic_world_max - u_magnetic_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_magnetic_material_tex, uv).z;
}

float sample_magnetic_occupancy_smooth(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_material_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float c = sample_magnetic_occupancy(pos) * 0.50;
    float ax = (sample_magnetic_occupancy(pos + vec2(cell.x, 0.0)) +
                sample_magnetic_occupancy(pos - vec2(cell.x, 0.0)) +
                sample_magnetic_occupancy(pos + vec2(0.0, cell.y)) +
                sample_magnetic_occupancy(pos - vec2(0.0, cell.y))) * 0.10;
    float dg = (sample_magnetic_occupancy(pos + cell) +
                sample_magnetic_occupancy(pos + vec2(cell.x, -cell.y)) +
                sample_magnetic_occupancy(pos + vec2(-cell.x, cell.y)) +
                sample_magnetic_occupancy(pos - cell)) * 0.025;
    return c + ax + dg;
}

vec2 magnetic_occ_grad(vec2 pos) {
    ivec2 res = textureSize(u_magnetic_material_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float occ_l = sample_magnetic_occupancy(pos - vec2(cell.x, 0.0));
    float occ_r = sample_magnetic_occupancy(pos + vec2(cell.x, 0.0));
    float occ_b = sample_magnetic_occupancy(pos - vec2(0.0, cell.y));
    float occ_t = sample_magnetic_occupancy(pos + vec2(0.0, cell.y));
    return vec2((occ_r - occ_l) / max(2.0 * cell.x, 1e-5),
                (occ_t - occ_b) / max(2.0 * cell.y, 1e-5));
}

float sample_sdf_distance(vec2 pos) {
    if (u_use_sdf == 0) return 1e6;
    vec2 uv = (pos - u_sdf_world_min) / (u_sdf_world_max - u_sdf_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 1e6;
    return texture(u_sdf_tex, uv).r;
}

vec2 sample_sdf_normal(vec2 pos) {
    vec2 texel = (u_sdf_world_max - u_sdf_world_min) / vec2(textureSize(u_sdf_tex, 0));
    float dx = sample_sdf_distance(pos + vec2(texel.x, 0.0)) - sample_sdf_distance(pos - vec2(texel.x, 0.0));
    float dy = sample_sdf_distance(pos + vec2(0.0, texel.y)) - sample_sdf_distance(pos - vec2(0.0, texel.y));
    vec2 g = vec2(dx, dy);
    float gl = length(g);
    return (gl > 1e-6) ? (g / gl) : vec2(0.0, 1.0);
}

float sample_air_temp(vec2 pos) {
    if (u_use_air_heat == 0) return u_ambient_temp;
    vec2 uv = (pos - u_air_world_min) / (u_air_world_max - u_air_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return u_ambient_temp;
    return texture(u_air_temp_tex, uv).r;
}

float sample_sdf_contact_temp(vec2 pos, out float contact_w) {
    contact_w = 0.0;
    if (u_use_sdf == 0 || u_use_air_heat == 0) return u_ambient_temp;
    float sdf_d = sample_sdf_distance(pos);
    if (sdf_d < 0.0) {
        contact_w = 1.0;
        return sample_air_temp(pos);
    }
    ivec2 air_res = textureSize(u_air_temp_tex, 0);
    vec2 air_cell = (u_air_world_max - u_air_world_min) / vec2(max(air_res, ivec2(1)));
    float probe = max(max(air_cell.x, air_cell.y) * 1.6, 0.02);
    if (sdf_d > probe * 1.4) return u_ambient_temp;
    vec2 n = sample_sdf_normal(pos);
    vec2 inside = pos - n * (sdf_d + probe);
    contact_w = 1.0 - clamp(sdf_d / max(probe * 1.4, 1e-5), 0.0, 1.0);
    return sample_air_temp(inside);
}

vec2 sample_bio_uv(vec2 pos) {
    return (pos - u_air_world_min) / (u_air_world_max - u_air_world_min);
}

float sample_bio_a(vec2 pos) {
    if (u_use_bio_field == 0) return 1.0;
    vec2 uv = sample_bio_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 1.0;
    return texture(u_bio_a_tex, uv).r;
}

float sample_bio_b(vec2 pos) {
    if (u_use_bio_field == 0) return 0.0;
    vec2 uv = sample_bio_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_bio_b_tex, uv).r;
}

vec2 sample_bio_b_gradient(vec2 pos) {
    if (u_use_bio_field == 0) return vec2(0.0);
    ivec2 res = textureSize(u_bio_b_tex, 0);
    vec2 span = u_air_world_max - u_air_world_min;
    vec2 cell = span / vec2(max(res, ivec2(1)));
    float bl = sample_bio_b(pos - vec2(cell.x, 0.0));
    float br = sample_bio_b(pos + vec2(cell.x, 0.0));
    float bd = sample_bio_b(pos - vec2(0.0, cell.y));
    float bu = sample_bio_b(pos + vec2(0.0, cell.y));
    return vec2((br - bl) / max(2.0 * cell.x, 1e-5),
                (bu - bd) / max(2.0 * cell.y, 1e-5));
}

float sample_bio_source(vec2 pos) {
    if (u_use_bio_field == 0) return 0.0;
    vec2 uv = sample_bio_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_bio_source_tex, uv).r;
}

vec2 sample_bio_source_gradient(vec2 pos) {
    if (u_use_bio_field == 0) return vec2(0.0);
    ivec2 res = textureSize(u_bio_source_tex, 0);
    vec2 span = u_air_world_max - u_air_world_min;
    vec2 cell = span / vec2(max(res, ivec2(1)));
    float sl = sample_bio_source(pos - vec2(cell.x, 0.0));
    float sr = sample_bio_source(pos + vec2(cell.x, 0.0));
    float sd = sample_bio_source(pos - vec2(0.0, cell.y));
    float su = sample_bio_source(pos + vec2(0.0, cell.y));
    return vec2((sr - sl) / max(2.0 * cell.x, 1e-5),
                (su - sd) / max(2.0 * cell.y, 1e-5));
}

float sample_automata(vec2 pos) {
    if (u_use_automata_field == 0) return 0.0;
    vec2 uv = sample_bio_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_automata_tex, uv).r;
}

vec2 sample_automata_gradient(vec2 pos) {
    if (u_use_automata_field == 0) return vec2(0.0);
    ivec2 res = textureSize(u_automata_tex, 0);
    vec2 span = u_air_world_max - u_air_world_min;
    vec2 cell = span / vec2(max(res, ivec2(1)));
    float al = sample_automata(pos - vec2(cell.x, 0.0));
    float ar = sample_automata(pos + vec2(cell.x, 0.0));
    float ad = sample_automata(pos - vec2(0.0, cell.y));
    float au = sample_automata(pos + vec2(0.0, cell.y));
    return vec2((ar - al) / max(2.0 * cell.x, 1e-5),
                (au - ad) / max(2.0 * cell.y, 1e-5));
}

float sample_bio_support(vec2 pos) {
    if (u_use_bio_field == 0 && u_use_automata_field == 0) return 0.0;
    vec2 uv = sample_bio_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_bio_support_tex, uv).r;
}

vec2 sample_bio_support_gradient(vec2 pos) {
    if (u_use_bio_field == 0 && u_use_automata_field == 0) return vec2(0.0);
    ivec2 res = textureSize(u_bio_support_tex, 0);
    vec2 span = u_air_world_max - u_air_world_min;
    vec2 cell = span / vec2(max(res, ivec2(1)));
    float sl = sample_bio_support(pos - vec2(cell.x, 0.0));
    float sr = sample_bio_support(pos + vec2(cell.x, 0.0));
    float sd = sample_bio_support(pos - vec2(0.0, cell.y));
    float su = sample_bio_support(pos + vec2(0.0, cell.y));
    return vec2((sr - sl) / max(2.0 * cell.x, 1e-5),
                (su - sd) / max(2.0 * cell.y, 1e-5));
}

vec2 cavity_uv(vec2 pos) {
    return (pos - u_air_world_min) / (u_air_world_max - u_air_world_min);
}

float sample_airtight_pressure(vec2 pos) {
    if (u_use_airtight_pressure == 0) return 0.0;
    vec2 uv = cavity_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return texture(u_airtight_pressure_tex, uv).r;
}

float sample_airtight_trapped(vec2 pos) {
    if (u_use_airtight_pressure == 0) return 0.0;
    vec2 uv = cavity_uv(pos);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return 0.0;
    return 1.0 - texture(u_airtight_outside_tex, uv).r;
}

vec2 sample_airtight_pressure_gradient(vec2 pos) {
    if (u_use_airtight_pressure == 0) return vec2(0.0);
    vec2 span = u_air_world_max - u_air_world_min;
    vec2 step_uv = 1.0 / vec2(max(u_cavity_res, ivec2(1)));
    vec2 du = vec2(step_uv.x, 0.0);
    vec2 dv = vec2(0.0, step_uv.y);
    vec2 uv = clamp(cavity_uv(pos), vec2(0.0), vec2(1.0));
    float pl = texture(u_airtight_pressure_tex, clamp(uv - du, vec2(0.0), vec2(1.0))).r;
    float pr = texture(u_airtight_pressure_tex, clamp(uv + du, vec2(0.0), vec2(1.0))).r;
    float pd = texture(u_airtight_pressure_tex, clamp(uv - dv, vec2(0.0), vec2(1.0))).r;
    float pu = texture(u_airtight_pressure_tex, clamp(uv + dv, vec2(0.0), vec2(1.0))).r;
    float dx = max(span.x * step_uv.x, 1e-5);
    float dy = max(span.y * step_uv.y, 1e-5);
    return vec2((pr - pl) / (2.0 * dx), (pu - pd) / (2.0 * dy));
}

float sample_contact_temp(ivec2 cell) {
    if (cell.x < 0 || cell.y < 0 || cell.x >= u_grid_res.x || cell.y >= u_grid_res.y) return 0.0;
    uint ci = uint(cell.y * u_grid_res.x + cell.x);
    return float(grid_contact_temp[ci]) * 0.001;
}

