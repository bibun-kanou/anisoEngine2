                crumb_c = mix(crumb_c, vec3(0.94, 0.86, 0.72), moisture * 0.16);
                cur.rgb = mix(cur.rgb, crumb_c, 0.80);
                cur.rgb = mix(cur.rgb, vec3(0.20, 0.08, 0.03), pore * 0.18);
            } else if (mat_type == 47u) {
                float binder = damage[idx];
                float moisture = phase_data[idx];
                float channel = Jp_data[idx];
                vec3 crumb_c = mix(vec3(0.98, 0.86, 0.64), vec3(0.56, 0.32, 0.14), binder);
                crumb_c = mix(crumb_c, vec3(1.00, 0.95, 0.82), channel * 0.20);
                crumb_c = mix(crumb_c, vec3(0.92, 0.82, 0.68), moisture * 0.14);
                cur.rgb = mix(cur.rgb, crumb_c, 0.80);
                cur.rgb = mix(cur.rgb, vec3(0.24, 0.10, 0.04), channel * 0.24);
            } else if (mat_type == 48u) {
                float fired = damage[idx];
                float moisture = phase_data[idx];
                float pore = Jp_data[idx];
                vec3 clay_c = mix(vec3(0.88, 0.76, 0.66), vec3(0.64, 0.40, 0.26), fired);
                clay_c = mix(clay_c, vec3(0.98, 0.94, 0.86), pore * 0.20);
                clay_c = mix(clay_c, vec3(0.86, 0.80, 0.74), moisture * 0.12);
                cur.rgb = mix(cur.rgb, clay_c, 0.80);
                cur.rgb = mix(cur.rgb, vec3(0.12, 0.05, 0.03), pore * 0.24);
            } else if (mat_type == 49u) {
                float dry = damage[idx];
                float moisture = phase_data[idx];
                float vent = Jp_data[idx];
                vec3 skin_c = mix(vec3(0.96, 0.90, 0.72), vec3(0.82, 0.58, 0.26), dry);
                skin_c = mix(skin_c, vec3(0.98, 0.95, 0.86), moisture * 0.14);
