    vec4 color;
    speed = length(new_vel);

    mat2 F_vis = mat2(deform_grads[idx].x, deform_grads[idx].y, deform_grads[idx].z, deform_grads[idx].w);
    SVD2 s_vis = svd2x2(F_vis);
    mat2 R_vis = s_vis.U * transpose(s_vis.V);
    float dev_vis = length(vec4((F_vis - R_vis)[0], (F_vis - R_vis)[1]));
    float J_vis = determinant(F_vis);
    float density_proxy = clamp(1.0 / max(J_vis, 0.30), 0.0, 2.2);
    float temp_vis = clamp((temp - 240.0) / 620.0, 0.0, 1.0);
    float stress_vis = clamp(dev_vis * 3.2, 0.0, 1.0);
