// Anisotropic dipole-dipole pair force for particles carrying a persistent
// magnetization M_p. Returns F = ∇(M_p · H) computed via 4-sample central
// differences on the bulk H field. When a neighbor particle raises H
// locally along the M_p direction, the gradient points toward the neighbor
// IF M_p is aligned with the displacement (head-to-tail) — attractive along
// the chain axis. Perpendicular to M_p, the same rasterized neighbor
// lowers M_p·H at the particle position (the neighbor's contribution to H
// is along M, perpendicular to r̂ → dot product smaller), so the gradient
// points AWAY — repulsive side-by-side. That asymmetry is exactly the
// Rosensweig chain-formation condition.
vec2 dipole_chain_force(vec2 pos, vec2 M_p, float scale) {
    if (u_use_real_magnetics == 0) return vec2(0.0);
    float Mm = length(M_p);
    if (Mm < 1e-4) return vec2(0.0);
    ivec2 res = textureSize(u_magnetic_field_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float mh_l = dot(sample_magnetic_field_bulk(pos - vec2(cell.x, 0.0)).xy, M_p);
    float mh_r = dot(sample_magnetic_field_bulk(pos + vec2(cell.x, 0.0)).xy, M_p);
    float mh_b = dot(sample_magnetic_field_bulk(pos - vec2(0.0, cell.y)).xy, M_p);
    float mh_t = dot(sample_magnetic_field_bulk(pos + vec2(0.0, cell.y)).xy, M_p);
    vec2 grad_mh = vec2((mh_r - mh_l) / max(2.0 * cell.x, 1e-5),
                        (mh_t - mh_b) / max(2.0 * cell.y, 1e-5));
    // Scale inversely with |M_p| so the force stays bounded when particles
    // briefly saturate to very large M (avoids runaway during peak field
    // moments). The physical force is linear in M, but for a stable sim
    // we want saturation-like cap.
    return grad_mh * (scale / (1.0 + 0.15 * Mm));
}

// Coulomb force on a charged particle: F = q * E * force_scale.
// force_scale bundles (1/ε₀-ρ)-analog factors to convert solver E units
// into m/s² on the particle mass. Returns a cap-free force; the caller
// clamps into the physically reasonable range.
vec2 coulomb_force(vec2 pos, float q) {
    if (u_use_electrostatics == 0 || abs(q) < 1e-5 || u_electric_force_scale <= 1e-5) return vec2(0.0);
    vec2 uv = (pos - u_electric_world_min) / (u_electric_world_max - u_electric_world_min);
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return vec2(0.0);
    vec4 E = texture(u_electric_field_tex, uv);
    return q * E.xy * u_electric_force_scale;
}

vec2 magnetic_body_force(vec2 pos, float susceptibility, float force_limit) {
    if (u_use_real_magnetics == 0 || susceptibility <= 1e-5 || u_magnetic_force_scale <= 1e-5) return vec2(0.0);

    ivec2 res = textureSize(u_magnetic_field_tex, 0);
    vec2 cell = (u_magnetic_world_max - u_magnetic_world_min) / vec2(max(res, ivec2(1)));
    float h2_l = sample_magnetic_field_bulk(pos - vec2(cell.x, 0.0)).w;
    float h2_r = sample_magnetic_field_bulk(pos + vec2(cell.x, 0.0)).w;
    float h2_b = sample_magnetic_field_bulk(pos - vec2(0.0, cell.y)).w;
    float h2_t = sample_magnetic_field_bulk(pos + vec2(0.0, cell.y)).w;
    vec2 grad_h2 = vec2((h2_r - h2_l) / max(2.0 * cell.x, 1e-5),
                        (h2_t - h2_b) / max(2.0 * cell.y, 1e-5));
    float bulk_h2 = sample_magnetic_field_bulk(pos).w;
    float local_h2 = sample_magnetic_field_smooth(pos).w;
    float sharpness = max(local_h2 - bulk_h2, 0.0) / max(bulk_h2, 1e-4);
    float grad_mag = length(grad_h2);
    float grad_ratio = grad_mag / max(local_h2, 1e-4);
    float bulk_ratio = clamp(bulk_h2 / max(local_h2, 1e-4), 0.0, 1.0);
    // Kelvin body force: F/m = (chi/2) * grad|H|^2.
    // u_magnetic_force_scale bundles the unit-reconciliation factor (μ₀/ρ)
    // since |H| here is in solver units, not SI A/m.
    vec2 f = 0.5 * susceptibility * u_magnetic_force_scale * grad_h2;
    // Aggressively suppress near-field rigid-magnet spikes. The ferro
    // constitutive path can still use the sharper field for shaping, but
    // bulk translation should only see the low-frequency scene component.
    float hf_suppress = bulk_ratio / (1.0 + 2.1 * sharpness + 0.08 * grad_ratio);
    float d = sample_sdf_distance(pos);
    float wall_gate = mix(0.22, 1.0, smoothstep(u_dx * 2.0, u_dx * 7.0, max(d, 0.0)));
    hf_suppress *= wall_gate;
    f *= hf_suppress;
    // External-drive gate. In the absence of a CLEAR external stimulus
    // (strong ambient, active cursor, or scene magnets via Real Magnetics),
    // we damp the Kelvin force so the particle-to-particle dipole-dipole
    // attraction can't run away from a microscopic ambient seed. ANY of
    // the three signals being strong lets the force through at full
    // strength.
    //   - ambient_gate: ramps in as |ambient_H| crosses 0.3 -> 3.0.
    //     Below 0.3 the ambient is physically too weak for real
    //     ferrofluid to macroscopically respond; above 3.0 particles
    //     are near saturation and demag feedback is self-regulating.
    //   - cursor_gate: ramps in as cursor_strength crosses 0.002 -> 0.05.
    //     Small threshold because cursor is a strongly localized source.
    //   - scene_gate: binary on/off tied to Real Magnetics. When scene
    //     magnets are enabled, whatever gradients exist are inherently
    //     non-self-referential; pass the force through.
    float ambient_gate = smoothstep(0.3, 3.0, u_magnetic_ambient_mag);
    float cursor_gate  = smoothstep(0.002, 0.05, u_magnetic_cursor_strength);
    float scene_gate   = (u_magnetic_scene_active != 0) ? 1.0 : 0.0;
    float ext_drive    = max(max(ambient_gate, cursor_gate), scene_gate);
    f *= ext_drive;
    // Safety clamp against solver spikes at coarse cell boundaries.
    // Real ferrofluid experiments see ~1-3g peak body-force acceleration
    // (they work against gravity but only marginally). force_limit is a
    // per-material cap — heavy ferro uses higher caps so it can climb,
    // regular ferro uses lower ones for subtle behavior.
    float mag = length(f);
    float max_force = max(force_limit, 0.0);
    if (mag > max_force) f *= max_force / mag;
    return f;
}

vec2 ferro_surface_force(vec2 pos) {
    if (u_use_real_magnetics == 0) return vec2(0.0);

    vec4 drive_f = sample_magnetic_field_smooth(pos);
    vec4 total_f = sample_magnetic_total_field_smooth(pos);
    float induced_gain = clamp((total_f.z - drive_f.z) / max(drive_f.z, 1e-4), 0.0, 1.0);
    vec2 align_vec = mix(drive_f.xy, total_f.xy, 0.18 * induced_gain);
    float hmag = mix(drive_f.z, total_f.z, 0.08 * induced_gain);
    if (hmag <= 1e-5) return vec2(0.0);

    float occ = sample_magnetic_occupancy(pos);
    float occ_support = sample_magnetic_occupancy_smooth(pos);
    vec2 occ_grad = magnetic_occ_grad(pos);
    float occ_grad_mag = length(occ_grad);
    if (occ_grad_mag <= 1e-5 || occ <= 1e-4) return vec2(0.0);

    // Once the puddle has already atomized into isolated grains, stop
    // applying the free-surface shaping force that is meant for a
    // connected liquid interface. Otherwise each lone particle behaves
    // like its own tiny spike emitter and turns into shrapnel.
    float cohesion_gate = smoothstep(0.18, 0.52, occ_support);
    if (cohesion_gate <= 1e-4) return vec2(0.0);

    vec2 n_in = occ_grad / occ_grad_mag;
    vec2 n_out = -n_in;
    vec2 field_dir = normalize(align_vec + vec2(1e-6, 0.0));
    float normal_align = abs(dot(field_dir, n_out));
    float interface_band = smoothstep(0.06, 0.28, occ_grad_mag) *
                           smoothstep(0.05, 0.22, occ) *
                           cohesion_gate;
    if (interface_band <= 1e-4) return vec2(0.0);

    float sat = 1.0 - exp(-hmag * 0.34);
    float capillary = 0.42 + 0.20 * sat;
    float magnetic_relief = (0.12 + 0.22 * u_magnet_spike_strength) *
                            sat * normal_align * normal_align;
    float column_pull = (0.05 + 0.10 * u_magnet_spike_strength) *
                        sat * normal_align;

    // n_in points toward the interior of the puddle. Capillary force
    // therefore pulls along +n_in, while magnetic normal traction
    // subtracts from it and can locally push the interface outward.
    vec2 f = (capillary - magnetic_relief) * n_in * interface_band;
    f += field_dir * column_pull * interface_band;
    float mag = length(f);
    float max_force = mix(0.45, 1.6, cohesion_gate);
    if (mag > max_force) f *= max_force / mag;
    return f;
}

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= u_count) return;

    uint p = u_offset + idx;
    vec2 pos = positions[p];
    vec2 old_vel = velocities[p];
    uint mat_type = material_ids[p];
    vec4 thermal_params = thermal_coupling_defaults(mat_type);

    float inv_dx = 1.0 / u_dx;
    vec2 cell_pos = (pos - u_grid_origin) * inv_dx;
    ivec2 base = ivec2(floor(cell_pos - 0.5));
    vec2 fx = cell_pos - vec2(base);
    vec3 wx = bspline_weights(fx.x);
    vec3 wy = bspline_weights(fx.y);

    vec2 new_vel = vec2(0.0);
    mat2 new_C = mat2(0.0);
    vec2 bio_debug_force = vec2(0.0);
    vec2 automata_debug_force = vec2(0.0);

    for (int gy = 0; gy < 3; gy++) {
        for (int gx = 0; gx < 3; gx++) {
            ivec2 node = base + ivec2(gx, gy);
            if (node.x < 0 || node.y < 0 || node.x >= u_grid_res.x || node.y >= u_grid_res.y)
                continue;
            float weight = wx[gx] * wy[gy];
            uint cell = uint(node.y * u_grid_res.x + node.x);
            vec2 g_vel = vec2(grid_vel_x[cell], grid_vel_y[cell]);
            vec2 dpos = (vec2(node) - cell_pos) * u_dx;
            new_vel += weight * g_vel;
            new_C += 4.0 * inv_dx * inv_dx * weight * mat2(
                g_vel.x*dpos.x, g_vel.x*dpos.y,
                g_vel.y*dpos.x, g_vel.y*dpos.y);
        }
    }

    float max_speed_cells = 3.0;
    if (mat_type == 31u) max_speed_cells = 0.45;      // ferro should never become ballistic shrapnel
    else if (mat_type == 67u) max_speed_cells = 0.55; // heavy ferro: bit faster allowed for taller spikes, still not ballistic
    else if (mat_type == 68u) max_speed_cells = 0.50; // diamagnetic: moderate cap, can drift away
    else if (mat_type == 69u) max_speed_cells = 1.40; // para mist: light aerosol, moves briskly
    else if (mat_type == 70u) max_speed_cells = 0.38; // sticky ferro: stays cohesive, slow
    else if (mat_type == 71u) max_speed_cells = 0.85; // superconductor: rigid solid, typical solid cap
    else if (mat_type == 72u) max_speed_cells = 0.65; // Curie ferro: solidly ferromagnetic below T_c
    else if (mat_type == 73u) max_speed_cells = 1.00; // eddy copper: a bit faster than ferro (heating comes from motion)
    else if (mat_type == 74u) max_speed_cells = 0.55; // hard magnet: solid, heavy
    else if (mat_type == 75u) max_speed_cells = 1.10; // sand: granular flow — grains can move briskly
    else if (mat_type == 76u) max_speed_cells = 0.90; // phase-brittle: solid cap, shatters on overload
    else if (mat_type == 77u) max_speed_cells = 1.60; // positive ion: light, can be pushed fast by field
    else if (mat_type == 78u) max_speed_cells = 1.60; // negative ion: same
    else if (mat_type == 79u) max_speed_cells = 0.70; // triboelectric solid: moderate
    else if (mat_type == 80u) max_speed_cells = 1.20; // rope segment: can swing freely
    else if (mat_type == 57u) max_speed_cells = 0.90; // soft iron can move, but not launch across the map
    else if (mat_type == 58u) max_speed_cells = 1.20; // rubber gets a little more room for bend response

    // Initial clamp on gathered grid velocity.
    float speed = length(new_vel);
    float max_speed = u_dx * max_speed_cells / u_dt;
    if (speed > max_speed) { new_vel *= max_speed / speed; new_C *= max_speed / speed; }

    // Buoyancy for burning/ember particles
    float temp_here = temperatures[p];
    if (mat_type == 7u || mat_type == 8u || mat_type == 16u || mat_type == 25u) { // burning / ember / flammable fluid / reactive burn
        float burn = damage[idx];
        bool is_ember = (mat_type == 8u);
        bool is_flammable_fluid = (mat_type == 16u);
        bool is_reactive_burn = (mat_type == 25u);
        float loft = clamp(thermal_params.w, 0.0, 2.0);
        if (u_use_airtight_pressure != 0) {
            float trapped = sample_airtight_trapped(pos);
            float trapped_gate = smoothstep(0.02, 0.14, trapped);
            float trapped_loft_keep = is_ember ? 0.0
                                    : (is_flammable_fluid ? 0.35
                                    : (is_reactive_burn ? 0.12 : 0.08));
            loft *= mix(1.0, trapped_loft_keep, trapped_gate);
        }
        float buoy_gate = is_ember ? burn : smoothstep(0.80, 1.0, burn);
        if (buoy_gate > 0.0 && loft > 0.0) {
            float heat_f = clamp((temp_here - 350.0) / 400.0, 0.0, 1.0);
            float buoy = is_ember ? 22.0 : (is_flammable_fluid ? 5.0 : 7.5);
            buoy *= heat_f;
            new_vel.y += buoy * buoy_gate * loft * u_dt;
            float drag = is_ember ? 0.18 : (is_flammable_fluid ? 0.08 : 0.18);
            new_vel *= (1.0 - drag * u_dt);
        }
    }

    if (u_use_real_magnetics != 0) {
        float susceptibility = 0.0;
        float max_mag_force = 0.0;
        float mag_temp = temperatures[p]; // temperature sampled early for thermally-gated magnetic materials
        // Magnetic materials. `max_mag_force` caps peak body-force acceleration in m/s².
        // Gravity is ~9.81, so to climb against it the ceiling must exceed that.
        // Older values (1.8, 5.5) were deliberately below gravity which is why
        // the fluid couldn't climb without disabling G. Bumped all to cleanly
        // overcome gravity in strong-field regions.
        if (mat_type == 31u) { susceptibility = 0.22; max_mag_force = 14.0; }   // ferro: visibly climbs to cursor
        else if (mat_type == 57u) { susceptibility = 0.22; max_mag_force = 9.0; }   // soft iron (MPM): was 0.0018 — effectively dead; now responds visibly to scene magnets
        else if (mat_type == 58u) { susceptibility = 0.34; max_mag_force = 6.0; }   // magnetic rubber
        else if (mat_type == 67u) { susceptibility = 0.90; max_mag_force = 28.0; }  // HEAVY ferro: strong climb vs gravity (2.8g cap); ext-drive gate prevents self-collapse
        else if (mat_type == 68u) { susceptibility = -0.55; max_mag_force = 12.0; } // DIAMAGNETIC: negative chi — particles pushed AWAY from field gradients (pool at edge of magnets)
        else if (mat_type == 69u) { susceptibility = 0.08; max_mag_force = 4.0; }   // PARA_MIST: very light, gentle drift along field lines, barely accelerates
        else if (mat_type == 70u) { susceptibility = 0.55; max_mag_force = 18.0; }  // STICKY_FERRO: strong attraction but stays cohesive — clumps into globules
        else if (mat_type == 71u) {                                                 // SUPERCONDUCTOR: Meissner — huge negative chi below T_c, zero above
            float active_sc = smoothstep(188.0, 172.0, mag_temp);                   // matches SUPERCONDUCTOR_T_C in magnetic_particles.comp (with hysteresis band)
            susceptibility = -1.8 * active_sc;
            max_mag_force = 38.0 * active_sc;
        }
        else if (mat_type == 72u) {                                                 // CURIE_FERRO: ferromagnet below T_Curie, zero above
            float below_curie = smoothstep(705.0, 655.0, mag_temp);
            susceptibility = 0.72 * below_curie;
            max_mag_force = 22.0 * below_curie;
        }
        else if (mat_type == 74u) { susceptibility = 0.90; max_mag_force = 26.0; }  // HARD_MAGNET: remanent permanent magnet — strong Kelvin, retains M via persistent SSBO
        // MAT_EDDY_COPPER (73) — purely conductive, no Kelvin susceptibility.
        // The eddy heating is computed below, outside this force block.
        // abs() so diamagnetic (negative chi) also gets the force path.
        // magnetic_body_force produces a signed force via `f = 0.5 * chi * ...`,
        // so negative chi correctly produces repulsion away from field gradients.
        if (abs(susceptibility) > 1e-5) {
            vec2 mag_force = magnetic_body_force(pos, susceptibility, max_mag_force);
            new_vel += mag_force * u_dt;
            if (mat_type == 58u) {
                new_vel *= (1.0 - 0.10 * u_dt);
            }
            // Sticky ferro: strong velocity damping so clumps don't splash apart.
            if (mat_type == 70u) {
                new_vel *= (1.0 - 0.35 * u_dt);
            }
        }

        // Ferrofluid chain formation — anisotropic dipole-dipole pair force
        // F = ∇(M_p · H). Only applies to liquid ferro materials that can
        // actually rearrange into chains; SOLIDS with magnetic response
        // (soft iron, rubber, hard magnet, Curie ferro, superconductor,
        // eddy copper) keep only the standard Kelvin body force so they
        // don't fragment along field lines.
        bool is_fluid_ferro = (mat_type == 31u || mat_type == 67u ||
                               mat_type == 68u || mat_type == 69u ||
                               mat_type == 70u);
        if (is_fluid_ferro) {
            vec2 M_p = particle_m_prev[p];
            // Per-material chain-force scale. Heavy ferro dominates because
            // its saturation M is high; para mist barely chains.
            float chain_scale;
            if (mat_type == 67u)      chain_scale = 0.045; // HEAVY: strong chaining
            else if (mat_type == 70u) chain_scale = 0.030; // STICKY: prefers globules over chains, mild
            else if (mat_type == 68u) chain_scale = 0.020; // DIAMAG: chains anti-align (still pattern-forming)
            else if (mat_type == 69u) chain_scale = 0.006; // PARA MIST: barely visible chaining
            else                      chain_scale = 0.028; // normal ferro
            vec2 f_chain = dipole_chain_force(pos, M_p, chain_scale);
            // Gate with the same ext-drive signal so chains only form under
            // a real external seed — matches the ambient/cursor/scene gate
            // philosophy of the main Kelvin force.
            float amb_gate = smoothstep(0.3, 3.0, u_magnetic_ambient_mag);
            float cur_gate = smoothstep(0.002, 0.05, u_magnetic_cursor_strength);
            float scn_gate = (u_magnetic_scene_active != 0) ? 1.0 : 0.0;
            float chain_gate = max(max(amb_gate, cur_gate), scn_gate);
            f_chain *= chain_gate;
            // Cap the chain force at ~4 m/s² so it accents the Kelvin
            // force rather than dominating it.
            float fc_mag = length(f_chain);
            if (fc_mag > 4.0) f_chain *= 4.0 / fc_mag;
            new_vel += f_chain * u_dt;
        }

        if (mat_type == 31u || mat_type == 67u || mat_type == 70u) {
            float hmag = sample_magnetic_field_smooth(pos).z;
            // Heavy ferro's surface force is scaled up aggressively so spikes
            // stretch tall and clumps compact even without a strong external
            // source. Regular ferro stays subtle-but-visible.
            float capillary_gate = (mat_type == 67u ? 0.70 : 0.42)
                                 + 0.70 * smoothstep(0.18, 1.1, hmag);
            float amplify = (mat_type == 67u) ? 3.2 : 1.1;
            new_vel += ferro_surface_force(pos) * (capillary_gate * amplify) * u_dt;
        }

        // Eddy-current heating (MAT_EDDY_COPPER). Physically: a conductor
        // moving through a field has an EMF ∝ v×B, which drives currents
        // that dissipate as Joule heat. 2D approximation uses scalar
        // |v|^2 * |H|^2 (ignores the angle between v and H but captures
        // the magnitude trend). Rate constant tuned so moving a copper
        // bar through a typical scene magnet visibly reddens it within
        // a few seconds of sim time without making it explode.
        if (mat_type == 73u) {
            float hmag = sample_magnetic_field_smooth(pos).z;
            float vspeed = length(new_vel);
            const float k_eddy = 0.32; // K per (m/s)^2 * |H|^2 * s
            float dQ = k_eddy * vspeed * vspeed * hmag * hmag * u_dt;
            // Safety clamp: even under extreme moves, limit single-frame
            // heating so we never produce NaN-inducing spikes.
            temperatures[p] = mag_temp + clamp(dQ, 0.0, 60.0);
        }
    }

    // Electrostatic Coulomb force. F = qE, applied to charged particle
    // materials only (POSITIVE_ION=77, NEGATIVE_ION=78, TRIBOELECTRIC=79).
    // Keep in sync with the charge_rasterize.comp material gate. The per-
    // particle q lives in particle_charge[p]; sign of q flips which way
    // the field pulls the particle.
    if (u_use_electrostatics != 0) {
        bool is_charged_mat = (mat_type == 77u || mat_type == 78u || mat_type == 79u);
        if (is_charged_mat) {
            float q = particle_charge[p];
            vec2 f_coulomb = coulomb_force(pos, q);
            // Per-frame cap on Coulomb acceleration so clustering into a
            // single super-charged blob can't explode the integrator.
            // 28 m/s^2 ≈ 2.9g — comparable to heavy-ferro max_mag_force.
            float fc_mag = length(f_coulomb);
            const float F_COULOMB_MAX = 28.0;
            if (fc_mag > F_COULOMB_MAX) f_coulomb *= F_COULOMB_MAX / fc_mag;
            new_vel += f_coulomb * u_dt;
        }
    }

    if (u_kinematic_targets_active != 0) {
        float w = spring_weight[idx];
        if (w > 0.0) {
            vec2 target_pos = spring_anchor[idx];
            vec2 to_target = target_pos - pos;
            new_vel += (to_target * (u_kinematic_target_force * w)
                        - new_vel * (u_kinematic_target_damping * w)) * u_dt;
        }
    }

    // Mode 3: Real Drag — per-particle targets maintain shape
    if (u_mouse_mode == 3) {
        float w = spring_weight[idx];
        if (w > 0.0) {
            vec2 target_pos = u_mouse_world + spring_anchor[idx];
            vec2 to_target = target_pos - pos;
            new_vel += (to_target * (u_mouse_force * w) - new_vel * (u_mouse_damping * w)) * u_dt;
        }
    }
    // Mode 1: Telekinesis — uniform force vector for all selected particles
    if (u_mouse_mode == 1) {
        float w = spring_weight[idx];
        if (w > 0.0) {
            vec2 force_dir = u_mouse_world - u_spring_origin;
            new_vel += (force_dir * (u_mouse_force * w) - new_vel * (u_mouse_damping * w)) * u_dt;
        }
    }

    // (Former fallback cursor magnet removed: the cursor is now always a
    //  dragged bar magnet in the real magnetics solver, so the Kelvin body
    //  force at line ~177 handles it via the solved |H|^2 gradient.)

    // Per-material gravity scaling (only when multi-scale mode is on)
    if (u_multi_scale == 1) {
        float grav_scale = 1.0;
        if (mat_type == 4u) grav_scale = 0.15;
        else if (mat_type == 9u || mat_type == 10u || mat_type == 22u || mat_type == 26u) grav_scale = 0.12;
        else if (mat_type == 19u || mat_type == 23u || mat_type == 27u) grav_scale = 0.10;
        else if (mat_type == 6u) grav_scale = 0.15;
        else if (mat_type == 30u) grav_scale = 0.12;
        else if (mat_type == 29u) grav_scale = 0.08;
        else if (mat_type == 14u || mat_type == 28u) grav_scale = 0.08;
        else if (mat_type == 32u || mat_type == 33u) grav_scale = 0.06;
        else if (mat_type == 34u) grav_scale = 0.10;
        else if (mat_type == 35u) grav_scale = 0.11;
        else if (mat_type == 36u) grav_scale = 0.08;
        else if (mat_type == 37u) grav_scale = 0.09;
        else if (mat_type == 38u) grav_scale = 0.11;
        else if (mat_type == 39u) grav_scale = 0.16;
        else if (mat_type == 40u) grav_scale = 0.14;
        else if (mat_type == 41u) grav_scale = 0.10;
        else if (mat_type == 42u) grav_scale = 0.11;
        else if (mat_type == 43u) grav_scale = 0.10;
        else if (mat_type == 44u) grav_scale = 0.10;
        else if (mat_type == 45u) grav_scale = 0.12;
        else if (mat_type == 46u) grav_scale = 0.10;
        else if (mat_type == 47u) grav_scale = 0.10;
        else if (mat_type == 48u) grav_scale = 0.11;
        else if (mat_type == 49u) grav_scale = 0.08;
        else if (mat_type == 59u) grav_scale = 0.10;
        else if (mat_type == 60u) grav_scale = 0.12;
        else if (mat_type == 61u) grav_scale = 0.12;
        else if (mat_type == 63u) grav_scale = 0.16;
        else if (mat_type == 64u) grav_scale = 0.18;
        else if (mat_type == 65u) grav_scale = 0.14;
        else if (mat_type == 66u) grav_scale = 0.14;
        else if (mat_type == 17u) grav_scale = 0.10;
        else if (mat_type == 20u) grav_scale = 0.10;
        else if (mat_type == 3u || mat_type == 5u || mat_type == 11u) grav_scale = 0.25;
        else if (mat_type == 12u || mat_type == 13u) grav_scale = 0.20;
        else if (mat_type == 24u) grav_scale = 0.15;
        else if (mat_type == 15u || mat_type == 18u) grav_scale = 0.10;
        if (grav_scale < 0.99)
            new_vel.y += (grav_scale - 1.0) * u_gravity.y * u_dt;
    }

    // Final clamp after buoyancy / magnetic / drag-tool forces. This is
    // the stage that previously let burning or magnetic particles escape
    // the early clamp and become high-energy pellets.
    speed = length(new_vel);
    if (speed > max_speed) {
        float s = max_speed / max(speed, 1e-6);
        new_vel *= s;
        new_C *= s;
    }

    float impact_delta = length(new_vel - old_vel);
    float impact_norm = impact_delta / max(max_speed * 0.20, 1e-5);
    float strain_proxy = clamp(length(vec4(new_C[0], new_C[1])) * (u_dx * u_dt * 0.08), 0.0, 1.0);
    float hit_signal = clamp(impact_norm + strain_proxy * 0.65, 0.0, 1.0);

    // Advect
    vec2 new_pos = pos + u_dt * new_vel;
    float collision_heat = 0.0;

    // Particle-level SDF collision
    if (u_use_sdf == 1) {
        float foot_contact = (u_kinematic_targets_active != 0) ? clamp(spring_weight[idx], 0.0, 1.0) : 0.0;
        float contact_margin = mix(0.003, 0.022, foot_contact);
        vec2 uv = (new_pos - u_sdf_world_min) / (u_sdf_world_max - u_sdf_world_min);
        if (uv.x >= 0.0 && uv.x <= 1.0 && uv.y >= 0.0 && uv.y <= 1.0) {
            float d = texture(u_sdf_tex, uv).r;
            vec2 collision_pos = new_pos;
            if (foot_contact > 0.0) {
                for (int s = 1; s <= 4; ++s) {
                    float t = float(s) * 0.25;
                    vec2 probe = mix(pos, new_pos, t);
                    vec2 probe_uv = (probe - u_sdf_world_min) / (u_sdf_world_max - u_sdf_world_min);
                    if (probe_uv.x < 0.0 || probe_uv.x > 1.0 || probe_uv.y < 0.0 || probe_uv.y > 1.0) continue;
                    float ds = texture(u_sdf_tex, probe_uv).r;
                    if (ds < d) {
                        d = ds;
                        uv = probe_uv;
                        collision_pos = probe;
                    }
                }
            }
            if (d < contact_margin) {
                vec2 pre_collision_vel = new_vel;
                vec2 eps = (u_sdf_world_max - u_sdf_world_min) / vec2(textureSize(u_sdf_tex, 0));
                float gdx = texture(u_sdf_tex, uv+vec2(eps.x,0)).r - texture(u_sdf_tex, uv-vec2(eps.x,0)).r;
                float gdy = texture(u_sdf_tex, uv+vec2(0,eps.y)).r - texture(u_sdf_tex, uv-vec2(0,eps.y)).r;
                vec2 n = normalize(vec2(gdx, gdy) + 1e-6);
                new_pos = collision_pos + n * (contact_margin - d);
                float vn = dot(new_vel, n);
                if (vn < 0.0) new_vel -= mix(1.3, 1.65, foot_contact) * vn * n;
                vec2 tangent = vec2(-n.y, n.x);
                float vt = dot(new_vel, tangent);
                new_vel -= vt * mix(0.08, 0.28, foot_contact) * tangent;
                float impact_speed = max(-dot(pre_collision_vel, n), 0.0);
                float tangential_speed = abs(dot(pre_collision_vel, tangent));
                float high_speed_gate = smoothstep(8.0, 24.0, impact_speed + tangential_speed * 0.6);
                if (high_speed_gate > 0.0) {
                    collision_heat = max(collision_heat,
                                         (40.0 + 220.0 * high_speed_gate) *
                                         max(impact_speed + tangential_speed * 0.45 - 8.0, 0.0) / 16.0);
                }
                speed = length(new_vel);
                if (speed > max_speed) new_vel *= max_speed / max(speed, 1e-6);
                velocities[p] = new_vel * mix(0.95, 0.90, foot_contact);
            }
        }
    }

    // Grid bounds clamp
    vec2 gmax = u_grid_origin + vec2(u_grid_res) * u_dx;
    float pad = u_dx * 3.0;
    new_pos = clamp(new_pos, u_grid_origin + pad, gmax - pad);
    positions[p] = new_pos;

    bool airtight_shell = (mat_type == 62u || mat_type == 38u);
    if (airtight_shell && u_use_airtight_pressure != 0) {
        float cavity_pressure = sample_airtight_pressure(new_pos);
        float trapped = sample_airtight_trapped(new_pos);
        if (cavity_pressure > 0.5 && trapped > 0.02) {
            vec2 grad_p = sample_airtight_pressure_gradient(new_pos);
            vec2 shell_push = -grad_p;
            float shell_like = (mat_type == 38u) ? 1.0 : (1.0 - smoothstep(0.14, 0.82, phase_data[idx]));
            float integrity = (mat_type == 38u)
                            ? (1.0 - smoothstep(0.18, 0.82, Jp_data[idx]))
                            : (1.0 - smoothstep(0.24, 0.92, Jp_data[idx]));
            float pressure_drive = smoothstep(1.5, 260.0, cavity_pressure) * trapped;
            float push_coeff = (mat_type == 38u) ? 0.34 : 0.24;
            float crack_coeff = (mat_type == 38u) ? 0.0056 : 0.0028;
            new_vel += shell_push * pressure_drive * shell_like * integrity * (push_coeff * u_dt);
            Jp_data[idx] = clamp(Jp_data[idx] + cavity_pressure * shell_like * integrity * crack_coeff * u_dt, 0.0, 1.0);
        }
    }

    if (mat_type == 59u) {
        float split = damage[idx];
        float heal = phase_data[idx];
        float pore = Jp_data[idx];
        split = clamp(max(split, hit_signal * 0.95) - 0.04 * u_dt, 0.0, 1.0);
        heal = clamp(heal - hit_signal * 0.30 + 0.34 * u_dt * (1.0 - split), 0.0, 1.0);
        pore = clamp(max(pore, hit_signal * 0.38) - 0.10 * u_dt, 0.0, 1.0);
        damage[idx] = split;
        phase_data[idx] = heal;
        Jp_data[idx] = pore;
    } else if (mat_type == 60u) {
        float jam = damage[idx];
        float yielded = phase_data[idx];
        float compact = Jp_data[idx];
        jam = clamp(max(jam, hit_signal * 1.35) - 0.02 * u_dt, 0.0, 1.0);
        yielded = clamp(max(yielded, hit_signal * 0.48) - 0.05 * u_dt, 0.0, 1.0);
        compact = clamp(max(compact, hit_signal * 0.42) - 0.04 * u_dt, 0.0, 1.0);
        damage[idx] = jam;
        phase_data[idx] = yielded;
        Jp_data[idx] = compact;
    } else if (mat_type == 61u) {
        float hard = damage[idx];
        float memory = phase_data[idx];
        float bruise = Jp_data[idx];
        hard = clamp(max(hard, hit_signal * 1.02) - 0.010 * u_dt, 0.0, 1.0);
        memory = clamp(max(memory, hit_signal * 1.06) - 0.015 * u_dt, 0.0, 1.0);
        bruise = clamp(max(bruise, hit_signal * 0.60) - 0.05 * u_dt, 0.0, 1.0);
        damage[idx] = hard;
        phase_data[idx] = memory;
        Jp_data[idx] = bruise;
    }

    velocities[p] = new_vel;
    affine_moms[idx] = vec4(new_C[0].x, new_C[0].y, new_C[1].x, new_C[1].y);

    // --- Thermal system ---
    float temp = temperatures[p];

    // Which materials respond to temperature?
    // Full thermal: interact with MPM grid temp + sources + ambient cooling
    bool full_thermal = (mat_type == 4u || mat_type == 6u ||
                         mat_type == 7u || mat_type == 8u ||
                         mat_type == 12u || mat_type == 13u ||
                         mat_type == 14u || mat_type == 15u ||
                         mat_type == 16u || mat_type == 17u ||
                         mat_type == 18u || mat_type == 19u ||
                         mat_type == 20u || mat_type == 21u ||
                         mat_type == 22u || mat_type == 23u ||
                         mat_type == 24u || mat_type == 25u ||
                         mat_type == 26u || mat_type == 27u ||
                         mat_type == 28u || mat_type == 29u ||
                         mat_type == 30u || mat_type == 31u ||
                         mat_type == 32u || mat_type == 33u ||
                         mat_type == 34u || mat_type == 35u ||
                         mat_type == 36u || mat_type == 37u ||
                         mat_type == 38u || mat_type == 40u ||
                         mat_type == 41u || mat_type == 42u ||
                         mat_type == 43u || mat_type == 44u ||
                         mat_type == 45u || mat_type == 46u ||
                         mat_type == 47u || mat_type == 48u ||
                         mat_type == 49u || mat_type == 62u ||
                         mat_type == 63u || mat_type == 64u || mat_type == 65u ||
                         mat_type == 66u || mat_type == 67u || mat_type == 68u ||
                         mat_type == 69u || mat_type == 70u || mat_type == 71u ||
                         mat_type == 72u || mat_type == 73u || mat_type == 74u ||
                         mat_type == 75u || mat_type == 76u || mat_type == 77u ||
                         mat_type == 78u || mat_type == 79u || mat_type == 80u);
    // Heat source only: gun + scene source + grid contact, no ambient cooling
    // Includes structural materials so they CAN be heated/ignited
    bool heat_source_only = (mat_type == 3u || mat_type == 5u ||
                             mat_type == 9u || mat_type == 10u || mat_type == 11u);
    // 3=ANISO, 5=FRACTURE, 9=HARDEN, 10=CERAMIC, 11=COMPOSITE
    // ELASTIC(1) and SNOW(2) remain completely non-thermal
    bool any_thermal = full_thermal || heat_source_only;

    if (any_thermal) {
        if (collision_heat > 0.0) {
            float friction_heat_gate = smoothstep(0.0, 120.0, collision_heat);
            temp += collision_heat * friction_heat_gate;
        }
        float ballistic_heat = smoothstep(0.45, 1.55, hit_signal) * smoothstep(7.0, 24.0, impact_delta * 18.0);
        if (ballistic_heat > 0.0) {
            temp += ballistic_heat * (6.0 + 36.0 * ballistic_heat);
        }
        float target_stall = 1.0 - smoothstep(3.0, 14.0, length(new_vel));
        float target_flash = smoothstep(0.10, 0.46, strain_proxy) *
                             smoothstep(1.4, 8.5, impact_delta) * target_stall;
        if (target_flash > 0.0) {
            temp += target_flash * (26.0 + 160.0 * target_flash);
        }
        // Grid-based heat transfer (object-to-object contact)
        // All thermal materials get this — needed for fire propagation
        if (full_thermal || heat_source_only) {
            float grid_temp_avg = 0.0;
            float grid_temp_weight = 0.0;
            for (int tgy = 0; tgy < 3; tgy++) {
                for (int tgx = 0; tgx < 3; tgx++) {
                    ivec2 tn = base + ivec2(tgx, tgy);
                    if (tn.x < 0 || tn.y < 0 || tn.x >= u_grid_res.x || tn.y >= u_grid_res.y)
                        continue;
                    float tw = wx[tgx] * wy[tgy];
                    uint tc = uint(tn.y * u_grid_res.x + tn.x);
                    float gt = grid_temp[tc];
                    if (gt > 0.0) {
                        grid_temp_avg += tw * gt;
                        grid_temp_weight += tw;
                    }
                }
            }
            if (grid_temp_weight > 0.01) {
                float gathered_temp = grid_temp_avg / grid_temp_weight;
                // Burning/ember particles resist grid cooling (they generate their own heat)
                float gather_rate = 1.0;
                if (mat_type == 7u || mat_type == 8u || mat_type == 16u || mat_type == 21u || mat_type == 25u || mat_type == 62u) {
                    // Only absorb heat FROM hotter neighbors, not cooler ones
                    if (gathered_temp < temp) gather_rate = 0.1;
                }
                if (mat_type == 62u && gathered_temp > temp + 2.0) gather_rate = 1.18;
                temp += (gathered_temp - temp) * gather_rate * u_dt;
            }
        }

        // Ambient heat source (from scene)
        if (u_heat_src_temp > 0.0) {
            float hd = length(new_pos - u_heat_src_pos);
            if (hd < u_heat_src_radius) {
                float falloff = 1.0 - hd / u_heat_src_radius;
                temp += (u_heat_src_temp - temp) * falloff * 0.5 * u_dt;
            }
        }
        // Heat gun (interactive) — strong for direct contact
        if (u_heat_power != 0.0) {
            float hd = length(new_pos - u_heat_pos);
            if (hd < u_heat_radius) {
                float falloff = 1.0 - hd / u_heat_radius;
                temp += u_heat_power * falloff * u_dt;
            }
        }
        if (u_use_air_heat != 0 && (full_thermal || heat_source_only)) {
            float air_temp = sample_air_temp(new_pos);
            float air_surplus = air_temp - temp;
            if (air_temp > u_ambient_temp + 20.0 && air_surplus > 2.0) {
                float plume = smoothstep(u_ambient_temp + 30.0, u_ambient_temp + 320.0, air_temp);
                float air_couple = heat_source_only ? 0.18 : 0.24;
                if (mat_type == 7u || mat_type == 8u || mat_type == 16u || mat_type == 21u || mat_type == 25u || mat_type == 62u) {
                    air_couple = (mat_type == 16u) ? 0.42 : 0.48;
                }
                float transfer_gate = smoothstep(8.0, 120.0, air_surplus);
                if (mat_type == 7u || mat_type == 8u || mat_type == 16u || mat_type == 21u || mat_type == 25u || mat_type == 62u) {
                    transfer_gate = smoothstep(4.0, 80.0, air_surplus);
                }
                temp += air_surplus * air_couple * plume * transfer_gate * u_dt;
            }
        }
        if (u_use_sdf == 1 && (full_thermal || heat_source_only)) {
            float sdf_contact_w = 0.0;
            float solid_temp = sample_sdf_contact_temp(new_pos, sdf_contact_w);
            float solid_surplus = solid_temp - temp;
            if (sdf_contact_w > 1e-4 && solid_surplus > 1.5) {
                float solid_couple = heat_source_only ? 0.72 : 0.90;
                if (mat_type == 7u || mat_type == 8u || mat_type == 16u || mat_type == 21u || mat_type == 25u || mat_type == 62u) {
                    solid_couple = (mat_type == 16u) ? 0.82 : 0.96;
                }
                temp += solid_surplus * solid_couple * sdf_contact_w * u_dt;
            }
        }
        if (full_thermal || heat_source_only) {
            float contact_temp_sum = 0.0;
            float contact_temp_weight = 0.0;
            for (int cgy = 0; cgy < 3; ++cgy) {
                for (int cgx = 0; cgx < 3; ++cgx) {
                    ivec2 cn = base + ivec2(cgx, cgy);
                    if (cn.x < 0 || cn.y < 0 || cn.x >= u_grid_res.x || cn.y >= u_grid_res.y) continue;
                    float ct = sample_contact_temp(cn);
                    if (ct <= u_ambient_temp + 10.0) continue;
                    float tw = wx[cgx] * wy[cgy];
                    contact_temp_sum += tw * ct;
                    contact_temp_weight += tw;
                }
            }
            if (contact_temp_weight > 0.01) {
                float contact_temp = contact_temp_sum / contact_temp_weight;
                if (contact_temp > temp + 3.0) {
                    float contact_couple = heat_source_only ? 0.32 : 0.45;
                    if (mat_type == 7u || mat_type == 8u || mat_type == 16u || mat_type == 21u || mat_type == 25u || mat_type == 62u) {
                        contact_couple = (mat_type == 16u) ? 0.62 : 0.72;
                    }
                    if (mat_type == 62u) contact_couple = 0.96;
                    temp += (contact_temp - temp) * contact_couple * u_dt;
                }
            }
        }
        // Ambient cooling (only for fully thermal materials)
        if (full_thermal) {
            float material_cooling = 1.0;
            if (mat_type == 7u) material_cooling = 0.40;       // burning solids keep heat
            else if (mat_type == 8u) material_cooling = 0.20;  // embers / coal hold heat longest
            else if (mat_type == 16u) material_cooling = 0.28; // oil pools stay hot and can relight
            else if (mat_type == 3u || mat_type == 11u) material_cooling = 0.62; // woods / composites
            else if (mat_type == 19u || mat_type == 23u || mat_type == 27u || mat_type == 29u) material_cooling = 0.82;
            else if (mat_type == 14u || mat_type == 28u) material_cooling = 0.76;
            else if (mat_type == 24u) material_cooling = 0.88;
            else if (mat_type == 30u) material_cooling = 0.68;
            else if (mat_type == 31u) material_cooling = 0.72;
            else if (mat_type == 67u) material_cooling = 0.68;
            else if (mat_type == 68u) material_cooling = 0.80; // diamagnetic: slightly cooler-preserving
            else if (mat_type == 69u) material_cooling = 1.25; // para mist: cools fast (low mass, aerosol)
            else if (mat_type == 70u) material_cooling = 0.55; // sticky ferro: dense, retains heat
            else if (mat_type == 71u) material_cooling = 1.80; // superconductor: cools ultra-fast (cryogenic wanted)
            else if (mat_type == 72u) material_cooling = 0.85; // Curie ferro: moderate cooling rate
            else if (mat_type == 73u) material_cooling = 1.40; // eddy copper: good thermal conductor, radiates heat quickly
            else if (mat_type == 74u) material_cooling = 0.75; // hard magnet: dense magnetite, retains heat
            else if (mat_type == 32u) material_cooling = 0.62;
            else if (mat_type == 33u) material_cooling = 0.58;
            else if (mat_type == 34u) material_cooling = 0.78;
            else if (mat_type == 35u) material_cooling = 0.74;
            else if (mat_type == 36u) material_cooling = 0.80;
            else if (mat_type == 37u) material_cooling = 0.82;
            else if (mat_type == 38u) material_cooling = 0.76;
            else if (mat_type == 40u) material_cooling = 0.70;
            else if (mat_type == 41u) material_cooling = 0.84;
            else if (mat_type == 42u) material_cooling = 0.74;
            else if (mat_type == 43u) material_cooling = 0.80;
            else if (mat_type == 44u) material_cooling = 0.86;
            else if (mat_type == 45u) material_cooling = 0.70;
            else if (mat_type == 46u) material_cooling = 0.82;
            else if (mat_type == 47u) material_cooling = 0.84;
            else if (mat_type == 48u) material_cooling = 0.74;
            else if (mat_type == 49u) material_cooling = 0.82;
            else if (mat_type == 62u) material_cooling = 0.26;
            else if (mat_type == 63u) material_cooling = 0.78;
            else if (mat_type == 64u) material_cooling = 0.84;
            else if (mat_type == 65u) material_cooling = 0.80;
            else if (mat_type == 66u) material_cooling = 0.86;
            if (u_enable_pseudo_25d != 0) {
                float depth_hold = clamp(u_pseudo_25d_depth, 0.0, 2.0);
                bool bake_kiln_mat = (mat_type == 14u || mat_type == 23u || mat_type == 27u ||
                                      mat_type == 34u || mat_type == 35u || mat_type == 36u ||
                                      mat_type == 38u || mat_type == 40u || mat_type == 41u ||
                                      mat_type == 42u || mat_type == 43u || mat_type == 44u ||
                                      mat_type == 45u || mat_type == 46u || mat_type == 47u ||
                                      mat_type == 48u || mat_type == 49u || mat_type == 63u ||
                                      mat_type == 64u || mat_type == 65u || mat_type == 66u);
                if (bake_kiln_mat) {
                    material_cooling *= max(1.0 - 0.18 * depth_hold, 0.55);
                }
            }
            float batch_cooling = max(thermal_params.z, 0.02);
            temp += (u_ambient_temp - temp) * u_particle_cooling * material_cooling * batch_cooling * u_dt;
        }
    }
    temperatures[p] = clamp(temp, 0.0, 1500.0);

    if ((u_use_bio_field != 0 && u_bio_coupling > 1e-5) ||
        (u_use_automata_field != 0 && u_automata_coupling > 1e-5)) {
        float bio_a = clamp(sample_bio_a(new_pos), 0.0, 1.0);
        float bio_b = clamp(sample_bio_b(new_pos), 0.0, 1.0);
        float bio_source = clamp(sample_bio_source(new_pos), 0.0, 1.0);
        vec2 bio_grad = sample_bio_b_gradient(new_pos);
        vec2 source_grad = sample_bio_source_gradient(new_pos);
        float bio_grad_mag = length(bio_grad);
        float source_grad_mag = length(source_grad);
        float bio_drive = clamp(bio_grad_mag * 0.16, 0.0, 2.2);
        float source_drive = clamp(source_grad_mag * 0.22, 0.0, 2.8);
        float bio_coupling = clamp(u_bio_coupling, 0.0, 6.0);
        float regrow_rate_raw = clamp(u_bio_regrowth_rate, 0.0, 16.0);
        float regrow_rate = regrow_rate_raw;
        if (regrow_rate_raw > 1.0) {
            float hi = regrow_rate_raw - 1.0;
            regrow_rate = 1.0 + hi * (0.90 + 0.20 * sqrt(hi));
        }
        float regrow_front_gain = 1.0 + 0.16 * min(regrow_rate, 18.0);

        float automata = clamp(sample_automata(new_pos), 0.0, 1.0);
        vec2 automata_grad = sample_automata_gradient(new_pos);
        float automata_grad_mag = length(automata_grad);
        float colony_drive = clamp(automata_grad_mag * 0.20, 0.0, 2.4);
        float automata_coupling = clamp(u_automata_coupling, 0.0, 6.0);
        float support = clamp(sample_bio_support(new_pos), 0.0, 1.0);
        vec2 support_grad = sample_bio_support_gradient(new_pos);
        float support_grad_mag = length(support_grad);
        vec2 edge_dir = (support_grad_mag > 1e-6) ? (-support_grad / support_grad_mag) : vec2(0.0);
        float support_edge = clamp(support_grad_mag * 0.18, 0.0, 1.2) *
                            smoothstep(0.01, 0.22, support) *
                            (1.0 - smoothstep(0.26, 0.72, support));

        vec2 field_grad = source_grad * bio_coupling * 1.55 +
                          bio_grad * bio_coupling * 0.85 +
                          automata_grad * automata_coupling * 1.10;
        float field_grad_mag = length(field_grad);
        vec2 field_dir = (field_grad_mag > 1e-6) ? (field_grad / field_grad_mag) : vec2(0.0);
        float field_drive = clamp(source_drive * bio_coupling + bio_drive * bio_coupling * 0.75 + colony_drive * automata_coupling, 0.0, 6.6);
        float chemical_growth = bio_b * (0.45 + 0.55 * (1.0 - bio_a));
        float scout_growth = bio_source * (0.62 + 0.38 * (1.0 - bio_a));
        float colony_fill = automata * (0.52 + 0.48 * (1.0 - bio_a));
        float combined_growth = max(max(chemical_growth * bio_coupling, scout_growth * bio_coupling * 1.18), colony_fill * automata_coupling);
        float bio_front = smoothstep(0.10, 0.28, bio_b) * (1.0 - smoothstep(0.34, 0.62, bio_b));
        float source_front = smoothstep(0.03, 0.16, bio_source) * (1.0 - smoothstep(0.24, 0.54, bio_source));
        float colony_front = smoothstep(0.14, 0.38, automata) * (1.0 - smoothstep(0.48, 0.78, automata));
        float pulse = 0.5 + 0.5 * sin(u_time * 7.5 + bio_b * 18.0 + automata * 11.0);
        float frontier_push = support_edge * max(max(source_front * 1.15, bio_front), colony_front * 0.9) * pulse;
        float density_gate = smoothstep(0.04, 0.32, support);
        float uncovered_bio = clamp(max(max(bio_source * 1.22, bio_b), automata) - density_gate * 0.68, 0.0, 1.0);
        float lead_pull = uncovered_bio * (0.55 + 0.65 * pulse) * clamp((1.0 + field_drive) / 4.8, 0.0, 1.2);
        float push_scale = 0.0;
        float pull_scale = 0.0;

        if ((mat_type == 59u || mat_type == 63u || mat_type == 64u || mat_type == 65u || mat_type == 66u) &&
            support_edge > 1e-5 && length(edge_dir) > 0.0) {
            push_scale = 5.8;
            if (mat_type == 63u) push_scale = 7.6;
            else if (mat_type == 64u) push_scale = 6.6;
            else if (mat_type == 65u) push_scale = 7.1;
            else if (mat_type == 66u) {
                float cool_gate = 1.0 - smoothstep(340.0, 395.0, temp);
                push_scale = mix(2.2, 4.8, cool_gate);
            }
            new_vel += edge_dir * (frontier_push * push_scale * (0.32 * bio_coupling + 0.28 * automata_coupling)) * u_dt;
        }
        if ((mat_type == 59u || mat_type == 63u || mat_type == 64u || mat_type == 65u || mat_type == 66u) &&
            lead_pull > 1e-5 && length(field_dir) > 0.0) {
            pull_scale = 7.6;
            if (mat_type == 63u) pull_scale = 9.0;
            else if (mat_type == 64u) pull_scale = 8.2;
            else if (mat_type == 65u) pull_scale = 8.8;
            else if (mat_type == 66u) {
                float cool_gate = 1.0 - smoothstep(340.0, 395.0, temp);
                pull_scale = mix(2.6, 5.4, cool_gate);
            }
            new_vel += field_dir * (lead_pull * pull_scale * (0.26 * bio_coupling + 0.24 * automata_coupling)) * u_dt;
        }

        if ((mat_type == 59u || mat_type == 63u || mat_type == 64u || mat_type == 65u || mat_type == 66u) &&
            (push_scale > 0.0 || pull_scale > 0.0)) {
            bio_debug_force =
                edge_dir * (frontier_push * push_scale * (0.32 * bio_coupling)) +
                field_dir * (lead_pull * pull_scale * (0.26 * bio_coupling));
            automata_debug_force =
                edge_dir * (frontier_push * push_scale * (0.28 * automata_coupling)) +
                field_dir * (lead_pull * pull_scale * (0.24 * automata_coupling)) +
                ((automata_grad_mag > 1e-6) ? (automata_grad / automata_grad_mag) : vec2(0.0)) *
                (colony_drive * (0.20 * automata_coupling));
        }

        if (mat_type == 59u) {
            float split = damage[idx];
            float heal = phase_data[idx];
            float pore = Jp_data[idx];
            heal = clamp(max(heal, max(max(bio_source * (0.72 + 0.28 * bio_coupling), bio_b * (0.52 + 0.24 * bio_coupling)), automata * (0.54 + 0.22 * automata_coupling))) - 0.012 * u_dt, 0.0, 1.0);
            split = clamp(split + max(bio_b - 0.68, 0.0) * 0.34 * bio_coupling * u_dt + max(automata - 0.76, 0.0) * 0.24 * automata_coupling * u_dt - bio_a * 0.025 * u_dt, 0.0, 1.0);
            pore = clamp(pore + combined_growth * 0.46 * u_dt - bio_a * 0.08 * u_dt, 0.0, 1.0);
            new_vel += field_dir * (3.2 * field_drive * (0.35 + 0.65 * heal)) * u_dt;
            damage[idx] = split;
            phase_data[idx] = heal;
            Jp_data[idx] = pore;
        } else if (mat_type == 33u) {
            float wilt = damage[idx];
            float spores = phase_data[idx];
            float crack = Jp_data[idx];
            spores = clamp(max(spores, max(bio_b * (0.58 + 0.24 * bio_coupling), automata * (0.52 + 0.18 * automata_coupling))) - 0.010 * u_dt, 0.0, 1.0);
            wilt = clamp(wilt - bio_b * 0.03 * u_dt + max(temp - 420.0, 0.0) * 0.00008 * u_dt, 0.0, 1.0);
            crack = clamp(crack + max(bio_b - 0.74, 0.0) * 0.28 * bio_coupling * u_dt + max(automata - 0.72, 0.0) * 0.16 * automata_coupling * u_dt, 0.0, 1.0);
            new_vel += field_dir * (2.4 * field_drive * (0.28 + 0.72 * spores)) * u_dt;
            new_vel.y += combined_growth * 0.30 * u_dt;
            damage[idx] = wilt;
            phase_data[idx] = spores;
            Jp_data[idx] = crack;
        } else if (mat_type == 34u) {
            float dry = damage[idx];
            float pore = phase_data[idx];
            float tear = Jp_data[idx];
            dry = clamp(dry + bio_b * 0.06 * bio_coupling * u_dt + max(automata - 0.60, 0.0) * 0.03 * automata_coupling * u_dt, 0.0, 1.0);
            pore = clamp(max(pore, combined_growth * (0.48 + 0.12 * automata_coupling)) - 0.010 * u_dt, 0.0, 1.0);
            tear = clamp(tear + max(bio_b - 0.72, 0.0) * 0.20 * bio_coupling * u_dt + max(automata - 0.78, 0.0) * 0.14 * automata_coupling * u_dt, 0.0, 1.0);
            damage[idx] = dry;
            phase_data[idx] = pore;
            Jp_data[idx] = tear;
        } else if (mat_type == 32u) {
            float brown = damage[idx];
            float dry = phase_data[idx];
            float blister = Jp_data[idx];
            brown = clamp(brown + max(bio_b - 0.42, 0.0) * 0.16 * bio_coupling * u_dt + max(automata - 0.64, 0.0) * 0.08 * automata_coupling * u_dt, 0.0, 1.0);
            dry = clamp(dry + combined_growth * 0.10 * u_dt, 0.0, 1.0);
            blister = clamp(max(blister, max(bio_b * 0.55, automata * 0.42)) - 0.008 * u_dt, 0.0, 1.0);
            damage[idx] = brown;
            phase_data[idx] = dry;
            Jp_data[idx] = blister;
        } else if (mat_type == 63u) {
            float morph_growth = damage[idx];
            float fold = phase_data[idx];
            float scar = Jp_data[idx];
            float burn_kill = smoothstep(430.0, 760.0, temp);
            morph_growth = clamp(max(morph_growth, max(max(scout_growth * (0.78 + 0.30 * bio_coupling),
                                                       chemical_growth * (0.64 + 0.22 * bio_coupling)),
                                                       colony_fill * (0.84 + 0.34 * automata_coupling))) - (0.004 + 0.090 * burn_kill) * u_dt, 0.0, 1.0);
            fold = clamp(fold + max(bio_b - 0.46, 0.0) * 0.22 * bio_coupling * u_dt +
                               max(automata - 0.50, 0.0) * 0.44 * automata_coupling * u_dt +
                               field_drive * 0.14 * u_dt - (bio_a * 0.010 + 0.16 * burn_kill) * u_dt, 0.0, 1.0);
            scar = clamp(max(scar, burn_kill * (0.35 + 0.50 * (1.0 - morph_growth))) +
                               max(bio_b - 0.80, 0.0) * 0.10 * bio_coupling * u_dt +
                               max(automata - 0.82, 0.0) * 0.12 * automata_coupling * u_dt - 0.006 * u_dt, 0.0, 1.0);
            new_vel += field_dir * (3.3 * field_drive * (0.28 + 0.72 * morph_growth) * (1.0 - 0.65 * burn_kill)) * u_dt;
            new_vel.y += morph_growth * (0.12 * bio_coupling + 0.30 * automata_coupling) * (1.0 - 0.60 * burn_kill) * u_dt;
            damage[idx] = morph_growth;
            phase_data[idx] = fold;
            Jp_data[idx] = scar;
        } else if (mat_type == 64u) {
            float colonize = damage[idx];
            float lignify = phase_data[idx];
            float branch = Jp_data[idx];
            float burn_kill = smoothstep(430.0, 760.0, temp);
            colonize = clamp(max(colonize, max(max(scout_growth * (0.74 + 0.32 * bio_coupling),
                                               chemical_growth * (0.54 + 0.24 * bio_coupling)),
                                               colony_fill * (0.72 + 0.32 * automata_coupling))) - (0.003 + 0.075 * burn_kill) * u_dt, 0.0, 1.0);
            lignify = clamp(lignify + max(colonize - 0.18, 0.0) * 0.12 * u_dt + max(temp - 325.0, 0.0) * 0.00016 * u_dt - 0.10 * burn_kill * u_dt, 0.0, 1.0);
            branch = clamp(max(branch, burn_kill * (0.28 + 0.42 * (1.0 - colonize))) + bio_drive * 0.22 * bio_coupling * u_dt +
                                   colony_drive * 0.34 * automata_coupling * u_dt +
                                   max(automata - 0.64, 0.0) * 0.14 * automata_coupling * u_dt - 0.004 * u_dt, 0.0, 1.0);
            new_vel += field_dir * (3.4 * field_drive * (0.22 + 0.58 * colonize) * (1.0 - 0.58 * burn_kill)) * u_dt;
            new_vel += vec2(0.0, 0.12) * colonize * (1.0 - 0.55 * burn_kill) * u_dt;
            damage[idx] = colonize;
            phase_data[idx] = lignify;
            Jp_data[idx] = branch;
        } else if (mat_type == 65u) {
            float bud = damage[idx];
            float seal = phase_data[idx];
            float frill = Jp_data[idx];
            float burn_kill = smoothstep(430.0, 760.0, temp);
            bud = clamp(max(bud, max(max(bio_source * (0.88 + 0.26 * bio_coupling),
                                     bio_b * (0.56 + 0.18 * bio_coupling)),
                                     automata * (0.90 + 0.34 * automata_coupling))) - (0.005 + 0.085 * burn_kill) * u_dt, 0.0, 1.0);
            seal = clamp(seal + chemical_growth * 0.10 * bio_coupling * u_dt +
                               max(automata - 0.40, 0.0) * 0.24 * automata_coupling * u_dt -
                               (max(bio_b - 0.82, 0.0) * 0.03 + 0.12 * burn_kill) * u_dt, 0.0, 1.0);
            frill = clamp(max(frill, burn_kill * (0.30 + 0.46 * (1.0 - bud))) + max(bio_b - 0.62, 0.0) * 0.18 * bio_coupling * u_dt +
                                max(automata - 0.52, 0.0) * 0.34 * automata_coupling * u_dt +
                                field_drive * 0.12 * u_dt - 0.004 * u_dt, 0.0, 1.0);
            new_vel += field_dir * (3.5 * field_drive * (0.30 + 0.70 * bud) * (1.0 - 0.62 * burn_kill)) * u_dt;
            new_vel.y += bud * (0.08 * bio_coupling + 0.24 * automata_coupling) * (1.0 - 0.60 * burn_kill) * u_dt;
            damage[idx] = bud;
            phase_data[idx] = seal;
            Jp_data[idx] = frill;
        } else if (mat_type == 66u) {
            float regrow = damage[idx];
            float ash = phase_data[idx];
            float crumble = Jp_data[idx];
            float burn_kill = smoothstep(430.0, 790.0, temp);
            float ash_memory = smoothstep(0.08, 0.92, ash);
            float cool_regrow = 1.0 - smoothstep(340.0, 395.0, temp);
            float live_front = max(max(scout_growth * (0.92 + 0.32 * bio_coupling),
                                       chemical_growth * (0.78 + 0.24 * bio_coupling)),
                                   colony_fill * (0.90 + 0.34 * automata_coupling));
            float dormant_wake = ash_memory * cool_regrow * regrow_front_gain *
                                 (0.12 + 0.52 * support +
                                  0.22 * max(max(bio_source, bio_b), automata));
            float scaffold_front = max(
                support * max(max(bio_source * 1.60, bio_b * 1.05), automata * 1.22) *
                    (0.28 + 0.72 * ash_memory) * cool_regrow * regrow_front_gain,
                dormant_wake);
            float growth_front = max(live_front, scaffold_front);
            float front_gate = smoothstep(0.003, 0.055, growth_front);
            float rebuild = max(growth_front, dormant_wake) * front_gate * cool_regrow *
                            (0.14 + 0.86 * ash_memory);
            float recovery = smoothstep(0.26, 0.84, regrow) * cool_regrow;

            ash = clamp(max(ash, burn_kill * (0.62 + 0.28 * (1.0 - regrow))) +
                        burn_kill * 0.70 * u_dt -
                        (0.010 + 0.34 * recovery * regrow_rate * (0.28 + 0.72 * growth_front) +
                         0.080 * front_gate * cool_regrow +
                         0.18 * rebuild * min(regrow_rate, 12.0)) * u_dt,
                       0.0, 1.0);

            float regrow_target = max(growth_front * front_gate * cool_regrow *
                                      (0.36 + 1.42 * ash_memory) * (1.0 - burn_kill * 0.97),
                                      dormant_wake * (0.30 + 0.90 * ash_memory));
            regrow += (regrow_target - regrow) * (0.34 + 1.26 * regrow_rate) * u_dt;
            regrow += rebuild * (0.06 + 0.12 * min(regrow_rate, 12.0)) * u_dt;
            regrow -= (0.006 + 0.018 * ash * (1.0 - growth_front) + 0.24 * burn_kill +
                       0.040 * (1.0 - cool_regrow) * ash_memory) * u_dt;
            regrow = clamp(regrow, 0.0, 1.0);

            crumble = clamp(max(crumble, burn_kill * (0.04 + 0.12 * ash)) -
                            recovery * 0.30 * regrow_rate * u_dt,
                            0.0, 1.0);

            new_vel += field_dir * (3.2 * field_drive * (0.10 + 0.38 * ash_memory) *
                                    (0.12 + 0.96 * regrow) * regrow_rate * cool_regrow *
                                    (1.0 - 0.55 * burn_kill)) * u_dt;
            new_vel.y += recovery * (0.04 * bio_coupling + 0.08 * automata_coupling) *
                         regrow_rate * u_dt;

            damage[idx] = regrow;
            phase_data[idx] = ash;
            Jp_data[idx] = crumble;
        }
    }

    // --- Visualization (skip if keeping batch colors, but still apply highlight) ---
    if (u_keep_colors == 1) {
        if (p >= u_highlight_start && p < u_highlight_end) {
            vec4 cur = colors[p];
            float pulse = sin(u_time * 6.0) * 0.3 + 0.7;
            vec3 gold = vec3(1.0, 0.85, 0.3);
            cur.rgb = mix(cur.rgb, gold, 0.5 * pulse);
            cur.rgb += gold * 0.4 * pulse;
            colors[p] = cur;
        } else {
            vec4 cur = colors[p];
            if (mat_type == 4u) {
                cur.rgb = mix(cur.rgb, heat_color((temp - 220.0) / 650.0), 0.35);
            } else if (mat_type == 5u) {
                float d = damage[idx];
                cur.rgb = mix(cur.rgb, vec3(0.2, 0.04, 0.02), d * 0.65);
            } else if (mat_type == 6u) {
                float phi = phase_data[idx];
                vec3 phase_c = (phi < 0.5)
                    ? mix(vec3(0.3,0.5,0.9), vec3(0.2,0.8,0.9), phi * 2.0)
                    : mix(vec3(0.2,0.8,0.9), vec3(0.15,0.4,0.8), (phi - 0.5) * 2.0);
                cur.rgb = mix(cur.rgb, phase_c, 0.55);
            } else if (mat_type == 7u) {
                float burn = damage[idx];
                vec3 burn_c;
                if (burn < 0.3) burn_c = mix(vec3(0.5,0.3,0.1), vec3(1.0,0.5,0.1), burn/0.3);
                else if (burn < 0.7) burn_c = mix(vec3(1.0,0.5,0.1), vec3(1.0,0.9,0.3), (burn-0.3)/0.4);
                else burn_c = mix(vec3(1.0,0.9,0.3), vec3(0.3,0.3,0.3), (burn-0.7)/0.3);
                cur.rgb = mix(cur.rgb, burn_c, 0.7);
            } else if (mat_type == 8u) {
                float glow = clamp((temp - 350.0) / 600.0, 0.0, 1.0);
                cur.rgb += vec3(0.45, 0.25, 0.08) * glow;
            } else if (mat_type == 9u) {
                float cured = damage[idx];
                cur.rgb = mix(cur.rgb, vec3(0.25,0.12,0.05), cured * 0.7);
            } else if (mat_type == 10u) {
                float crack = Jp_data[idx];
                cur.rgb = mix(cur.rgb, vec3(0.12, 0.05, 0.02), crack * 0.7);
            } else if (mat_type == 12u) {
                float d = damage[idx];
                cur.rgb = mix(cur.rgb, vec3(0.16, 0.05, 0.03), d * 0.55);
            } else if (mat_type == 13u) {
                float d = damage[idx];
                cur.rgb = mix(cur.rgb, vec3(0.2, 0.1, 0.06), d * 0.4);
            } else if (mat_type == 14u) {
                float soft = phase_data[idx];
                float crack = damage[idx];
