        color = vec4(viridis((jp - 0.6) / 1.4), 1.0);
    } else if (u_vis_mode == 7) {
        // Compression / density proxy
        color = vec4(coolwarm((density_proxy - 0.70) / 0.90), 1.0);
    } else if (u_vis_mode == 8) {
        // Packed RGB: temperature, stress, damage
        color = vec4(vec3(temp_vis, stress_vis, damage_vis), 1.0);
        } else if (u_vis_mode == 9) {
            // Packed RGB: damage/hardening, phase/memory, plasticity/compression
