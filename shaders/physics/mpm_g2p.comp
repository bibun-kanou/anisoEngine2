                (mat_type == 32u || mat_type == 33u || mat_type == 34u || mat_type == 59u ||
                 mat_type == 63u || mat_type == 64u || mat_type == 65u || mat_type == 66u)) {
                float bio_vis = max(clamp(sample_bio_b(new_pos), 0.0, 1.0),
                                    clamp(sample_bio_source(new_pos) * 1.2, 0.0, 1.0));
                float auto_vis = clamp(sample_automata(new_pos), 0.0, 1.0);
                vec3 bio_c = mix(vec3(0.18, 0.34, 0.92), vec3(0.96, 0.96, 0.74), bio_vis);
