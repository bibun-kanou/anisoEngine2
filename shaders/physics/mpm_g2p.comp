            color = vec4(vec3(damage_vis, phase_vis, blue), 1.0);
        } else if (u_vis_mode == 10) {
            // Latent SmoothLife / colony field sampled at the particle.
            float latent_raw = clamp(sample_automata(new_pos) * max(u_automata_view_gain, 0.01), 0.0, 1.0);
            vec2 latent_grad = sample_automata_gradient(new_pos);
            float frontier = clamp(length(latent_grad) * 0.55, 0.0, 1.0);
            float latent = smoothstep(0.004, 0.24, latent_raw);
            latent = pow(latent, 0.58);
            float plateau = smoothstep(0.05, 0.54, latent_raw);
            vec3 c;
            if (latent < 0.20) c = mix(vec3(0.08, 0.10, 0.18), vec3(0.18, 0.34, 0.86), latent / 0.20);
            else if (latent < 0.48) c = mix(vec3(0.18, 0.34, 0.86), vec3(0.18, 0.86, 0.62), (latent - 0.20) / 0.28);
            else if (latent < 0.78) c = mix(vec3(0.18, 0.86, 0.62), vec3(0.98, 0.88, 0.28), (latent - 0.48) / 0.30);
            else c = mix(vec3(0.98, 0.88, 0.28), vec3(1.0, 0.98, 0.92), (latent - 0.78) / 0.22);
            c = mix(c, vec3(1.0, 0.97, 0.90), plateau * 0.30);
            c = mix(c, vec3(1.0, 0.90, 1.0), frontier * 0.82);
            c += vec3(0.06, 0.08, 0.12) * frontier;
